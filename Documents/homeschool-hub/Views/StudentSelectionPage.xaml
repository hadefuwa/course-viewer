<Page x:Class="HomeschoolHub.Views.StudentSelectionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Padding="20">
        <StackPanel MaxWidth="600">
            <TextBlock Text="👤 Select or Create Student" 
                      FontSize="28" 
                      FontWeight="Bold"
                      Margin="0,0,0,20"/>

            <!-- Create New Student -->
            <Border Background="#E8F4F8" Padding="20" CornerRadius="10" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Create New Student" FontSize="20" FontWeight="SemiBold"/>
                    
                    <TextBox x:Name="StudentNameTextBox" 
                            PlaceholderText="Enter student name"
                            FontSize="16"
                            Padding="10"
                            Margin="0,0,0,15"/>
                    
                    <StackPanel Margin="0,15,0,0">
                        <TextBlock Text="Age" FontSize="14" Margin="0,0,0,5"/>
                        <TextBox x:Name="StudentAgeTextBox"
                                Text="7"
                                FontSize="16"/>
                    </StackPanel>
                    
                    <Button x:Name="CreateStudentButton"
                            Content="Create Student"
                            Click="CreateStudentButton_Click"
                            Background="#4A90E2"
                            Foreground="White"
                            Padding="15"
                            FontSize="16"
                            FontWeight="SemiBold"
                            CornerRadius="5"/>
                </StackPanel>
            </Border>

            <!-- Existing Students -->
            <TextBlock Text="Existing Students" FontSize="20" FontWeight="SemiBold"/>
            
            <ListView x:Name="StudentsListView"
                     SelectionMode="Single"
                     SelectionChanged="StudentsListView_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" 
                               Padding="15" 
                               Margin="0,5"
                               CornerRadius="5"
                               BorderBrush="#E0E0E0"
                               BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👤" FontSize="24" VerticalAlignment="Center"/>
                                <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" 
                                              FontSize="18" 
                                              FontWeight="SemiBold"/>
                                    <TextBlock FontSize="14" 
                                              Foreground="Gray">
                                        <Run Text="Age: "/>
                                        <Run Text="{Binding Age}"/>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Button x:Name="BackButton"
                    Content="Back to Home"
                    Click="BackButton_Click"
                    Margin="0,20,0,0"
                    Padding="15"
                    Background="#E0E0E0"
                    CornerRadius="5"/>
        </StackPanel>
    </Grid>
</Page>

