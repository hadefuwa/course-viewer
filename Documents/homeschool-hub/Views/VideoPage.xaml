<Page x:Class="HomeschoolHub.Views.VideoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#F38181" Padding="15">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BackButton"
                        Click="BackButton_Click"
                        Background="Transparent"
                        Foreground="White"
                        Content="← Back"
                        FontSize="16"
                        Margin="0,0,20,0"/>
                <TextBlock x:Name="VideoTitleText" 
                          Text="Video" 
                          FontSize="24" 
                          FontWeight="Bold" 
                          Foreground="White"
                          VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Video Content -->
        <Grid Grid.Row="1" Padding="20">
            <ScrollViewer>
                <StackPanel>
                    <TextBlock x:Name="VideoDescriptionText" 
                              Text="" 
                              FontSize="16"
                              TextWrapping="Wrap"
                              Margin="0,0,0,20"/>
                    
                    <Border Background="Black" 
                           Height="400" 
                           CornerRadius="10"
                           Padding="0"
                           x:Name="VideoContainer">
                        <!-- WebView2 will be added programmatically -->
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>

