<Page x:Class="HomeschoolHub.Views.QuizPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#4ECDC4" Padding="15">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="QuizTitleText" 
                          Text="Quiz" 
                          FontSize="24" 
                          FontWeight="Bold" 
                          Foreground="White"
                          VerticalAlignment="Center"/>
                <TextBlock x:Name="QuestionNumberText" 
                          Text="" 
                          FontSize="18" 
                          Foreground="White"
                          Margin="20,0,0,0"
                          VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Question Content -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel x:Name="QuestionStackPanel"/>
        </ScrollViewer>

        <!-- Navigation -->
        <Border Grid.Row="2" Background="#F0F0F0" Padding="15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="PreviousButton"
                        Content="Previous"
                        Click="PreviousButton_Click"
                        IsEnabled="False"
                        Padding="15,10"
                        Background="#E0E0E0"
                        CornerRadius="5"/>
                <Button x:Name="NextButton"
                        Content="Next"
                        Click="NextButton_Click"
                        Padding="15,10"
                        Background="#4ECDC4"
                        Foreground="White"
                        CornerRadius="5"/>
                <Button x:Name="SubmitButton"
                        Content="Submit Quiz"
                        Click="SubmitButton_Click"
                        Visibility="Collapsed"
                        Padding="15,10"
                        Background="#4A90E2"
                        Foreground="White"
                        CornerRadius="5"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>

