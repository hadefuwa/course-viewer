<Page x:Class="HomeschoolHub.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#4A90E2" Padding="20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📚 Homeschool Hub" 
                          FontSize="32" 
                          FontWeight="Bold" 
                          Foreground="White"
                          VerticalAlignment="Center"/>
                <TextBlock x:Name="StudentNameText" 
                          Text="" 
                          FontSize="20" 
                          Foreground="White"
                          Margin="20,0,0,0"
                          VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel>
                <TextBlock Text="Welcome! Choose what you'd like to learn:" 
                          FontSize="24" 
                          FontWeight="SemiBold"
                          Margin="0,0,0,20"/>

                <!-- Category Cards -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Maths Card -->
                    <Button Grid.Row="0" Grid.Column="0" 
                            x:Name="MathsButton"
                            Click="MathsButton_Click"
                            Margin="5" 
                            Padding="20"
                            Background="#FF6B9E"
                            CornerRadius="10">
                        <StackPanel>
                            <TextBlock Text="🔢" FontSize="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="Maths" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            <TextBlock Text="Reception Age" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- History Card -->
                    <Button Grid.Row="0" Grid.Column="1" 
                            x:Name="HistoryButton"
                            Click="HistoryButton_Click"
                            Margin="5" 
                            Padding="20"
                            Background="#4ECDC4"
                            CornerRadius="10">
                        <StackPanel>
                            <TextBlock Text="⚔️" FontSize="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="Vikings" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            <TextBlock Text="Age 7+" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Arduino Card -->
                    <Button Grid.Row="1" Grid.Column="0" 
                            x:Name="ArduinoButton"
                            Click="ArduinoButton_Click"
                            Margin="5" 
                            Padding="20"
                            Background="#95E1D3"
                            CornerRadius="10">
                        <StackPanel>
                            <TextBlock Text="⚡" FontSize="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="Arduino" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            <TextBlock Text="Programming" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Fusion 360 Card -->
                    <Button Grid.Row="1" Grid.Column="1" 
                            x:Name="Fusion360Button"
                            Click="Fusion360Button_Click"
                            Margin="5" 
                            Padding="20"
                            Background="#F38181"
                            CornerRadius="10">
                        <StackPanel>
                            <TextBlock Text="🎨" FontSize="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="Fusion 360" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            <TextBlock Text="3D Design" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Progress Button -->
                <Button x:Name="ProgressButton"
                        Click="ProgressButton_Click"
                        Margin="5" 
                        Padding="20"
                        Background="#FFD93D"
                        CornerRadius="10"
                        HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📊" FontSize="32" VerticalAlignment="Center"/>
                        <TextBlock Text="View My Progress" 
                                  FontSize="18" 
                                  FontWeight="Bold" 
                                  Margin="15,0,0,0"
                                  VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Student Selection Button -->
                <Button x:Name="StudentButton"
                        Click="StudentButton_Click"
                        Margin="5" 
                        Padding="15"
                        Background="#E8E8E8"
                        CornerRadius="10"
                        HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="👤" FontSize="24" VerticalAlignment="Center"/>
                        <TextBlock Text="Change Student" 
                                  FontSize="16" 
                                  Margin="15,0,0,0"
                                  VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

