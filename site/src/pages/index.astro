---
import HomeLayout from "../layouts/HomeLayout.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const courses = [
  {
    unit: "Unit 6",
    code: "CP4807",
    title: "Introduction to Microcontrollers",
    subject: "Electronics & Programming",
    hours: 60,
    worksheets: 12,
    tiers: ["Bronze", "Silver", "Gold"],
    live: true,
    href: `${base}/course`,
    thumb: `${base}/images/flashing_light.jpg`,
  },
  {
    unit: "Unit 8",
    title: "Mechanical Principles",
    subject: "Engineering Science",
    hours: 60,
    live: false,
    thumb: `${base}/images/course-mechanical.jpg`,
  },
  {
    unit: "Unit 13",
    title: "Fundamentals of Thermodynamics and Heat Engines",
    subject: "Engineering Science",
    hours: 60,
    live: false,
    thumb: `${base}/images/course-thermodynamics.jpg`,
  },
  {
    unit: "Unit 15",
    title: "Automation, Robotics and PLCs",
    subject: "Control Systems",
    hours: 60,
    live: false,
    thumb: `${base}/images/course-automation.jpg`,
  },
  {
    unit: "Unit 19",
    title: "Electrical and Electronic Principles",
    subject: "Electronics",
    hours: 60,
    live: false,
    thumb: `${base}/images/course-electrical.jpg`,
  },
];
---
<HomeLayout>

  <!-- Ticker -->
  <div class="hp-ticker" aria-hidden="true">
    <div class="hp-ticker-track">
      {Array.from({length: 3}).map(() => (
        <span>BTEC NATIONAL&nbsp;&nbsp;·&nbsp;&nbsp;HIGHER NATIONAL&nbsp;&nbsp;·&nbsp;&nbsp;MICROCONTROLLERS&nbsp;&nbsp;·&nbsp;&nbsp;MECHANICAL PRINCIPLES&nbsp;&nbsp;·&nbsp;&nbsp;THERMODYNAMICS&nbsp;&nbsp;·&nbsp;&nbsp;AUTOMATION &amp; ROBOTICS&nbsp;&nbsp;·&nbsp;&nbsp;ELECTRONICS&nbsp;&nbsp;·&nbsp;&nbsp;E-BLOCKS 3&nbsp;&nbsp;·&nbsp;&nbsp;FLOWCODE&nbsp;&nbsp;·&nbsp;&nbsp;</span>
      ))}
    </div>
  </div>

  <!-- Hero -->
  <section class="hp-hero">
    <div class="hp-hero-glow" aria-hidden="true"></div>
    <div class="container hp-hero-inner">
      <div class="hp-eyebrow">Matrix TSL · Course Viewer</div>
      <h1 class="hp-headline">
        Welcome to<br/>
        <span class="hp-headline-accent">Matrix TSL's</span><br/>
        Course Viewer
      </h1>
      <p class="hp-sub">
        Below are our 60–120 hour courses on all the BTEC National and Higher National Units.
        Built for E-blocks 3 and Flowcode, designed to take learners from first principles
        through to advanced engineering systems.
      </p>
      <div class="hp-stats-row">
        <div class="hp-stat">
          <span class="hp-stat-n">5</span>
          <span class="hp-stat-l">Subjects</span>
        </div>
        <div class="hp-stat-divider" aria-hidden="true"></div>
        <div class="hp-stat">
          <span class="hp-stat-n">300+</span>
          <span class="hp-stat-l">Hours of Content</span>
        </div>
        <div class="hp-stat-divider" aria-hidden="true"></div>
        <div class="hp-stat">
          <span class="hp-stat-n">12</span>
          <span class="hp-stat-l">Worksheets Live</span>
        </div>
        <div class="hp-stat-divider" aria-hidden="true"></div>
        <div class="hp-stat">
          <span class="hp-stat-n">100%</span>
          <span class="hp-stat-l">Interactive</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Course Library -->
  <section class="container hp-library">
    <div class="hp-library-head">
      <h2 class="hp-library-title">Course Library</h2>
      <p class="hp-library-sub">Browse our complete collection of interactive BTEC course modules. More units coming soon.</p>
    </div>

    <div class="hp-grid">
      {courses.map((c) => c.live ? (
        <a class="hp-card hp-card--live" href={c.href}>
          {c.thumb && <div class="hp-card-thumb" style={`background-image:url('${c.thumb}')`}></div>}
          <div class="hp-card-body">
            <div class="hp-card-top">
              <span class="hp-card-unit">{c.unit}</span>
              <span class="hp-card-live-badge">● Live</span>
            </div>
            <h3 class="hp-card-title">{c.title}</h3>
            <p class="hp-card-subject">{c.subject}</p>
            <div class="hp-card-meta-row">
              <span class="hp-card-meta-item">{c.code}</span>
              <span class="hp-card-meta-sep">·</span>
              <span class="hp-card-meta-item">{c.hours} hours</span>
              <span class="hp-card-meta-sep">·</span>
              <span class="hp-card-meta-item">{c.worksheets} worksheets</span>
            </div>
            <div class="hp-card-tiers">
              {c.tiers?.map((t) => (
                <span class={`hp-tier hp-tier--${t.toLowerCase()}`}>{t}</span>
              ))}
            </div>
            <div class="hp-card-cta">
              View Course
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
        </a>
      ) : (
        <div class="hp-card hp-card--soon">
          {c.thumb && <div class="hp-card-thumb" style={`background-image:url('${c.thumb}')`}></div>}
          <div class="hp-card-body">
            <div class="hp-card-top">
              <span class="hp-card-unit">{c.unit}</span>
              <span class="hp-card-soon-badge">Coming Soon</span>
            </div>
            <h3 class="hp-card-title">{c.title}</h3>
            <p class="hp-card-subject">{c.subject}</p>
            <div class="hp-card-meta-row">
              <span class="hp-card-meta-item">{c.hours} hours</span>
              <span class="hp-card-meta-sep">·</span>
              <span class="hp-card-meta-item">BTEC National</span>
            </div>
            <div class="hp-card-lock" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

</HomeLayout>

<style is:global>
/* ===== HOMEPAGE BODY ===== */
.hp-body {
  background:
    linear-gradient(rgba(255,255,255,0.018) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.018) 1px, transparent 1px),
    radial-gradient(ellipse 120% 60% at 50% -5%, rgba(147,51,234,0.12), transparent 55%),
    #080c15;
  background-size: 56px 56px, 56px 56px, 100% 100%, 100% 100%;
  color: #e8edf5;
}

/* ===== HEADER ===== */
.hp-header {
  position: sticky; top: 0; z-index: 50;
  backdrop-filter: blur(12px);
  background: rgba(8,12,21,0.82);
  border-bottom: 1px solid rgba(255,255,255,0.07);
  box-shadow: 0 1px 0 rgba(147,51,234,0.4);
}
.hp-header-inner {
  display: flex; align-items: center; justify-content: space-between;
  height: 68px;
}
.hp-brand {
  display: flex; align-items: center; gap: 14px;
  text-decoration: none;
}
.hp-brand:hover { text-decoration: none; }
.hp-logo { height: 28px; width: auto; display: block; }
.hp-brand-divider {
  width: 1px; height: 22px;
  background: rgba(255,255,255,0.18);
  flex-shrink: 0;
}
.hp-brand-label {
  font-size: 13px; font-weight: 500; letter-spacing: 0.04em;
  color: rgba(255,255,255,0.55); text-transform: uppercase;
}
.hp-nav {
  display: flex; align-items: center; gap: 24px;
}
.hp-nav a {
  font-size: 13px; color: rgba(255,255,255,0.5); text-decoration: none;
  transition: color .15s;
}
.hp-nav a:hover, .hp-nav a.active { color: #fff; text-decoration: none; }

/* ===== TICKER ===== */
.hp-ticker {
  overflow: hidden;
  background: rgba(147,51,234,0.08);
  border-bottom: 1px solid rgba(147,51,234,0.25);
  height: 32px;
  display: flex; align-items: center;
}
.hp-ticker-track {
  display: flex; white-space: nowrap;
  font-size: 10px; font-weight: 700; letter-spacing: 0.12em;
  color: rgba(167,91,255,0.8);
  animation: hpTicker 40s linear infinite;
}
@keyframes hpTicker {
  from { transform: translateX(0); }
  to   { transform: translateX(-33.333%); }
}

/* ===== HERO ===== */
.hp-hero {
  position: relative;
  padding: 96px 0 72px;
  overflow: hidden;
}
.hp-hero-glow {
  position: absolute;
  top: -120px; left: 50%; transform: translateX(-50%);
  width: 800px; height: 400px;
  background: radial-gradient(ellipse, rgba(147,51,234,0.16), transparent 70%);
  pointer-events: none;
}
.hp-hero-inner {
  position: relative; z-index: 1;
}
.hp-eyebrow {
  font-size: 11px; font-weight: 700; letter-spacing: 0.16em;
  text-transform: uppercase;
  color: rgba(167,91,255,0.9);
  margin-bottom: 20px;
  animation: hpFadeUp 0.6s ease 0.05s both;
}
.hp-headline {
  font-size: clamp(44px, 6.5vw, 82px);
  font-weight: 900;
  letter-spacing: -0.035em;
  line-height: 0.95;
  margin: 0 0 28px;
  color: #fff;
  animation: hpFadeUp 0.6s ease 0.15s both;
}
.hp-headline-accent { color: #a855f7; }
.hp-sub {
  font-size: clamp(15px, 1.6vw, 17px);
  color: rgba(232,237,245,0.6);
  max-width: 680px;
  line-height: 1.75;
  margin: 0 0 48px;
  animation: hpFadeUp 0.6s ease 0.25s both;
}
.hp-stats-row {
  display: flex; align-items: center; flex-wrap: wrap; gap: 0;
  animation: hpFadeUp 0.6s ease 0.35s both;
}
.hp-stat {
  display: flex; flex-direction: column; gap: 3px;
  padding: 0 28px 0 0;
}
.hp-stat:first-child { padding-left: 0; }
.hp-stat-n {
  font-size: 28px; font-weight: 800; letter-spacing: -0.03em;
  color: #fff; line-height: 1;
}
.hp-stat-l {
  font-size: 11px; text-transform: uppercase; letter-spacing: 0.07em;
  color: rgba(232,237,245,0.45);
}
.hp-stat-divider {
  width: 1px; height: 36px;
  background: rgba(255,255,255,0.1);
  margin: 0 28px 0 0;
  flex-shrink: 0;
}

/* ===== LIBRARY SECTION ===== */
.hp-library {
  padding: 0 24px 100px;
}
.hp-library-head {
  margin-bottom: 32px;
}
.hp-library-title {
  font-size: clamp(22px, 2.5vw, 28px);
  font-weight: 800; letter-spacing: -0.02em;
  color: #fff; margin: 0 0 8px;
}
.hp-library-sub {
  font-size: 14px; color: rgba(232,237,245,0.45);
  margin: 0;
}

/* ===== COURSE GRID ===== */
.hp-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}
@media (max-width: 900px) {
  .hp-grid { grid-template-columns: repeat(2, 1fr); }
  .hp-card--live { grid-column: span 2; }
}
@media (max-width: 600px) {
  .hp-grid { grid-template-columns: 1fr; }
  .hp-card--live { grid-column: span 1; }
}

/* ===== COURSE CARDS ===== */
.hp-card {
  background: rgba(15, 22, 40, 0.9);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 16px;
  padding: 0;
  display: flex; flex-direction: column; gap: 0;
  position: relative;
  overflow: hidden;
}
.hp-card-thumb {
  width: 100%;
  aspect-ratio: 16 / 9;
  background: #0a0e1a center / cover no-repeat;
  flex-shrink: 0;
}
.hp-card-body {
  display: flex; flex-direction: column; gap: 10px;
  padding: 20px 22px 22px;
  flex: 1;
}

/* Live card */
.hp-card--live {
  grid-column: span 2;
  border-color: rgba(147,51,234,0.4);
  border-top: 3px solid #9333ea;
  text-decoration: none;
  color: inherit;
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  cursor: pointer;
}
.hp-card--live::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 80% 60% at 0% 100%, rgba(147,51,234,0.08), transparent 60%);
  pointer-events: none;
}
.hp-card--live:hover {
  transform: translateY(-3px);
  box-shadow: 0 16px 48px rgba(147,51,234,0.22), 0 4px 16px rgba(0,0,0,0.4);
  border-color: rgba(147,51,234,0.65);
  text-decoration: none;
}

/* Coming soon cards */
.hp-card--soon {
  opacity: 0.42;
  filter: grayscale(0.5);
  cursor: not-allowed;
  border-top: 3px solid rgba(255,255,255,0.1);
}

/* Card internals */
.hp-card-top {
  display: flex; align-items: center; justify-content: space-between;
  gap: 8px;
}
.hp-card-unit {
  font-size: 11px; font-weight: 700; letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.4);
}
.hp-card-live-badge {
  font-size: 11px; font-weight: 700; letter-spacing: 0.06em;
  color: #4ade80;
  background: rgba(74,222,128,0.1);
  border: 1px solid rgba(74,222,128,0.25);
  padding: 3px 10px; border-radius: 999px;
}
.hp-card-soon-badge {
  font-size: 11px; font-weight: 600; letter-spacing: 0.06em;
  color: rgba(255,255,255,0.35);
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  padding: 3px 10px; border-radius: 999px;
}
.hp-card-title {
  font-size: clamp(17px, 1.8vw, 21px);
  font-weight: 700; letter-spacing: -0.02em;
  color: #fff; margin: 0;
  line-height: 1.25;
}
.hp-card-subject {
  font-size: 13px; color: rgba(232,237,245,0.45);
  margin: 0;
}
.hp-card-meta-row {
  display: flex; align-items: center; gap: 7px;
  flex-wrap: wrap;
}
.hp-card-meta-item {
  font-size: 12px; color: rgba(232,237,245,0.45);
}
.hp-card-meta-sep { color: rgba(232,237,245,0.2); font-size: 11px; }

.hp-card-tiers {
  display: flex; gap: 6px; flex-wrap: wrap;
  margin-top: 4px;
}
.hp-tier {
  font-size: 11px; font-weight: 700; letter-spacing: 0.04em;
  padding: 3px 10px; border-radius: 999px;
  text-transform: uppercase;
}
.hp-tier--bronze { background: rgba(205,127,50,0.15); color: #e8a96e; border: 1px solid rgba(205,127,50,0.25); }
.hp-tier--silver { background: rgba(192,192,192,0.12); color: #d6d6d6; border: 1px solid rgba(192,192,192,0.2); }
.hp-tier--gold   { background: rgba(255,211,77,0.12);  color: #ffe082; border: 1px solid rgba(255,211,77,0.2); }

.hp-card-cta {
  display: flex; align-items: center; gap: 8px;
  margin-top: auto; padding-top: 12px;
  font-size: 13px; font-weight: 600;
  color: #a855f7;
  transition: gap 0.2s ease;
}
.hp-card--live:hover .hp-card-cta { gap: 12px; }

.hp-card-lock {
  position: absolute; bottom: 20px; right: 20px;
  color: rgba(255,255,255,0.15);
}

/* ===== FOOTER ===== */
.hp-footer {
  border-top: 1px solid rgba(255,255,255,0.07);
  padding: 28px 0;
}
.hp-footer-inner {
  display: flex; align-items: center; flex-wrap: wrap; gap: 16px;
  justify-content: space-between;
}
.hp-footer-logo { height: 20px; width: auto; opacity: 0.4; }
.hp-footer-inner span { font-size: 12px; color: rgba(255,255,255,0.3); }
.hp-footer-inner a { font-size: 12px; color: rgba(255,255,255,0.3); text-decoration: none; }
.hp-footer-inner a:hover { color: rgba(255,255,255,0.6); }

/* ===== ANIMATIONS ===== */
@keyframes hpFadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}
</style>
