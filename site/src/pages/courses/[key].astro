---
import Base from "../../layouts/Base.astro";
import { getCourseByKey } from "../../lib/supabase";

const { key } = Astro.params;
const course = await getCourseByKey(key!);
if (!course) return Astro.redirect("/");

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const worksheets = ((course.sections ?? []) as any[]).filter((s: any) => s.kind === "worksheet");
const tiers: any[] = course.tiers ?? [];

function tierColor(name: string) {
  if (name === "Bronze") return "#cd7f32";
  if (name === "Silver") return "#c0c0c0";
  if (name === "Gold")   return "#ffd34d";
  return "#4dd0ff";
}

function worksheetsForTier(tier: any) {
  return worksheets.filter((w: any) => {
    const n = w.number;
    return n >= tier.range[0] && n <= tier.range[1];
  });
}
---
<Base title={`${course.title} — ${course.unit || course.code}`} active="unit6">

  <!-- Course Hero -->
  <section class="course-hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="container hero-inner">
      <div class="hero-eyebrow">{course.code} · {course.unit || "Course Overview"}</div>
      <h1 class="hero-title">{course.title}</h1>
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="stat-num">{course.hours ?? "—"}</span>
          <span class="stat-lbl">Hours</span>
        </div>
        <div class="hero-stat">
          <span class="stat-num">{worksheets.length}</span>
          <span class="stat-lbl">Worksheets</span>
        </div>
        <div class="hero-stat">
          <span class="stat-num">{tiers.length}</span>
          <span class="stat-lbl">Tiers</span>
        </div>
      </div>
      <div class="hero-actions">
        {worksheets.length > 0 && (
          <a href={`${base}/courses/${key}/worksheets/${worksheets[0].number}`} class="btn-start">
            Start Worksheet 1 →
          </a>
        )}
        <a href={`${base}/`} class="btn-back">← All Courses</a>
      </div>
    </div>
  </section>

  <!-- Tiers + Worksheet Grid -->
  <section class="container worksheets-section">
    {tiers.length > 0 ? tiers.map((tier: any) => {
      const ws = worksheetsForTier(tier);
      return (
        <div class="tier-block">
          <div class="tier-header" style={`--tier-color: ${tierColor(tier.name)}`}>
            <span class="tier-name">{tier.name}</span>
            <span class="tier-range">Worksheets {tier.range[0]}–{tier.range[1]}</span>
            {tier.blurb && <p class="tier-blurb">{tier.blurb}</p>}
          </div>
          <div class="ws-grid">
            {ws.map((w: any) => (
              <a href={`${base}/courses/${key}/worksheets/${w.number}`} class="ws-card">
                <span class="ws-num">WS {w.number}</span>
                <span class="ws-title">{w.title || `Worksheet ${w.number}`}</span>
                {w.heroImage && (
                  <div class="ws-thumb" style={`background-image: url('${base}/images/${w.heroImage}')`}></div>
                )}
              </a>
            ))}
          </div>
        </div>
      );
    }) : (
      <div class="ws-grid">
        {worksheets.map((w: any) => (
          <a href={`${base}/courses/${key}/worksheets/${w.number}`} class="ws-card">
            <span class="ws-num">WS {w.number}</span>
            <span class="ws-title">{w.title || `Worksheet ${w.number}`}</span>
          </a>
        ))}
      </div>
    )}
  </section>

</Base>

<style>
  /* ── Hero ── */
  .course-hero {
    position: relative; overflow: hidden;
    padding: 72px 0 56px;
    background: var(--bg);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .hero-glow {
    position: absolute; inset: 0; pointer-events: none;
    background:
      radial-gradient(800px 500px at 20% 0%, rgba(255,107,31,0.12), transparent 60%),
      radial-gradient(600px 400px at 80% 100%, rgba(77,208,255,0.08), transparent 60%);
  }
  .hero-inner { position: relative; z-index: 1; }
  .hero-eyebrow {
    font-size: 11px; font-weight: 700; letter-spacing: 1.5px;
    text-transform: uppercase; color: var(--accent); margin-bottom: 14px;
    font-family: var(--mono, monospace);
  }
  .hero-title {
    font-size: clamp(28px, 5vw, 48px); font-weight: 800;
    color: var(--text, #f0f4ff); letter-spacing: -0.8px;
    line-height: 1.1; margin-bottom: 28px;
  }
  .hero-stats { display: flex; gap: 32px; margin-bottom: 32px; flex-wrap: wrap; }
  .hero-stat { display: flex; flex-direction: column; }
  .stat-num { font-size: 28px; font-weight: 800; color: var(--accent); line-height: 1; }
  .stat-lbl { font-size: 12px; color: var(--text-dim, #8b9ab8); margin-top: 2px; }
  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }
  .btn-start {
    padding: 12px 24px;
    background: linear-gradient(135deg, var(--accent), #ff9554);
    border-radius: 10px; color: #fff; font-weight: 700; font-size: 14px;
    text-decoration: none; transition: all 0.15s;
    box-shadow: 0 4px 16px rgba(255,107,31,0.3);
  }
  .btn-start:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(255,107,31,0.4); text-decoration: none; }
  .btn-back {
    padding: 12px 20px;
    border: 1px solid rgba(255,255,255,0.12); border-radius: 10px;
    color: var(--text-dim, #8b9ab8); font-size: 14px; text-decoration: none;
    transition: all 0.15s;
  }
  .btn-back:hover { border-color: rgba(255,255,255,0.25); color: var(--text, #f0f4ff); text-decoration: none; }

  /* ── Worksheets ── */
  .worksheets-section { padding: 48px 0 80px; }

  .tier-block { margin-bottom: 48px; }
  .tier-header {
    display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap;
    margin-bottom: 16px; padding-bottom: 12px;
    border-bottom: 2px solid var(--tier-color);
  }
  .tier-name {
    font-size: 18px; font-weight: 800; color: var(--tier-color);
    text-transform: uppercase; letter-spacing: 0.5px;
  }
  .tier-range { font-size: 12px; color: var(--text-dim, #8b9ab8); }
  .tier-blurb { width: 100%; font-size: 13px; color: var(--text-dim, #8b9ab8); margin-top: 4px; }

  .ws-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 12px;
  }
  .ws-card {
    position: relative; overflow: hidden;
    background: var(--bg-card, #16213d); border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.07);
    padding: 16px; min-height: 90px;
    display: flex; flex-direction: column; gap: 6px;
    text-decoration: none; transition: all 0.15s;
  }
  .ws-card:hover {
    border-color: var(--accent); transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.4);
    text-decoration: none;
  }
  .ws-thumb {
    position: absolute; inset: 0;
    background-size: cover; background-position: center;
    opacity: 0.15; transition: opacity 0.15s;
  }
  .ws-card:hover .ws-thumb { opacity: 0.25; }
  .ws-num {
    position: relative; z-index: 1;
    font-size: 10px; font-weight: 700; letter-spacing: 1px;
    text-transform: uppercase; color: var(--accent);
    font-family: var(--mono, monospace);
  }
  .ws-title {
    position: relative; z-index: 1;
    font-size: 14px; font-weight: 600; color: var(--text, #f0f4ff);
    line-height: 1.3;
  }
</style>
