/* subtle grid inside ppt card — applied to inner wrapper so it doesn't scroll */
.ppt-card-top::before {
  content: '';
  position: absolute; inset: -30px -36px 0; pointer-events: none; z-index: 0;
  background-image: linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px),
                    linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px);
  background-size: 40px 40px;
}
.ppt-card-top { display: flex; align-items: center; gap: 16px; position: relative; }
.ppt-icon-wrap {
  width: 50px; height: 50px; border-radius: 12px;
  background: rgba(234,88,12,0.12); color: #fdba74;
  border: 1px solid rgba(234,88,12,0.25);
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.ppt-card-type {
  font-size: 10px; font-weight: 800; letter-spacing: 0.12em;
  text-transform: uppercase; color: rgba(253,186,116,0.55); margin-bottom: 4px;
}
.ppt-card-title {
  font-size: clamp(18px, 2.2vw, 24px); font-weight: 800;
  letter-spacing: -0.025em; color: #fff; margin: 0;
}
.ppt-divider { height: 1px; background: rgba(255,255,255,0.06); }
.ppt-agenda-label {
  font-size: 10px; font-weight: 800; letter-spacing: 0.12em;
  text-transform: uppercase; color: rgba(255,255,255,0.25);
}
.ppt-points { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 9px; }
.ppt-point {
  display: flex; align-items: baseline; gap: 14px;
  font-size: 14px; line-height: 1.5; color: rgba(255,255,255,0.72);
  position: relative;
}
.ppt-num {
  font-size: 10px; font-weight: 800; color: rgba(234,88,12,0.7);
  letter-spacing: 0.04em; flex-shrink: 0; width: 18px; text-align: right;
}
.ppt-open-btn {
  display: inline-flex; align-items: center; gap: 10px;
  margin-top: 2px; padding: 11px 20px; border-radius: 9px;
  font-size: 13px; font-weight: 600;
  color: rgba(255,255,255,0.25); background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08); cursor: not-allowed; width: fit-content;
  position: relative;
}
.ppt-open-soon {
  font-size: 11px; font-weight: 500; color: rgba(255,255,255,0.15);
  background: rgba(255,255,255,0.06); padding: 2px 8px; border-radius: 999px;
}

/* ═══════════════════════════════════════════════════════
   WORKSHEET CARD (full-bleed cinematic)
═══════════════════════════════════════════════════════ */
.ws-card {
  position: relative; width: 100%; height: 100%;
  overflow: hidden;
}
.ws-card-bg {
  position: absolute; inset: 0;
  background: var(--ws-img) center / cover no-repeat;
  transform: scale(1.04); transition: transform 7s ease;
}
.ws-card:hover .ws-card-bg { transform: scale(1.08); }
.ws-card-gradient {
  position: absolute; inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(8,12,21,0.08) 0%,
    rgba(8,12,21,0.3)  30%,
    rgba(8,12,21,0.75) 62%,
    rgba(8,12,21,0.97) 100%
  );
}
.ws-card-info {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 40px 52px 44px;
  display: flex; flex-direction: column; gap: 14px;
}
.ws-card-meta { display: flex; align-items: center; gap: 12px; }
.ws-card-label {
  font-size: 11px; font-weight: 800; letter-spacing: 0.16em;
  text-transform: uppercase; color: rgba(255,255,255,0.45);
}
.ws-card-title {
  font-size: clamp(30px, 5vw, 58px); font-weight: 900;
  letter-spacing: -0.04em; color: #fff; margin: 0; line-height: 1.02;
  text-shadow: 0 4px 28px rgba(0,0,0,0.5);
}
.ws-tier-badge {
  font-size: 10px; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase;
  padding: 4px 12px; border-radius: 999px; flex-shrink: 0;
}
.ws-tier-badge.bronze { background: rgba(205,127,50,0.2); color: #e8a96e; border: 1px solid rgba(205,127,50,0.35); }
.ws-tier-badge.silver { background: rgba(192,192,192,0.15); color: #d6d6d6; border: 1px solid rgba(192,192,192,0.3); }
.ws-tier-badge.gold   { background: rgba(255,211,77,0.15); color: #ffe082; border: 1px solid rgba(255,211,77,0.3); }
.ws-open-btn {
  display: inline-flex; align-items: center; gap: 12px; margin-top: 4px;
  padding: 15px 32px; background: linear-gradient(135deg, #9333ea, #7c3aed);
  color: #fff; border-radius: 12px; font-size: 15px; font-weight: 700;
  text-decoration: none; width: fit-content;
  transition: opacity 0.15s, transform 0.15s, gap 0.2s;
  box-shadow: 0 6px 28px rgba(147,51,234,0.55);
}
.ws-open-btn:hover { opacity: 0.9; transform: translateY(-2px); gap: 16px; text-decoration: none; }

/* ═══════════════════════════════════════════════════════
   BARE DOC HERO (full-bleed, no worksheet page)
═══════════════════════════════════════════════════════ */
.doc-hero {
  position: relative; width: 100%; height: 100%; overflow: hidden;
  background: linear-gradient(135deg, rgba(20,184,166,0.14) 0%, rgba(8,12,21,1) 55%);
  border-top: 2px solid rgba(20,184,166,0.25);
  display: flex; align-items: center; justify-content: center;
}
.doc-hero-watermark {
  position: absolute; top: 50%; left: 58%;
  transform: translate(-50%,-50%);
  opacity: 0.04; color: #14b8a6; pointer-events: none;
}
.doc-hero-content {
  position: relative; z-index: 1;
  display: flex; flex-direction: column; align-items: flex-start;
  gap: 16px; max-width: 560px; width: 100%; padding: 0 52px;
}
.doc-hero-icon {
  width: 68px; height: 68px; border-radius: 16px;
  background: rgba(20,184,166,0.12); color: #2dd4bf;
  border: 1px solid rgba(20,184,166,0.25);
  display: flex; align-items: center; justify-content: center;
}
.doc-hero-label {
  font-size: 11px; font-weight: 800; letter-spacing: 0.14em;
  text-transform: uppercase; color: rgba(45,212,191,0.6); margin: 0;
}
.doc-hero-title {
  font-size: clamp(28px, 4vw, 48px); font-weight: 900;
  letter-spacing: -0.04em; color: #fff; margin: 0; line-height: 1.05;
}
.doc-hero-desc { font-size: 14px; color: rgba(255,255,255,0.38); margin: 0; line-height: 1.6; }

/* ═══════════════════════════════════════════════════════
   WELCOME SLIDE (full-bleed — course overview + images)
═══════════════════════════════════════════════════════ */
.welcome-hero {
  position: relative; width: 100%; height: 100%; overflow: hidden;
  display: flex; align-items: stretch;
  background: linear-gradient(135deg, #080c15 0%, #0f1428 100%);
}
.welcome-left {
  flex: 0 0 52%; display: flex; flex-direction: column;
  justify-content: center; gap: 22px; padding: 52px;
  position: relative; z-index: 1;
}
.welcome-chips {
  display: flex; flex-wrap: wrap; gap: 8px;
}
.welcome-chip {
  font-size: 10px; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase;
  color: rgba(255,255,255,0.45); background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.12); padding: 4px 12px; border-radius: 999px;
}
.welcome-title {
  font-size: clamp(24px, 3.6vw, 44px); font-weight: 900;
  letter-spacing: -0.04em; color: #fff; margin: 0; line-height: 1.05;
}
.welcome-sub {
  font-size: 14px; color: rgba(255,255,255,0.38); margin: 0; line-height: 1.7;
  max-width: 420px;
}
.welcome-tiers { display: flex; gap: 10px; flex-wrap: wrap; }
/* gallery */
.welcome-gallery {
  flex: 1; display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 1fr 1fr;
  gap: 8px; padding: 8px 8px 8px 0;
  overflow: hidden;
}
.welcome-gallery-img {
  background: #0b1220 center / cover no-repeat;
  border-radius: 12px;
  transition: transform 7s ease;
}
.welcome-gallery-img:nth-child(odd)  { transform: scale(1.03); }
.welcome-gallery-img:nth-child(even) { transform: scale(1.04); }

/* ═══════════════════════════════════════════════════════
   HTML HERO (homework / assessment — full-bleed)
═══════════════════════════════════════════════════════ */
.html-hero {
  position: relative; width: 100%; height: 100%; overflow: hidden;
  display: flex; align-items: center; justify-content: center;
}
.html-homework   {
  background: linear-gradient(135deg, rgba(99,102,241,0.22) 0%, rgba(8,12,21,1) 58%);
  border-top: 2px solid rgba(99,102,241,0.3);
}
.html-assessment {
  background: linear-gradient(135deg, rgba(245,158,11,0.22) 0%, rgba(8,12,21,1) 58%);
  border-top: 2px solid rgba(245,158,11,0.3);
}
/* .html-welcome removed — welcome slide now uses .welcome-hero */
.html-hero-watermark {
  position: absolute; top: 50%; left: 58%;
  transform: translate(-50%,-50%);
  opacity: 0.04; pointer-events: none;
}
.html-homework   .html-hero-watermark { color: #6366f1; }
.html-assessment .html-hero-watermark { color: #f59e0b; }
/* .html-welcome watermark removed */

.html-hero-content {
  position: relative; z-index: 1;
  display: flex; flex-direction: column; align-items: flex-start;
  gap: 18px; max-width: 560px; width: 100%; padding: 0 52px;
}
.html-hero-icon {
  width: 68px; height: 68px; border-radius: 16px;
  display: flex; align-items: center; justify-content: center;
}
.html-homework   .html-hero-icon { background: rgba(99,102,241,0.14); color: #a5b4fc; border: 1px solid rgba(99,102,241,0.28); }
.html-assessment .html-hero-icon { background: rgba(245,158,11,0.14); color: #fcd34d; border: 1px solid rgba(245,158,11,0.28); }
/* .html-welcome icon removed */

.html-hero-label {
  font-size: 11px; font-weight: 800; letter-spacing: 0.14em;
  text-transform: uppercase; margin: 0;
}
.html-homework   .html-hero-label { color: rgba(165,180,252,0.65); }
.html-assessment .html-hero-label { color: rgba(252,211,77,0.65); }
/* .html-welcome label removed */

.html-hero-title {
  font-size: clamp(28px, 4vw, 52px); font-weight: 900;
  letter-spacing: -0.04em; color: #fff; margin: 0; line-height: 1.02;
}
.html-hero-desc { font-size: 14px; color: rgba(255,255,255,0.38); margin: 0; line-height: 1.65; }

/* ═══════════════════════════════════════════════════════
   BOTTOM NAV
═══════════════════════════════════════════════════════ */
.sw-nav {
  display: flex; align-items: center; justify-content: space-between;
  gap: 16px; padding: 12px 20px;
  background: rgba(255,255,255,0.025);
  border-top: 1px solid rgba(255,255,255,0.06); flex-shrink: 0;
}
.sw-nav-btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 10px 24px; border-radius: 10px; font-size: 13px; font-weight: 700;
  color: rgba(255,255,255,0.6); background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.09); cursor: pointer;
  transition: background 0.15s, color 0.15s, border-color 0.15s;
  min-width: 114px; letter-spacing: 0.01em;
}
.sw-nav-btn:hover:not(:disabled) {
  background: rgba(255,255,255,0.1); color: #fff;
  border-color: rgba(255,255,255,0.16);
}
.sw-nav-btn:disabled { opacity: 0.25; cursor: not-allowed; }
.sw-next { justify-content: flex-end; }

/* Pips */
.sw-nav-pips { display: flex; align-items: center; gap: 7px; }
.sw-pip {
  width: 7px; height: 7px; border-radius: 50%;
  background: rgba(255,255,255,0.15); border: none; cursor: pointer; padding: 0;
  transition: background 0.25s, transform 0.25s, width 0.25s;
}
.sw-pip.active { width: 22px; border-radius: 4px; transform: none; }

/* Dynamic pip accent */
[data-type="type-opening"]    .sw-pip.active { background: #9333ea; }
[data-type="type-youtube"]    .sw-pip.active { background: #ef4444; }
[data-type="type-pdf"]        .sw-pip.active { background: #f97316; }
[data-type="type-powerpoint"] .sw-pip.active { background: #ea580c; }
[data-type="type-document"]   .sw-pip.active { background: #14b8a6; }
[data-type="type-homework"]   .sw-pip.active { background: #6366f1; }
[data-type="type-assessment"] .sw-pip.active { background: #f59e0b; }
[data-type="type-welcome"]    .sw-pip.active { background: #3b82f6; }
[data-type="type-section"]   .sw-pip.active { background: #eab308; }
[data-type="type-module"]    .sw-pip.active { background: #6366f1; }
[data-type="type-session"]   .sw-pip.active { background: #64748b; }

/* ═══════════════════════════════════════════════════════
   RESPONSIVE — WIDTH
═══════════════════════════════════════════════════════ */
@media (max-width: 640px) {
  .sw-course-name { display: none; }
  .ws-card-info, .pdf-hero-content, .doc-hero-content, .html-hero-content { padding: 0 22px 32px; }
  .ws-card-title, .pdf-hero-title, .doc-hero-title, .html-hero-title { font-size: clamp(22px, 7vw, 32px); }
  .opening-overlay { padding: 24px 28px; }
  .opening-headline { font-size: clamp(24px, 8vw, 40px); }
  .ppt-card { padding: 20px 20px 18px; }
  .ppt-point { font-size: 13px; }
  .sw-nav-btn { padding: 10px 14px; min-width: 82px; }
  .welcome-left { flex: 0 0 100%; padding: 28px 24px; }
  .welcome-gallery { display: none; }
  /* Watermarks scaled down so they can't cause horizontal overflow */
  .pdf-hero-watermark svg,
  .doc-hero-watermark svg,
  .html-hero-watermark svg { width: 200px; height: 200px; }
}

/* ═══════════════════════════════════════════════════════
   RESPONSIVE — HEIGHT (short viewports / landscape mobile)
═══════════════════════════════════════════════════════ */
@media (max-height: 680px) {
  .sw-topbar { height: 38px; }
  .sw-nav { padding: 8px 20px; }
  .sw-slide-header { padding: 12px 24px 0; }
  .type-document   .sw-slide-header,
  .type-homework   .sw-slide-header,
  .type-assessment .sw-slide-header,
  .type-welcome    .sw-slide-header,
  .type-pdf        .sw-slide-header,
  .type-opening    .sw-slide-header,
  .type-section    .sw-slide-header,
  .type-module     .sw-slide-header { padding: 12px 20px; }
  .section-hero-hours { font-size: clamp(56px, 12vw, 100px); }
  .section-hero-title { font-size: clamp(18px, 2.8vw, 30px); }
  .module-hero-content { gap: 10px; }
  .module-hero-icon { width: 52px; height: 52px; }
  .module-hero-title { font-size: clamp(22px, 3.2vw, 36px); }
  .sw-slide-body { padding: 12px 24px 16px; }
  /* PPT: tighten spacing */
  .ppt-card { gap: 10px; padding: 20px 28px 18px; }
  .ppt-points { gap: 6px; }
  .ppt-point { font-size: 13px; line-height: 1.4; }
  .ppt-card-title { font-size: 18px; }
  .ppt-icon-wrap { width: 42px; height: 42px; }
  /* Full-bleed content: shift info panel up */
  .ws-card-info { padding: 28px 40px 32px; }
  .ws-card-title { font-size: clamp(24px, 4vw, 40px); }
  .pdf-hero-content, .doc-hero-content, .html-hero-content { gap: 12px; }
  .pdf-hero-title, .doc-hero-title, .html-hero-title { font-size: clamp(24px, 3.5vw, 36px); }
  .pdf-hero-icon, .doc-hero-icon, .html-hero-icon { width: 54px; height: 54px; }
  .opening-overlay { padding: 28px 40px; }
  .opening-headline { font-size: clamp(28px, 4.5vw, 48px); }
  /* Watermarks smaller on short screens */
  .pdf-hero-watermark svg,
  .doc-hero-watermark svg,
  .html-hero-watermark svg { width: 240px; height: 240px; }
}

/* ═══════════════════════════════════════════════════════
   SESSION CARD (chapter marker — non-full-bleed)
═══════════════════════════════════════════════════════ */
.session-card {
  display: flex; align-items: stretch;
  max-width: 720px; width: 100%;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(100,116,139,0.18);
  border-left: 3px solid #475569;
  border-radius: 18px; overflow: hidden;
  box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 0 1px rgba(100,116,139,0.06);
}
.session-card-num {
  display: flex; align-items: center; justify-content: center;
  font-size: clamp(72px, 11vw, 128px); font-weight: 900;
  letter-spacing: -0.07em; color: rgba(100,116,139,0.1);
  min-width: 160px; flex-shrink: 0; padding: 0 28px;
  border-right: 1px solid rgba(100,116,139,0.1);
  font-variant-numeric: tabular-nums;
}
.session-card-body {
  flex: 1; display: flex; flex-direction: column;
  gap: 20px; padding: 34px 40px;
}
.session-card-duration {
  display: inline-flex; align-items: center;
  font-size: 10px; font-weight: 800; letter-spacing: 0.14em;
  text-transform: uppercase; color: rgba(148,163,184,0.55);
  background: rgba(100,116,139,0.1); border: 1px solid rgba(100,116,139,0.18);
  padding: 4px 14px; border-radius: 999px; width: fit-content;
}
.session-card-topics {
  list-style: none; margin: 0; padding: 0;
  display: flex; flex-direction: column; gap: 13px;
}
.session-card-topics li {
  display: flex; align-items: center; gap: 14px;
  font-size: clamp(15px, 1.8vw, 18px); font-weight: 600;
  color: rgba(255,255,255,0.8); line-height: 1.35;
}
.session-card-topics li::before {
  content: ''; flex-shrink: 0;
  width: 6px; height: 6px; border-radius: 50%;
  background: #475569;
}

/* ═══════════════════════════════════════════════════════
   SECTION DIVIDER (120-hour milestone — full-bleed)
═══════════════════════════════════════════════════════ */
.section-hero {
  position: relative; width: 100%; height: 100%; overflow: hidden;
  background: #080c15;
  display: flex; align-items: center; justify-content: center;
}
/* Animated grid */
.section-hero-grid {
  position: absolute; inset: 0; pointer-events: none;
  background-image:
    linear-gradient(rgba(234,179,8,0.06) 1px, transparent 1px),
    linear-gradient(90deg, rgba(234,179,8,0.06) 1px, transparent 1px);
  background-size: 64px 64px;
}
/* Radial amber glow behind content */
.section-hero-glow {
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%,-50%);
  width: 700px; height: 700px; border-radius: 50%;
  background: radial-gradient(ellipse at center, rgba(234,179,8,0.18) 0%, transparent 68%);
  pointer-events: none;
}
.section-hero-content {
  position: relative; z-index: 1;
  display: flex; flex-direction: column; align-items: center;
  text-align: center; gap: 18px; padding: 0 32px;
}
.section-hero-pill {
  font-size: 10px; font-weight: 800; letter-spacing: 0.18em; text-transform: uppercase;
  color: rgba(253,224,71,0.7); background: rgba(234,179,8,0.12);
  border: 1px solid rgba(234,179,8,0.28); padding: 5px 16px; border-radius: 999px;
}
.section-hero-hours {
  font-size: clamp(80px, 16vw, 160px); font-weight: 900; line-height: 0.85;
  letter-spacing: -0.06em; color: rgba(234,179,8,0.9);
  text-shadow: 0 0 80px rgba(234,179,8,0.4), 0 4px 32px rgba(0,0,0,0.6);
}
.section-hero-hrs-label {
  font-size: clamp(24px, 4vw, 48px); font-weight: 700;
  color: rgba(253,224,71,0.5); margin-left: 6px;
}
.section-hero-title {
  font-size: clamp(22px, 3.5vw, 42px); font-weight: 900;
  letter-spacing: -0.04em; color: #fff; margin: 0; line-height: 1.05;
}
.section-hero-sub {
  font-size: 14px; color: rgba(255,255,255,0.38); margin: 0; line-height: 1.6;
  max-width: 480px;
}
.section-hero-modules {
  display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin-top: 4px;
}
.section-hero-modules span {
  font-size: 11px; font-weight: 700; letter-spacing: 0.04em;
  color: rgba(253,224,71,0.55); background: rgba(234,179,8,0.08);
  border: 1px solid rgba(234,179,8,0.2); padding: 5px 14px; border-radius: 999px;
}

/* ═══════════════════════════════════════════════════════
   MODULE SLIDE (120-hour extension — full-bleed)
═══════════════════════════════════════════════════════ */
.module-hero {
  position: relative; width: 100%; height: 100%; overflow: hidden;
  background: linear-gradient(135deg, rgba(99,102,241,0.2) 0%, rgba(8,12,21,1) 58%);
  border-top: 2px solid rgba(99,102,241,0.3);
  display: flex; align-items: center; justify-content: center;
}
.module-hero-watermark {
  position: absolute; top: 50%; left: 58%;
  transform: translate(-50%,-50%);
  opacity: 0.04; color: #818cf8; pointer-events: none;
}
.module-hero-content {
  position: relative; z-index: 1;
  display: flex; flex-direction: column; align-items: flex-start;
  gap: 16px; max-width: 560px; width: 100%; padding: 0 52px;
}
.module-hero-icon {
  width: 68px; height: 68px; border-radius: 16px;
  background: rgba(99,102,241,0.14); color: #a5b4fc;
  border: 1px solid rgba(99,102,241,0.28);
  display: flex; align-items: center; justify-content: center;
}
.module-hero-label {
  font-size: 11px; font-weight: 800; letter-spacing: 0.14em;
  text-transform: uppercase; color: rgba(165,180,252,0.65); margin: 0;
}
.module-hero-title {
  font-size: clamp(28px, 4vw, 48px); font-weight: 900;
  letter-spacing: -0.04em; color: #fff; margin: 0; line-height: 1.05;
}
.module-hero-desc {
  font-size: 14px; color: rgba(255,255,255,0.42); margin: 0; line-height: 1.65;
}
