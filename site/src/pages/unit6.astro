      <button class="sw-nav-btn sw-next" id="sw-next" aria-label="Next slide">
        Next
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>

  </div>
</Base>

<script define:vars={{ total }}>
(function () {
  let current = 0;
  const slideEls = Array.from(document.querySelectorAll('.sw-slide'));
  const wrap     = document.getElementById('sw-wrap');
  const prevBtn  = document.getElementById('sw-prev');
  const nextBtn  = document.getElementById('sw-next');
  const counter  = document.getElementById('sw-counter');
  const fill     = document.getElementById('sw-progress-fill');
  const pipsWrap = document.getElementById('sw-pips');

  // Build pips
  const PIP_MAX = 9;
  const pipEls  = [];
  for (let i = 0; i < Math.min(total, PIP_MAX); i++) {
    const btn = document.createElement('button');
    btn.className = 'sw-pip';
    pipsWrap.appendChild(btn);
    pipEls.push(btn);
  }

  // Wire up lite YouTube embeds — replace thumbnail with autoplay iframe on click
  document.querySelectorAll('.yt-lite').forEach(lite => {
    lite.querySelector('.yt-play-btn').addEventListener('click', () => {
      const vid = lite.dataset.vid;
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube.com/embed/${vid}?autoplay=1&rel=0`;
      iframe.title = lite.querySelector('.yt-thumb').alt;
      iframe.setAttribute('frameborder', '0');
      iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share');
      iframe.setAttribute('allowfullscreen', '');
      // Swap the lite div for the iframe inside the same .yt-wrap
      lite.parentNode.replaceChild(iframe, lite);
    }, { once: true });
  });

  function goTo(n) {
    const prev = slideEls[current];
    prev.hidden = true;
    prev.setAttribute('aria-hidden', 'true');
    prev.classList.remove('entering');
    // Pause any live iframes when navigating away
    prev.querySelectorAll('iframe').forEach(f => {
      try { f.contentWindow.postMessage('{"event":"command","func":"pauseVideo","args":""}', '*'); } catch (_) {}
    });

    current = Math.max(0, Math.min(total - 1, n));
    const next = slideEls[current];
    next.hidden = false;
    next.setAttribute('aria-hidden', 'false');
    next.classList.remove('entering');
    requestAnimationFrame(() => next.classList.add('entering'));

    wrap.dataset.type = next.dataset.type || '';
    update();
  }

  function update() {
    prevBtn.disabled = current === 0;
    nextBtn.disabled = current === total - 1;
    counter.innerHTML = (current + 1) + ' <span class="sw-counter-of">/ ' + total + '</span>';
    if (fill) fill.style.width = ((current + 1) / total * 100) + '%';

    // Pips
    if (total <= PIP_MAX) {
      pipEls.forEach((p, i) => {
        p.classList.toggle('active', i === current);
        p.onclick = () => goTo(i);
        p.setAttribute('aria-label', 'Slide ' + (i + 1));
      });
    } else {
      const half  = Math.floor(PIP_MAX / 2);
      let   start = Math.max(0, current - half);
      if (start + PIP_MAX > total) start = total - PIP_MAX;
      pipEls.forEach((p, i) => {
        const idx = start + i;
        p.classList.toggle('active', idx === current);
        p.setAttribute('aria-label', 'Slide ' + (idx + 1));
        p.onclick = () => goTo(idx);
      });
    }
  }

  prevBtn.addEventListener('click', () => goTo(current - 1));
  nextBtn.addEventListener('click', () => goTo(current + 1));
  document.addEventListener('keydown', e => {
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown') { e.preventDefault(); goTo(current + 1); }
    if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')   { e.preventDefault(); goTo(current - 1); }
  });

  // Init first slide
  wrap.dataset.type = slideEls[0]?.dataset.type || '';
  slideEls[0]?.classList.add('entering');
  update();
})();
</script>

<style is:global>
  /* SOW page — everything must fit in the viewport, no page scroll */
