[data-type="type-module"]    .sw-progress-fill { background: linear-gradient(90deg,#6366f1,#818cf8); box-shadow: 0 0 10px rgba(99,102,241,0.6); }
[data-type="type-session"]   .sw-progress-fill { background: linear-gradient(90deg,#475569,#64748b); box-shadow: 0 0 8px rgba(71,85,105,0.5); }

.sw-counter { font-size: 13px; font-weight: 700; color: #fff; flex-shrink: 0; min-width: 58px; text-align: right; }
.sw-counter-of { color: rgba(255,255,255,0.3); font-weight: 400; }

/* ═══════════════════════════════════════════════════════
   SLIDE TRANSITION
═══════════════════════════════════════════════════════ */
@keyframes swIn {
  from { opacity: 0; transform: translateY(12px) scale(0.994); }
  to   { opacity: 1; transform: translateY(0)    scale(1); }
}
.sw-slide.entering {
  animation: swIn 0.32s cubic-bezier(0.22, 1, 0.36, 1) both;
}

/* ═══════════════════════════════════════════════════════
