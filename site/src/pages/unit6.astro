/* ═══════════════════════════════════════════════════════
   POWERPOINT CARD
═══════════════════════════════════════════════════════ */
.ppt-card {
  display: flex; flex-direction: column; gap: 14px;
  background: rgba(255,255,255,0.035);
  border: 1px solid rgba(234,88,12,0.18);
  border-top: 3px solid #ea580c;
  border-radius: 18px; padding: 30px 36px 28px;
