[data-type="type-homework"]   .sw-progress-fill { background: linear-gradient(90deg,#6366f1,#818cf8); box-shadow: 0 0 10px rgba(99,102,241,0.6); }
[data-type="type-assessment"] .sw-progress-fill { background: linear-gradient(90deg,#f59e0b,#fbbf24); box-shadow: 0 0 10px rgba(245,158,11,0.6); }
[data-type="type-welcome"]    .sw-progress-fill { background: linear-gradient(90deg,#3b82f6,#60a5fa); box-shadow: 0 0 10px rgba(59,130,246,0.6); }
