---
import Base from "../layouts/Base.astro";
import course from "../data/course.json";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const worksheets = (course.sections as any[]).filter((s: any) => s.kind === "worksheet");
const wsMap: Record<number, any> = {};
for (const w of worksheets) wsMap[w.number] = w;

function ytId(url: string): string {
  return url.match(/youtu\.be\/([^?&]+)/)?.[1] ?? "";
}

interface DocSlide    { type: "document";    title: string; ws?: number; }
interface YtSlide     { type: "youtube";     title: string; url: string; }
interface PdfSlide    { type: "pdf";         title: string; url: string; }
interface PptSlide    { type: "powerpoint";  title: string; points: string[]; }
interface HtmlSlide   { type: "html";        title: string; subtype: "welcome" | "homework" | "assessment"; }
interface OpenSlide   { type: "opening";     title: string; }
interface SectionSlide { type: "section";   title: string; subtitle: string; hours: number; }
interface ModuleSlide  { type: "module";    title: string; desc: string; icon: string; }
interface SessionCard  { type: "session";   title: string; num: number; hours: number; topics: string[]; }
type SlideDef = DocSlide | YtSlide | PdfSlide | PptSlide | HtmlSlide | OpenSlide | SectionSlide | ModuleSlide | SessionCard;

const SLIDES: SlideDef[] = [

  // ── Course intro ────────────────────────────────────────────────────────────
  { type: "opening", title: "Introduction to Microcontrollers" },
  { type: "html",    title: "Welcome", subtype: "welcome" },

  // ── Session 1: Hardware & software intro ────────────────────────────────────
  { type: "youtube",    title: "Introducing E-blocks 3",  url: "https://youtu.be/KmpyVmv6J_Y?si=bzAVMntlAOE_-Rlv" },
  { type: "youtube",    title: "Introducing Flowcode",    url: "https://youtu.be/tDdptTbvDM0?si=19xqKAzPCOO3In5e" },
  { type: "pdf",        title: "E-blocks 3 Datasheet",   url: "https://www.matrixtsl.com/wp-content/uploads/2026/03/CP9645-Eblocks-3-Datasheet-1.pdf" },
  { type: "powerpoint", title: "Microcontroller basics 1", points: [
    "What is a microcontroller, and how does it differ from a microprocessor?",
    "Key internal components: CPU, Flash memory, RAM, and I/O ports",
    "Overview of the E-blocks 3 hardware platform and its modules",
    "Digital signals — HIGH and LOW logic levels explained",
    "Introduction to binary: how computers represent data in 1s and 0s",
    "Real-world applications of microcontrollers in everyday products",
  ]},
  { type: "powerpoint", title: "Microcontroller basics 2", points: [
    "The fetch-decode-execute cycle: how a microcontroller runs a program",
    "GPIO pins — configuring ports as inputs or outputs in Flowcode",
    "Pull-up and pull-down resistors and why floating pins cause problems",
    "Clock speed and its effect on instruction timing and delays",
    "Introduction to the Flowcode Embedded IDE and project structure",
    "Program flow: variables, loops, and conditional branching",
  ]},

  // ── Sessions 2–3: First programs & digital I/O ──────────────────────────────
  { type: "document", title: "First program",             ws: 1 },
  { type: "document", title: "Performing calculations",   ws: 2 },
  { type: "document", title: "Digital inputs",            ws: 4 },
  { type: "document", title: "Connection points",         ws: 3 },

  { type: "html", title: "Homework 1", subtype: "homework" },

  // ── Sessions 4–7: Core logic, sensors & displays ────────────────────────────
  { type: "document", title: "Making decisions",          ws: 5 },
  { type: "document", title: "Macros / subroutines",      ws: 6 },
  { type: "document", title: "Using prototype boards",    ws: 7 },
  { type: "document", title: "Analogue inputs" },
  { type: "document", title: "Colour graphical displays", ws: 8 },

  { type: "html", title: "Homework 2", subtype: "homework" },

  // ── Sessions 8–9: Displays & light sensor ───────────────────────────────────
  { type: "document", title: "Colour graphical displays", ws: 8 },
  { type: "document", title: "Light sensor" },

  { type: "html", title: "Homework 3", subtype: "homework" },

  // ── Session 10: Assessment 1 ────────────────────────────────────────────────
  { type: "html", title: "Assessment 1", subtype: "assessment" },

  // ── Sessions 11–12: Temperature & accelerometer ─────────────────────────────
  { type: "document", title: "Digital temperature sensor" },
  { type: "document", title: "Digital accelerometer" },

  { type: "html", title: "Homework 4", subtype: "homework" },

  // ── Sessions 13–14: Assessment 2 ────────────────────────────────────────────
  { type: "html", title: "Assessment 2", subtype: "assessment" },

  { type: "html", title: "Homework 5", subtype: "homework" },

  { type: "html", title: "Assessment 2", subtype: "assessment" },

  // ── Sessions 15–16: Motors ──────────────────────────────────────────────────
  { type: "document", title: "Basic DC motors" },
  { type: "document", title: "Full bridge motor control" },
  { type: "document", title: "Stepper motor control" },
  { type: "document", title: "Servo motor control" },

  { type: "html", title: "Homework 6", subtype: "homework" },

  // ── Sessions 17–19: Data types & interrupts ─────────────────────────────────
  { type: "document", title: "Floats and INTs" },
  { type: "document", title: "Pin interrupts",         ws: 9 },
  { type: "document", title: "Timer interrupts",       ws: 10 },

  { type: "html", title: "Homework 7", subtype: "homework" },

  // ── Sessions 20–22: Touch & Assessment 3 ────────────────────────────────────
  { type: "document", title: "Touch control systems",  ws: 11 },
  { type: "document", title: "Touch control systems",  ws: 11 },
  { type: "html",     title: "Assessment 3", subtype: "assessment" },

  { type: "html", title: "Homework 8", subtype: "homework" },

  // ── Sessions 23–24: Web mirror ───────────────────────────────────────────────
  { type: "document", title: "Web mirror",             ws: 12 },
  { type: "document", title: "Web mirror",             ws: 12 },

  { type: "html", title: "Homework 9", subtype: "homework" },

  // ── 120-Hour Extension ──────────────────────────────────────────────────────
  { type: "section", title: "120-Hour Scheme of Work", subtitle: "Extended content — builds on the 60-hour programme", hours: 120 },
  { type: "module", title: "Allcode Competition",             icon: "robot",   desc: "Formula Allcode is a small mobile robot powered by a PIC microcontroller. Allcode is a fantastic tool for teaching autonomous mobile robotics through a range of exercises including line following, tune playing and dancing, and maze following." },
  { type: "module", title: "PC Interfacing",                  icon: "monitor", desc: "In this module students learn how to create apps for a PC which interface to low-cost embedded systems like Arduino Uno." },
  { type: "module", title: "Working with Mechanical Sensors", icon: "sensors", desc: "Working with strain sensors, thermistors, pressure sensors, and power boards." },
  { type: "module", title: "DC Motor Control",                icon: "motor",   desc: "Students understand how to control DC motors using feedback." },
  { type: "module", title: "Further Project",                 icon: "project", desc: "Students undertake a larger, open-ended project drawing on skills developed throughout the full 120-hour programme." },
];

const slides = SLIDES.map((s, i) => {
  const wsNum = (s as DocSlide).ws;
  return { ...s, index: i, wsData: wsNum ? wsMap[wsNum] : null };
});
const total = slides.length;

function typeLabel(s: SlideDef): string {
  if (s.type === "html") {
    return { welcome: "Welcome", homework: "Homework", assessment: "Assessment" }[(s as HtmlSlide).subtype];
  }
  if (s.type === "session") return `Session ${(s as SessionCard).num}`;
  return ({ opening: "Introduction", youtube: "Video", pdf: "PDF Resource", powerpoint: "Presentation", document: "Worksheet", section: "120-Hour Programme", module: "Module" } as Record<string,string>)[s.type] ?? s.type;
}
function typeClass(s: SlideDef): string {
  if (s.type === "html") return `type-${(s as HtmlSlide).subtype}`;
  return `type-${s.type}`;
}
---

<Base title={`${course.unit}: Scheme of Work`}>
  <div class="sw-wrap" id="sw-wrap">

    <!-- Top bar -->
    <div class="sw-topbar">
      <div class="sw-topbar-left">
        <span class="sw-course-code">{course.code}</span>
        <span class="sw-course-name">{course.title}</span>
      </div>
      <div class="sw-progress-track">
        <div class="sw-progress-fill" id="sw-progress-fill"></div>
      </div>
      <div class="sw-counter" id="sw-counter">1 <span class="sw-counter-of">/ {total}</span></div>
    </div>

    <!-- Slides container -->
    <div class="sw-viewport" id="sw-viewport">
      {slides.map((s, i) => {
        const label  = typeLabel(s as SlideDef);
        const cls    = typeClass(s as SlideDef);
        const isDoc  = s.type === "document";
        const wsNum  = (s as any).ws as number | undefined;
        const wsData = (s as any).wsData;
        return (
          <div class={`sw-slide ${cls}`} data-index={i} data-type={cls} aria-hidden={i > 0 ? "true" : "false"} hidden={i > 0}>

            <!-- Ambient glow orbs — color driven by CSS var per slide type -->
            <div class="sw-orb sw-orb-1" aria-hidden="true"></div>
            <div class="sw-orb sw-orb-2" aria-hidden="true"></div>

            <!-- Slide header (hidden for full-bleed slides via CSS) -->
            <div class="sw-slide-header">
              <span class={`sw-badge ${cls}`}>{label}</span>
              <h1 class="sw-slide-title">{s.title}</h1>
            </div>

            <div class="sw-slide-body">

              {/* ── Opening ── */}
              {s.type === "opening" && (
                <div class="opening-card">
                  <div class="opening-img" style={`background-image: url('${base}/images/intro_to_micros_cover.jpg')`}>
                    <div class="opening-grid" aria-hidden="true"></div>
                    <div class="opening-overlay">
                      <div class="opening-chips">
                        <span class="opening-chip">{course.unit}</span>
                        <span class="opening-chip">{course.code}</span>
                        <span class="opening-chip">{course.hours}-hour course</span>
                      </div>
                      <div class="opening-headline">{s.title}</div>
                      <div class="opening-pub">{course.publisher}</div>
                    </div>
                  </div>
                </div>
              )}

              {/* ── YouTube (lite embed — thumbnail until clicked) ── */}
              {s.type === "youtube" && (
                <div class="yt-outer">
                  <div class="yt-glow" aria-hidden="true"></div>
                  <div class="yt-wrap">
                    <div class="yt-lite" data-vid={ytId((s as YtSlide).url)}>
                      <img
                        class="yt-thumb"
                        src={`https://img.youtube.com/vi/${ytId((s as YtSlide).url)}/maxresdefault.jpg`}
                        onerror={`this.src='https://img.youtube.com/vi/${ytId((s as YtSlide).url)}/hqdefault.jpg'`}
                        alt={s.title}
                        loading="lazy"
                        draggable="false"
                      />
                      <button class="yt-play-btn" aria-label={`Play: ${s.title}`}>
                        <svg class="yt-play-bg" viewBox="0 0 68 48" width="68" height="48" aria-hidden="true">
                          <path d="M66.5 7.7a8.5 8.5 0 0 0-6-6C56.1 0 34 0 34 0S11.9 0 7.5 1.7a8.5 8.5 0 0 0-6 6C0 12.1 0 24 0 24s0 11.9 1.5 16.3a8.5 8.5 0 0 0 6 6C11.9 48 34 48 34 48s22.1 0 26.5-1.7a8.5 8.5 0 0 0 6-6C68 35.9 68 24 68 24s0-11.9-1.5-16.3z" fill="#ff0000"/>
                          <path d="M45 24L27 14v20" fill="#fff"/>
                        </svg>
                      </button>
                    </div>
                  </div>
                </div>
              )}

              {/* ── PDF ── */}
              {s.type === "pdf" && (
                <div class="pdf-hero">
                  <div class="pdf-hero-watermark" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.4" width="340" height="340"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                  </div>
                  <div class="pdf-hero-content">
                    <div class="pdf-hero-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="36" height="36"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                    </div>
                    <p class="pdf-hero-label">PDF Resource</p>
                    <h2 class="pdf-hero-title">{s.title}</h2>
                    <p class="pdf-hero-desc">Technical specification document — open to read or download.</p>
                    <a href={(s as PdfSlide).url} target="_blank" rel="noopener" class="pdf-hero-btn">
                      Open PDF
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                    </a>
                  </div>
                </div>
              )}

              {/* ── PowerPoint ── */}
              {s.type === "powerpoint" && (
                <div class="ppt-card">
                  <div class="ppt-card-top">
                    <div class="ppt-icon-wrap">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/><path d="M9 8h3a2 2 0 0 1 0 4H9V8z"/></svg>
                    </div>
                    <div>
                      <div class="ppt-card-type">PowerPoint Presentation</div>
                      <h2 class="ppt-card-title">{s.title}</h2>
                    </div>
                  </div>
                  <div class="ppt-divider"></div>
                  <div class="ppt-agenda-label">In this session we will cover:</div>
                  <ul class="ppt-points">
                    {(s as PptSlide).points.map((p, pi) => (
                      <li class="ppt-point">
                        <span class="ppt-num" aria-hidden="true">0{pi + 1}</span>
                        {p}
                      </li>
                    ))}
                  </ul>
                  <button class="ppt-open-btn" disabled aria-disabled="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
                    Open Presentation
                    <span class="ppt-open-soon">coming soon</span>
                  </button>
                </div>
              )}

              {/* ── Worksheet with page ── */}
              {isDoc && wsData && (
                <div
                  class="ws-card"
                  style={wsData.heroImage ? `--ws-img: url('${base}/images/${wsData.heroImage}')` : ""}
                >
                  {wsData.heroImage && <div class="ws-card-bg"></div>}
                  <div class="ws-card-gradient"></div>
                  <div class="ws-card-info">
                    <div class="ws-card-meta">
                      <span class="ws-card-label">Worksheet {wsNum}</span>
                      {wsData.tier && (
                        <span class={`ws-tier-badge ${wsData.tier.toLowerCase()}`}>{wsData.tier}</span>
                      )}
                    </div>
                    <h2 class="ws-card-title">{s.title}</h2>
                    <a href={`${base}/worksheets/${wsNum}`} class="ws-open-btn">
                      Open interactive worksheet
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="18" height="18" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </a>
                  </div>
                </div>
              )}

              {/* ── Worksheet without page ── */}
              {isDoc && !wsData && (
                <div class="doc-hero">
                  <div class="doc-hero-watermark" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.35" width="300" height="300"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                  </div>
                  <div class="doc-hero-content">
                    <div class="doc-hero-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="32" height="32"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                    </div>
                    <p class="doc-hero-label">Worksheet Document</p>
                    <h2 class="doc-hero-title">{s.title}</h2>
                    <p class="doc-hero-desc">Practical worksheet — work through the activities with your E-blocks 3 kit.</p>
                  </div>
                </div>
              )}

              {/* ── Welcome slide — course overview with image gallery ── */}
              {s.type === "html" && (s as HtmlSlide).subtype === "welcome" && (
                <div class="welcome-hero">
                  <div class="welcome-left">
                    <div class="welcome-chips">
                      <span class="welcome-chip">{course.unit}</span>
                      <span class="welcome-chip">{course.code}</span>
                      <span class="welcome-chip">{course.hours}-hour programme</span>
                      <span class="welcome-chip">12 worksheets</span>
                    </div>
                    <h2 class="welcome-title">{course.title}</h2>
                    <p class="welcome-sub">A practical introduction to microcontroller programming using E-blocks 3 hardware and Flowcode visual programming software.</p>
                    <div class="welcome-tiers">
                      <span class="ws-tier-badge bronze">Bronze</span>
                      <span class="ws-tier-badge silver">Silver</span>
                      <span class="ws-tier-badge gold">Gold</span>
                    </div>
                  </div>
                  <div class="welcome-gallery" aria-hidden="true">
                    {Object.values(wsMap).filter((w: any) => w.heroImage).slice(0, 4).map((w: any) => (
                      <div class="welcome-gallery-img" style={`background-image: url('${base}/images/${w.heroImage}')`}></div>
                    ))}
                  </div>
                </div>
              )}

              {/* ── HTML: homework / assessment ── */}
              {s.type === "html" && (s as HtmlSlide).subtype !== "welcome" && (
                <div class={`html-hero html-${(s as HtmlSlide).subtype}`}>
                  <div class="html-hero-watermark" aria-hidden="true">
                    {(s as HtmlSlide).subtype === "assessment" && (
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.3" width="340" height="340"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                    )}
                    {(s as HtmlSlide).subtype === "homework" && (
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.3" width="340" height="340"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                    )}
                  </div>
                  <div class="html-hero-content">
                    <div class="html-hero-icon">
                      {(s as HtmlSlide).subtype === "assessment" && (
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="34" height="34"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                      )}
                      {(s as HtmlSlide).subtype === "homework" && (
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="34" height="34"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                      )}
                    </div>
                    <p class="html-hero-label">
                      {(s as HtmlSlide).subtype === "assessment" ? "Summative Assessment" : "Take-Home Homework"}
                    </p>
                    <h2 class="html-hero-title">{s.title}</h2>
                    <p class="html-hero-desc">
                      {(s as HtmlSlide).subtype === "assessment"
                        ? "Formal assessment — students complete and submit via your institution's VLE."
                        : "Set for home — students complete and bring answers to the next session."}
                    </p>
                  </div>
                </div>
              )}

              {/* ── Section divider ── */}
              {s.type === "section" && (
                <div class="section-hero">
                  <div class="section-hero-grid" aria-hidden="true"></div>
                  <div class="section-hero-glow" aria-hidden="true"></div>
                  <div class="section-hero-content">
                    <div class="section-hero-pill">Extended Programme</div>
                    <div class="section-hero-hours">{(s as SectionSlide).hours}<span class="section-hero-hrs-label">hrs</span></div>
                    <h2 class="section-hero-title">{s.title}</h2>
                    <p class="section-hero-sub">{(s as SectionSlide).subtitle}</p>
                    <div class="section-hero-modules">
                      <span>Allcode Competition</span>
                      <span>PC Interfacing</span>
                      <span>Mechanical Sensors</span>
                      <span>DC Motor Control</span>
                      <span>Further Project</span>
                    </div>
                  </div>
                </div>
              )}

              {/* ── Module ── */}
              {s.type === "module" && (
                <div class="module-hero">
                  <div class="module-hero-watermark" aria-hidden="true">
                    {(s as ModuleSlide).icon === "robot"   && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.35" width="320" height="320"><rect x="3" y="11" width="18" height="10" rx="2"/><path d="M12 11V7"/><circle cx="12" cy="5" r="2"/><path d="M7 11V9a5 5 0 0 1 10 0v2"/><line x1="7" y1="16" x2="7" y2="16"/><line x1="12" y1="16" x2="12" y2="16"/><line x1="17" y1="16" x2="17" y2="16"/></svg>}
                    {(s as ModuleSlide).icon === "monitor" && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.35" width="320" height="320"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>}
                    {(s as ModuleSlide).icon === "sensors" && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.35" width="320" height="320"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>}
                    {(s as ModuleSlide).icon === "motor"   && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.35" width="320" height="320"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><path d="M12 2v4M12 18v4M2 12h4M18 12h4"/></svg>}
                    {(s as ModuleSlide).icon === "project" && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.35" width="320" height="320"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>}
                  </div>
                  <div class="module-hero-content">
                    <div class="module-hero-icon">
