---
import Base from "../layouts/Base.astro";
import course from "../data/course.json";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const worksheets = (course.sections as any[]).filter((s: any) => s.kind === "worksheet");
const wsMap: Record<number, any> = {};
for (const w of worksheets) wsMap[w.number] = w;

function ytId(url: string): string {
  return url.match(/youtu\.be\/([^?&]+)/)?.[1] ?? "";
}

interface DocSlide  { type: "document";    title: string; ws?: number; }
interface YtSlide   { type: "youtube";     title: string; url: string; }
interface PdfSlide  { type: "pdf";         title: string; url: string; }
interface PptSlide  { type: "powerpoint";  title: string; }
interface HtmlSlide { type: "html";        title: string; subtype: "welcome" | "homework" | "assessment"; }
interface OpenSlide { type: "opening";     title: string; }
type SlideDef = DocSlide | YtSlide | PdfSlide | PptSlide | HtmlSlide | OpenSlide;

const SLIDES: SlideDef[] = [
  { type: "opening",    title: "Introduction to Microcontrollers" },
  { type: "html",       title: "Welcome",                            subtype: "welcome" },
  { type: "youtube",    title: "Introducing E-blocks 3",             url: "https://youtu.be/KmpyVmv6J_Y?si=bzAVMntlAOE_-Rlv" },
  { type: "youtube",    title: "Introducing Flowcode",               url: "https://youtu.be/tDdptTbvDM0?si=19xqKAzPCOO3In5e" },
  { type: "pdf",        title: "E-blocks datasheet",                 url: "https://www.matrixtsl.com/wp-content/uploads/2026/03/CP9645-Eblocks-3-Datasheet-1.pdf" },
  { type: "powerpoint", title: "Microcontroller basics 1" },
  { type: "powerpoint", title: "Microcontroller basics 2" },
  { type: "document",   title: "First program",                      ws: 1 },
  { type: "document",   title: "Performing calculations",            ws: 2 },
  { type: "document",   title: "Connection points",                  ws: 3 },
  { type: "document",   title: "Digital inputs",                     ws: 4 },
  { type: "html",       title: "Homework 1",                         subtype: "homework" },
  { type: "document",   title: "Making decisions",                   ws: 5 },
  { type: "document",   title: "Macros / subroutines",               ws: 6 },
  { type: "document",   title: "Using prototype boards",             ws: 7 },
  { type: "document",   title: "Analogue inputs" },
  { type: "document",   title: "Colour graphical displays",          ws: 8 },
  { type: "html",       title: "Homework 2",                         subtype: "homework" },
  { type: "document",   title: "Colour graphical displays",          ws: 8 },
  { type: "document",   title: "Light sensor" },
  { type: "document",   title: "Analogue temperature sensor" },
  { type: "html",       title: "Homework 3",                         subtype: "homework" },
  { type: "html",       title: "Assessment 1",                       subtype: "assessment" },
  { type: "document",   title: "Digital temperature sensor" },
  { type: "document",   title: "Digital accelerometer" },
  { type: "html",       title: "Assessment 2",                       subtype: "assessment" },
  { type: "document",   title: "Basic DC motors" },
  { type: "document",   title: "Full bridge motor control" },
  { type: "document",   title: "Stepper motor control" },
  { type: "document",   title: "Servo motor control" },
  { type: "html",       title: "Homework 6",                         subtype: "homework" },
  { type: "document",   title: "Floats and INTs" },
  { type: "document",   title: "Pin interrupts",                     ws: 9 },
  { type: "document",   title: "Timer interrupts",                   ws: 10 },
  { type: "html",       title: "Homework 7",                         subtype: "homework" },
  { type: "document",   title: "Touch control systems",              ws: 11 },
  { type: "html",       title: "Homework 8",                         subtype: "homework" },
  { type: "document",   title: "Web mirror",                         ws: 12 },
  { type: "html",       title: "Homework 9",                         subtype: "homework" },
];

const slides = SLIDES.map((s, i) => {
  const wsNum = (s as DocSlide).ws;
  return { ...s, index: i, wsData: wsNum ? wsMap[wsNum] : null };
});
const total = slides.length;

function typeLabel(s: SlideDef): string {
  if (s.type === "html") {
    return { welcome: "Welcome", homework: "Homework", assessment: "Assessment" }[(s as HtmlSlide).subtype];
  }
  return ({ opening: "Introduction", youtube: "Video", pdf: "PDF Resource", powerpoint: "Presentation", document: "Worksheet" } as Record<string,string>)[s.type] ?? s.type;
}
function typeClass(s: SlideDef): string {
  if (s.type === "html") return `type-${(s as HtmlSlide).subtype}`;
  return `type-${s.type}`;
}
---

<Base title={`${course.unit}: Scheme of Work`}>
  <div class="sw-wrap">

    <!-- Top bar -->
    <div class="sw-topbar">
      <div class="sw-topbar-left">
        <span class="sw-course-code">{course.code}</span>
        <span class="sw-course-name">{course.title}</span>
      </div>
      <div class="sw-progress-track">
        <div class="sw-progress-fill" id="sw-progress-fill"></div>
      </div>
      <div class="sw-counter" id="sw-counter">1 <span class="sw-counter-of">/ {total}</span></div>
    </div>

    <!-- Slides container -->
    <div class="sw-viewport">
      {slides.map((s, i) => {
        const label  = typeLabel(s as SlideDef);
        const cls    = typeClass(s as SlideDef);
        const isDoc  = s.type === "document";
        const wsNum  = (s as any).ws as number | undefined;
        const wsData = (s as any).wsData;
        return (
          <div class={`sw-slide ${cls}`} data-index={i} aria-hidden={i > 0 ? "true" : "false"} hidden={i > 0}>

            <div class="sw-slide-header">
              <span class={`sw-badge ${cls}`}>{label}</span>
              <h1 class="sw-slide-title">{s.title}</h1>
            </div>

            <div class="sw-slide-body">

              {s.type === "opening" && (
                <div class="opening-card">
                  <div class="opening-img" style={`background-image: url('${base}/images/intro_to_micros_cover.jpg')`}>
                    <div class="opening-overlay">
                      <div class="opening-chips">
                        <span class="opening-chip">{course.unit}</span>
                        <span class="opening-chip">{course.code}</span>
                        <span class="opening-chip">{course.hours}-hour course</span>
                      </div>
                      <div class="opening-headline">{s.title}</div>
                      <div class="opening-pub">{course.publisher}</div>
                    </div>
                  </div>
                </div>
              )}

              {s.type === "youtube" && (
                <div class="yt-wrap">
                  <iframe
                    src={`https://www.youtube.com/embed/${ytId((s as YtSlide).url)}`}
                    title={s.title}
                    frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    allowfullscreen
                  ></iframe>
                </div>
              )}

              {s.type === "pdf" && (
                <div class="resource-card">
                  <div class="rc-icon rc-icon-pdf">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="52" height="52" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                  </div>
                  <div class="rc-info">
                    <div class="rc-type">PDF Document</div>
                    <h2 class="rc-title">{s.title}</h2>
                  </div>
                  <a href={(s as PdfSlide).url} target="_blank" rel="noopener" class="rc-btn rc-btn-pdf">
                    Open PDF
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  </a>
                </div>
              )}

              {s.type === "powerpoint" && (
                <div class="resource-card">
                  <div class="rc-icon rc-icon-ppt">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="52" height="52" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/><path d="M9 8h3a2 2 0 0 1 0 4H9V8z"/></svg>
                  </div>
                  <div class="rc-info">
                    <div class="rc-type">PowerPoint Presentation</div>
                    <h2 class="rc-title">{s.title}</h2>
                    <p class="rc-note">Delivered live in session</p>
                  </div>
                </div>
              )}

              {isDoc && wsData && (
                <div class="ws-card">
                  {wsData.heroImage && (
                    <div class="ws-card-img" style={`background-image: url('${base}/images/${wsData.heroImage}')`}></div>
                  )}
                  <div class="ws-card-info">
                    <div class="ws-card-label">Worksheet {wsNum}</div>
                    <h2 class="ws-card-title">{s.title}</h2>
                    {wsData.tier && (
                      <span class={`ws-tier-badge ${wsData.tier.toLowerCase()}`}>{wsData.tier} tier</span>
                    )}
                    <a href={`${base}/worksheets/${wsNum}`} class="ws-open-btn">
                      Open interactive worksheet
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </a>
                  </div>
                </div>
              )}

              {isDoc && !wsData && (
                <div class="resource-card">
                  <div class="rc-icon rc-icon-doc">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="52" height="52" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                  </div>
                  <div class="rc-info">
                    <div class="rc-type">Worksheet Document</div>
                    <h2 class="rc-title">{s.title}</h2>
                  </div>
                </div>
              )}

              {s.type === "html" && (
                <div class={`html-card html-${(s as HtmlSlide).subtype}`}>
                  <div class="html-icon">
                    {(s as HtmlSlide).subtype === "assessment" && (
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="56" height="56" aria-hidden="true"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                    )}
                    {(s as HtmlSlide).subtype === "homework" && (
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="56" height="56" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                    )}
                    {(s as HtmlSlide).subtype === "welcome" && (
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="56" height="56" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                    )}
                  </div>
                  <div class="html-info">
                    <div class="html-type">
                      {(s as HtmlSlide).subtype === "assessment" ? "Summative Assessment" :
                       (s as HtmlSlide).subtype === "homework"   ? "Take-Home Homework"   : "Interactive Resource"}
                    </div>
                    <h2 class="html-title">{s.title}</h2>
                    <p class="html-desc">
                      {(s as HtmlSlide).subtype === "assessment"
                        ? "Formal assessment — students complete and submit via your institution's VLE."
                        : (s as HtmlSlide).subtype === "homework"
                        ? "Set for home — students complete and bring answers to the next session."
                        : "Interactive HTML resource. Open in a browser window."}
                    </p>
                  </div>
                </div>
              )}

            </div>
          </div>
        );
      })}
    </div>

    <!-- Navigation -->
    <div class="sw-nav">
      <button class="sw-nav-btn" id="sw-prev" disabled aria-label="Previous slide">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="18" height="18" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
        Previous
      </button>
      <div class="sw-nav-pips" id="sw-pips" aria-hidden="true"></div>
      <button class="sw-nav-btn sw-nav-btn-next" id="sw-next" aria-label="Next slide">
        Next
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="18" height="18" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>

  </div>
</Base>

<script define:vars={{ total }}>
(function () {
  let current = 0;
  const slides   = Array.from(document.querySelectorAll('.sw-slide'));
  const prevBtn  = document.getElementById('sw-prev');
  const nextBtn  = document.getElementById('sw-next');
  const counter  = document.getElementById('sw-counter');
  const fill     = document.getElementById('sw-progress-fill');
  const pipsWrap = document.getElementById('sw-pips');

  const PIP_MAX = 9;
  const pipEls  = [];
  for (let i = 0; i < Math.min(total, PIP_MAX); i++) {
    const btn = document.createElement('button');
    btn.className = 'sw-pip';
    pipsWrap.appendChild(btn);
    pipEls.push(btn);
  }

  function goTo(n) {
    slides[current].hidden = true;
    slides[current].setAttribute('aria-hidden', 'true');
    // Pause any iframes on the slide we're leaving
    slides[current].querySelectorAll('iframe').forEach(f => {
      try { f.src = f.src; } catch (_) {}
    });
    current = Math.max(0, Math.min(total - 1, n));
    slides[current].hidden = false;
    slides[current].setAttribute('aria-hidden', 'false');
    update();
  }

  function update() {
    prevBtn.disabled = current === 0;
    nextBtn.disabled = current === total - 1;
    counter.innerHTML = (current + 1) + ' <span class="sw-counter-of">/ ' + total + '</span>';
    if (fill) fill.style.width = ((current + 1) / total * 100) + '%';

    // Pips
    if (total <= PIP_MAX) {
      pipEls.forEach((p, i) => {
        p.classList.toggle('active', i === current);
        p.onclick = () => goTo(i);
        p.setAttribute('aria-label', 'Slide ' + (i + 1));
      });
    } else {
      const half  = Math.floor(PIP_MAX / 2);
      let   start = Math.max(0, current - half);
      if (start + PIP_MAX > total) start = total - PIP_MAX;
      pipEls.forEach((p, i) => {
        const idx = start + i;
        p.classList.toggle('active', idx === current);
        p.setAttribute('aria-label', 'Slide ' + (idx + 1));
        p.onclick = () => goTo(idx);
      });
    }
  }

  prevBtn.addEventListener('click', () => goTo(current - 1));
  nextBtn.addEventListener('click', () => goTo(current + 1));

  document.addEventListener('keydown', e => {
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown') { e.preventDefault(); goTo(current + 1); }
    if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')   { e.preventDefault(); goTo(current - 1); }
  });

  update();
})();
</script>

<style>
/* ── Layout ─────────────────────────────────────────── */
.sw-wrap {
  display: flex;
  flex-direction: column;
  height: calc(100vh - 68px);
  background: var(--bg, #0d1117);
  overflow: hidden;
}

/* ── Top bar ─────────────────────────────────────────── */
.sw-topbar {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 10px 24px;
  background: rgba(255,255,255,0.03);
  border-bottom: 1px solid rgba(255,255,255,0.07);
  flex-shrink: 0;
}
.sw-topbar-left {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
}
.sw-course-code {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.35);
  background: rgba(255,255,255,0.06);
  padding: 3px 8px;
  border-radius: 4px;
}
.sw-course-name {
  font-size: 13px;
  color: rgba(255,255,255,0.5);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 240px;
}
.sw-progress-track {
  flex: 1;
  height: 4px;
  background: rgba(255,255,255,0.08);
  border-radius: 2px;
  overflow: hidden;
}
.sw-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #9333ea, #a855f7);
  border-radius: 2px;
  transition: width 0.35s ease;
}
.sw-counter {
  font-size: 13px;
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
  min-width: 56px;
  text-align: right;
}
.sw-counter-of { color: rgba(255,255,255,0.35); font-weight: 400; }

/* ── Viewport ────────────────────────────────────────── */
.sw-viewport {
  flex: 1;
  overflow: hidden;
  position: relative;
}
.sw-slide {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  overflow-y: auto;
}
.sw-slide[hidden] { display: none; }

/* ── Slide header ────────────────────────────────────── */
.sw-slide-header {
  padding: 20px 32px 0;
  display: flex;
  align-items: center;
  gap: 14px;
  flex-shrink: 0;
}
.sw-badge {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 4px 11px;
  border-radius: 999px;
  flex-shrink: 0;
}
.sw-slide-title {
  font-size: clamp(17px, 2.2vw, 24px);
  font-weight: 700;
  letter-spacing: -0.02em;
  color: #fff;
  margin: 0;
  line-height: 1.2;
}

/* badge colours */
.type-opening    { background: rgba(147,51,234,0.15); color: #c084fc; border: 1px solid rgba(147,51,234,0.3); }
.type-youtube    { background: rgba(239,68,68,0.15);  color: #f87171; border: 1px solid rgba(239,68,68,0.3); }
.type-pdf        { background: rgba(249,115,22,0.15); color: #fb923c; border: 1px solid rgba(249,115,22,0.3); }
.type-powerpoint { background: rgba(234,88,12,0.15);  color: #fdba74; border: 1px solid rgba(234,88,12,0.3); }
.type-document   { background: rgba(20,184,166,0.15); color: #2dd4bf; border: 1px solid rgba(20,184,166,0.3); }
.type-homework   { background: rgba(99,102,241,0.15); color: #a5b4fc; border: 1px solid rgba(99,102,241,0.3); }
.type-assessment { background: rgba(245,158,11,0.15); color: #fcd34d; border: 1px solid rgba(245,158,11,0.3); }
.type-welcome    { background: rgba(59,130,246,0.15); color: #93c5fd; border: 1px solid rgba(59,130,246,0.3); }

/* ── Slide body ──────────────────────────────────────── */
.sw-slide-body {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px 32px;
}

/* ── Opening ─────────────────────────────────────────── */
.opening-card {
  width: 100%;
  max-width: 800px;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 24px 64px rgba(0,0,0,0.6);
}
.opening-img {
  position: relative;
  aspect-ratio: 16 / 7;
  background: #0a0e1a center / cover no-repeat;
}
.opening-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(8,12,21,0.88) 40%, rgba(147,51,234,0.22));
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 36px;
}
.opening-chips {
  display: flex;
  gap: 8px;
  margin-bottom: 16px;
  flex-wrap: wrap;
}
.opening-chip {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.6);
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.15);
  padding: 4px 10px;
  border-radius: 999px;
}
.opening-headline {
  font-size: clamp(24px, 4vw, 46px);
  font-weight: 900;
  letter-spacing: -0.035em;
  color: #fff;
  line-height: 1.05;
  margin-bottom: 10px;
}
.opening-pub {
  font-size: 13px;
  color: rgba(255,255,255,0.45);
}

/* ── YouTube ─────────────────────────────────────────── */
.yt-wrap {
  width: 100%;
  max-width: 860px;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 20px 60px rgba(0,0,0,0.6);
  aspect-ratio: 16 / 9;
}
.yt-wrap iframe {
  width: 100%;
  height: 100%;
  border: none;
  display: block;
}

/* ── Resource card (PDF / PPT / bare doc) ─────────────── */
.resource-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20px;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 20px;
  padding: 48px 48px 44px;
  max-width: 460px;
  width: 100%;
  text-align: center;
  box-shadow: 0 16px 48px rgba(0,0,0,0.4);
}
.rc-icon {
  width: 88px;
  height: 88px;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.rc-icon-pdf { background: rgba(249,115,22,0.12); color: #fb923c; border: 1px solid rgba(249,115,22,0.25); }
.rc-icon-ppt { background: rgba(234,88,12,0.12);  color: #fdba74; border: 1px solid rgba(234,88,12,0.25); }
.rc-icon-doc { background: rgba(20,184,166,0.12); color: #2dd4bf; border: 1px solid rgba(20,184,166,0.25); }
.rc-info { display: flex; flex-direction: column; gap: 6px; }
.rc-type {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.35);
}
.rc-title {
  font-size: clamp(18px, 2.2vw, 24px);
  font-weight: 700;
  letter-spacing: -0.02em;
  color: #fff;
  margin: 0;
}
.rc-note {
  font-size: 13px;
  color: rgba(255,255,255,0.35);
  margin: 0;
