---
import Base from "../layouts/Base.astro";
import course from "../data/course.json";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const worksheets = (course.sections as any[]).filter((s: any) => s.kind === "worksheet");
const wsMap: Record<number, any> = {};
for (const w of worksheets) wsMap[w.number] = w;

function ytId(url: string): string {
  return url.match(/youtu\.be\/([^?&]+)/)?.[1] ?? "";
}

interface DocSlide  { type: "document";    title: string; ws?: number; }
interface YtSlide   { type: "youtube";     title: string; url: string; }
interface PdfSlide  { type: "pdf";         title: string; url: string; }
interface PptSlide  { type: "powerpoint";  title: string; points: string[]; }
interface HtmlSlide { type: "html";        title: string; subtype: "welcome" | "homework" | "assessment"; }
interface OpenSlide { type: "opening";     title: string; }
type SlideDef = DocSlide | YtSlide | PdfSlide | PptSlide | HtmlSlide | OpenSlide;

const SLIDES: SlideDef[] = [
  { type: "opening",    title: "Introduction to Microcontrollers" },
  { type: "html",       title: "Welcome",                            subtype: "welcome" },
  { type: "youtube",    title: "Introducing E-blocks 3",             url: "https://youtu.be/KmpyVmv6J_Y?si=bzAVMntlAOE_-Rlv" },
  { type: "youtube",    title: "Introducing Flowcode",               url: "https://youtu.be/tDdptTbvDM0?si=19xqKAzPCOO3In5e" },
  { type: "pdf",        title: "E-blocks datasheet",                 url: "https://www.matrixtsl.com/wp-content/uploads/2026/03/CP9645-Eblocks-3-Datasheet-1.pdf" },
  { type: "powerpoint", title: "Microcontroller basics 1", points: [
    "What is a microcontroller, and how does it differ from a microprocessor?",
    "Key internal components: CPU, Flash memory, RAM, and I/O ports",
    "Overview of the E-blocks 3 hardware platform and its modules",
    "Digital signals — HIGH and LOW logic levels explained",
    "Introduction to binary: how computers represent data in 1s and 0s",
    "Real-world applications of microcontrollers in everyday products",
  ]},
  { type: "powerpoint", title: "Microcontroller basics 2", points: [
    "The fetch-decode-execute cycle: how a microcontroller runs a program",
    "GPIO pins — configuring ports as inputs or outputs in Flowcode",
    "Pull-up and pull-down resistors and why floating pins cause problems",
    "Clock speed and its effect on instruction timing and delays",
    "Introduction to the Flowcode Embedded IDE and project structure",
    "Program flow: variables, loops, and conditional branching",
  ]},
  { type: "document",   title: "First program",                      ws: 1 },
  { type: "document",   title: "Performing calculations",            ws: 2 },
  { type: "document",   title: "Connection points",                  ws: 3 },
  { type: "document",   title: "Digital inputs",                     ws: 4 },
  { type: "html",       title: "Homework 1",                         subtype: "homework" },
  { type: "document",   title: "Making decisions",                   ws: 5 },
  { type: "document",   title: "Macros / subroutines",               ws: 6 },
  { type: "document",   title: "Using prototype boards",             ws: 7 },
  { type: "document",   title: "Analogue inputs" },
  { type: "document",   title: "Colour graphical displays",          ws: 8 },
  { type: "html",       title: "Homework 2",                         subtype: "homework" },
  { type: "document",   title: "Colour graphical displays",          ws: 8 },
  { type: "document",   title: "Light sensor" },
  { type: "document",   title: "Analogue temperature sensor" },
  { type: "html",       title: "Homework 3",                         subtype: "homework" },
  { type: "html",       title: "Assessment 1",                       subtype: "assessment" },
  { type: "document",   title: "Digital temperature sensor" },
  { type: "document",   title: "Digital accelerometer" },
  { type: "html",       title: "Assessment 2",                       subtype: "assessment" },
  { type: "document",   title: "Basic DC motors" },
  { type: "document",   title: "Full bridge motor control" },
  { type: "document",   title: "Stepper motor control" },
  { type: "document",   title: "Servo motor control" },
  { type: "html",       title: "Homework 6",                         subtype: "homework" },
  { type: "document",   title: "Floats and INTs" },
  { type: "document",   title: "Pin interrupts",                     ws: 9 },
  { type: "document",   title: "Timer interrupts",                   ws: 10 },
  { type: "html",       title: "Homework 7",                         subtype: "homework" },
  { type: "document",   title: "Touch control systems",              ws: 11 },
  { type: "html",       title: "Homework 8",                         subtype: "homework" },
  { type: "document",   title: "Web mirror",                         ws: 12 },
  { type: "html",       title: "Homework 9",                         subtype: "homework" },
];

const slides = SLIDES.map((s, i) => {
  const wsNum = (s as DocSlide).ws;
  return { ...s, index: i, wsData: wsNum ? wsMap[wsNum] : null };
});
const total = slides.length;

function typeLabel(s: SlideDef): string {
  if (s.type === "html") {
    return { welcome: "Welcome", homework: "Homework", assessment: "Assessment" }[(s as HtmlSlide).subtype];
  }
  return ({ opening: "Introduction", youtube: "Video", pdf: "PDF Resource", powerpoint: "Presentation", document: "Worksheet" } as Record<string,string>)[s.type] ?? s.type;
}
function typeClass(s: SlideDef): string {
  if (s.type === "html") return `type-${(s as HtmlSlide).subtype}`;
  return `type-${s.type}`;
}
---

<Base title={`${course.unit}: Scheme of Work`}>
  <div class="sw-wrap" id="sw-wrap">

    <!-- Top bar -->
    <div class="sw-topbar">
      <div class="sw-topbar-left">
        <span class="sw-course-code">{course.code}</span>
        <span class="sw-course-name">{course.title}</span>
      </div>
      <div class="sw-progress-track">
        <div class="sw-progress-fill" id="sw-progress-fill"></div>
      </div>
      <div class="sw-counter" id="sw-counter">1 <span class="sw-counter-of">/ {total}</span></div>
    </div>

    <!-- Slides container -->
    <div class="sw-viewport" id="sw-viewport">
      {slides.map((s, i) => {
        const label  = typeLabel(s as SlideDef);
        const cls    = typeClass(s as SlideDef);
        const isDoc  = s.type === "document";
        const wsNum  = (s as any).ws as number | undefined;
        const wsData = (s as any).wsData;
        return (
          <div class={`sw-slide ${cls}`} data-index={i} data-type={cls} aria-hidden={i > 0 ? "true" : "false"} hidden={i > 0}>

            <!-- Ambient glow orbs — color driven by CSS var per slide type -->
            <div class="sw-orb sw-orb-1" aria-hidden="true"></div>
            <div class="sw-orb sw-orb-2" aria-hidden="true"></div>

            <!-- Slide header (hidden for full-bleed slides via CSS) -->
            <div class="sw-slide-header">
              <span class={`sw-badge ${cls}`}>{label}</span>
              <h1 class="sw-slide-title">{s.title}</h1>
            </div>

            <div class="sw-slide-body">

              {/* ── Opening ── */}
              {s.type === "opening" && (
                <div class="opening-card">
                  <div class="opening-img" style={`background-image: url('${base}/images/intro_to_micros_cover.jpg')`}>
                    <div class="opening-grid" aria-hidden="true"></div>
                    <div class="opening-overlay">
                      <div class="opening-chips">
                        <span class="opening-chip">{course.unit}</span>
                        <span class="opening-chip">{course.code}</span>
                        <span class="opening-chip">{course.hours}-hour course</span>
                      </div>
                      <div class="opening-headline">{s.title}</div>
                      <div class="opening-pub">{course.publisher}</div>
                    </div>
                  </div>
                </div>
              )}

              {/* ── YouTube (lite embed — thumbnail until clicked) ── */}
              {s.type === "youtube" && (
                <div class="yt-outer">
                  <div class="yt-glow" aria-hidden="true"></div>
                  <div class="yt-wrap">
                    <div class="yt-lite" data-vid={ytId((s as YtSlide).url)}>
                      <img
                        class="yt-thumb"
                        src={`https://img.youtube.com/vi/${ytId((s as YtSlide).url)}/maxresdefault.jpg`}
                        onerror={`this.src='https://img.youtube.com/vi/${ytId((s as YtSlide).url)}/hqdefault.jpg'`}
                        alt={s.title}
                        loading="lazy"
                        draggable="false"
                      />
                      <button class="yt-play-btn" aria-label={`Play: ${s.title}`}>
                        <svg class="yt-play-bg" viewBox="0 0 68 48" width="68" height="48" aria-hidden="true">
                          <path d="M66.5 7.7a8.5 8.5 0 0 0-6-6C56.1 0 34 0 34 0S11.9 0 7.5 1.7a8.5 8.5 0 0 0-6 6C0 12.1 0 24 0 24s0 11.9 1.5 16.3a8.5 8.5 0 0 0 6 6C11.9 48 34 48 34 48s22.1 0 26.5-1.7a8.5 8.5 0 0 0 6-6C68 35.9 68 24 68 24s0-11.9-1.5-16.3z" fill="#ff0000"/>
                          <path d="M45 24L27 14v20" fill="#fff"/>
                        </svg>
                      </button>
                    </div>
                  </div>
                </div>
              )}

              {/* ── PDF ── */}
              {s.type === "pdf" && (
                <div class="pdf-hero">
                  <div class="pdf-hero-watermark" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.4" width="340" height="340"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                  </div>
                  <div class="pdf-hero-content">
                    <div class="pdf-hero-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="36" height="36"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                    </div>
                    <p class="pdf-hero-label">PDF Resource</p>
                    <h2 class="pdf-hero-title">{s.title}</h2>
                    <p class="pdf-hero-desc">Technical specification document — open to read or download.</p>
                    <a href={(s as PdfSlide).url} target="_blank" rel="noopener" class="pdf-hero-btn">
                      Open PDF
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                    </a>
                  </div>
                </div>
              )}

              {/* ── PowerPoint ── */}
              {s.type === "powerpoint" && (
                <div class="ppt-card">
                  <div class="ppt-card-top">
                    <div class="ppt-icon-wrap">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/><path d="M9 8h3a2 2 0 0 1 0 4H9V8z"/></svg>
                    </div>
                    <div>
                      <div class="ppt-card-type">PowerPoint Presentation</div>
                      <h2 class="ppt-card-title">{s.title}</h2>
                    </div>
                  </div>
                  <div class="ppt-divider"></div>
                  <div class="ppt-agenda-label">In this session we will cover:</div>
                  <ul class="ppt-points">
                    {(s as PptSlide).points.map((p, pi) => (
                      <li class="ppt-point">
                        <span class="ppt-num" aria-hidden="true">0{pi + 1}</span>
                        {p}
                      </li>
                    ))}
                  </ul>
                  <button class="ppt-open-btn" disabled aria-disabled="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
                    Open Presentation
                    <span class="ppt-open-soon">coming soon</span>
                  </button>
                </div>
              )}

              {/* ── Worksheet with page ── */}
              {isDoc && wsData && (
                <div
                  class="ws-card"
                  style={wsData.heroImage ? `--ws-img: url('${base}/images/${wsData.heroImage}')` : ""}
                >
                  {wsData.heroImage && <div class="ws-card-bg"></div>}
                  <div class="ws-card-gradient"></div>
                  <div class="ws-card-info">
                    <div class="ws-card-meta">
                      <span class="ws-card-label">Worksheet {wsNum}</span>
                      {wsData.tier && (
                        <span class={`ws-tier-badge ${wsData.tier.toLowerCase()}`}>{wsData.tier}</span>
                      )}
                    </div>
                    <h2 class="ws-card-title">{s.title}</h2>
                    <a href={`${base}/worksheets/${wsNum}`} class="ws-open-btn">
                      Open interactive worksheet
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="18" height="18" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </a>
                  </div>
                </div>
              )}

              {/* ── Worksheet without page ── */}
              {isDoc && !wsData && (
                <div class="doc-hero">
                  <div class="doc-hero-watermark" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.35" width="300" height="300"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                  </div>
                  <div class="doc-hero-content">
                    <div class="doc-hero-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="32" height="32"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                    </div>
                    <p class="doc-hero-label">Worksheet Document</p>
                    <h2 class="doc-hero-title">{s.title}</h2>
                    <p class="doc-hero-desc">Practical worksheet — work through the activities with your E-blocks 3 kit.</p>
                  </div>
                </div>
              )}

              {/* ── HTML (homework / assessment / welcome) ── */}
              {s.type === "html" && (
                <div class={`html-hero html-${(s as HtmlSlide).subtype}`}>
                  <div class="html-hero-watermark" aria-hidden="true">
                    {(s as HtmlSlide).subtype === "assessment" && (
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.3" width="340" height="340"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                    )}
                    {(s as HtmlSlide).subtype === "homework" && (
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.3" width="340" height="340"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                    )}
                    {(s as HtmlSlide).subtype === "welcome" && (
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.3" width="340" height="340"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                    )}
                  </div>
                  <div class="html-hero-content">
                    <div class="html-hero-icon">
                      {(s as HtmlSlide).subtype === "assessment" && (
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="34" height="34"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                      )}
                      {(s as HtmlSlide).subtype === "homework" && (
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="34" height="34"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                      )}
                      {(s as HtmlSlide).subtype === "welcome" && (
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="34" height="34"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                      )}
                    </div>
                    <p class="html-hero-label">
                      {(s as HtmlSlide).subtype === "assessment" ? "Summative Assessment" :
                       (s as HtmlSlide).subtype === "homework"   ? "Take-Home Homework"   : "Interactive Resource"}
                    </p>
                    <h2 class="html-hero-title">{s.title}</h2>
                    <p class="html-hero-desc">
                      {(s as HtmlSlide).subtype === "assessment"
                        ? "Formal assessment — students complete and submit via your institution's VLE."
                        : (s as HtmlSlide).subtype === "homework"
                        ? "Set for home — students complete and bring answers to the next session."
                        : "Interactive HTML resource — open in a browser window."}
                    </p>
                  </div>
                </div>
              )}

            </div>
          </div>
        );
      })}
    </div>

    <!-- Navigation -->
    <div class="sw-nav">
      <button class="sw-nav-btn sw-prev" id="sw-prev" disabled aria-label="Previous slide">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
        Previous
      </button>
      <div class="sw-nav-pips" id="sw-pips" aria-hidden="true"></div>
      <button class="sw-nav-btn sw-next" id="sw-next" aria-label="Next slide">
        Next
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>

  </div>
</Base>

<script define:vars={{ total }}>
(function () {
  let current = 0;
  const slideEls = Array.from(document.querySelectorAll('.sw-slide'));
  const wrap     = document.getElementById('sw-wrap');
  const prevBtn  = document.getElementById('sw-prev');
  const nextBtn  = document.getElementById('sw-next');
  const counter  = document.getElementById('sw-counter');
  const fill     = document.getElementById('sw-progress-fill');
  const pipsWrap = document.getElementById('sw-pips');

  // Build pips
  const PIP_MAX = 9;
  const pipEls  = [];
  for (let i = 0; i < Math.min(total, PIP_MAX); i++) {
    const btn = document.createElement('button');
    btn.className = 'sw-pip';
    pipsWrap.appendChild(btn);
    pipEls.push(btn);
  }

  // Wire up lite YouTube embeds — replace thumbnail with autoplay iframe on click
  document.querySelectorAll('.yt-lite').forEach(lite => {
    lite.querySelector('.yt-play-btn').addEventListener('click', () => {
      const vid = lite.dataset.vid;
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube.com/embed/${vid}?autoplay=1&rel=0`;
      iframe.title = lite.querySelector('.yt-thumb').alt;
      iframe.setAttribute('frameborder', '0');
      iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share');
      iframe.setAttribute('allowfullscreen', '');
      // Swap the lite div for the iframe inside the same .yt-wrap
      lite.parentNode.replaceChild(iframe, lite);
    }, { once: true });
  });

  function goTo(n) {
    const prev = slideEls[current];
    prev.hidden = true;
    prev.setAttribute('aria-hidden', 'true');
    prev.classList.remove('entering');
    // Pause any live iframes when navigating away
    prev.querySelectorAll('iframe').forEach(f => {
      try { f.contentWindow.postMessage('{"event":"command","func":"pauseVideo","args":""}', '*'); } catch (_) {}
    });

    current = Math.max(0, Math.min(total - 1, n));
    const next = slideEls[current];
    next.hidden = false;
    next.setAttribute('aria-hidden', 'false');
    next.classList.remove('entering');
    requestAnimationFrame(() => next.classList.add('entering'));

    wrap.dataset.type = next.dataset.type || '';
    update();
  }

  function update() {
    prevBtn.disabled = current === 0;
    nextBtn.disabled = current === total - 1;
    counter.innerHTML = (current + 1) + ' <span class="sw-counter-of">/ ' + total + '</span>';
    if (fill) fill.style.width = ((current + 1) / total * 100) + '%';

    // Pips
    if (total <= PIP_MAX) {
      pipEls.forEach((p, i) => {
        p.classList.toggle('active', i === current);
        p.onclick = () => goTo(i);
        p.setAttribute('aria-label', 'Slide ' + (i + 1));
      });
    } else {
      const half  = Math.floor(PIP_MAX / 2);
      let   start = Math.max(0, current - half);
      if (start + PIP_MAX > total) start = total - PIP_MAX;
      pipEls.forEach((p, i) => {
        const idx = start + i;
        p.classList.toggle('active', idx === current);
        p.setAttribute('aria-label', 'Slide ' + (idx + 1));
        p.onclick = () => goTo(idx);
      });
    }
  }

  prevBtn.addEventListener('click', () => goTo(current - 1));
  nextBtn.addEventListener('click', () => goTo(current + 1));
  document.addEventListener('keydown', e => {
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown') { e.preventDefault(); goTo(current + 1); }
    if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')   { e.preventDefault(); goTo(current - 1); }
  });

  // Init first slide
  wrap.dataset.type = slideEls[0]?.dataset.type || '';
  slideEls[0]?.classList.add('entering');
  update();
})();
</script>

<style>
/* ═══════════════════════════════════════════════════════
   LAYOUT
═══════════════════════════════════════════════════════ */
.sw-wrap {
  display: flex;
  flex-direction: column;
  height: calc(100vh - 68px);
  background: #080c15;
  overflow: hidden;
}

/* ═══════════════════════════════════════════════════════
   TOP BAR
═══════════════════════════════════════════════════════ */
.sw-topbar {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 0 24px;
  height: 44px;
  background: rgba(255,255,255,0.025);
  border-bottom: 1px solid rgba(255,255,255,0.06);
  flex-shrink: 0;
}
.sw-topbar-left { display: flex; align-items: center; gap: 10px; flex-shrink: 0; }
.sw-course-code {
  font-size: 10px; font-weight: 800; letter-spacing: 0.12em;
  text-transform: uppercase; color: rgba(255,255,255,0.3);
  background: rgba(255,255,255,0.06); padding: 3px 8px; border-radius: 4px;
}
.sw-course-name {
  font-size: 12px; color: rgba(255,255,255,0.4);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 260px;
}
.sw-progress-track {
  flex: 1; height: 3px; background: rgba(255,255,255,0.07); border-radius: 2px; overflow: hidden;
}
.sw-progress-fill {
  height: 100%; border-radius: 2px;
  background: linear-gradient(90deg, #9333ea, #a855f7);
  transition: width 0.4s cubic-bezier(0.25,0.46,0.45,0.94),
              background 0.5s ease;
  box-shadow: 0 0 10px rgba(147,51,234,0.6);
}
/* Dynamic progress accent — driven by [data-type] on .sw-wrap */
[data-type="type-youtube"]    .sw-progress-fill { background: linear-gradient(90deg,#ef4444,#f87171); box-shadow: 0 0 10px rgba(239,68,68,0.6); }
[data-type="type-pdf"]        .sw-progress-fill { background: linear-gradient(90deg,#f97316,#fb923c); box-shadow: 0 0 10px rgba(249,115,22,0.6); }
[data-type="type-powerpoint"] .sw-progress-fill { background: linear-gradient(90deg,#ea580c,#f97316); box-shadow: 0 0 10px rgba(234,88,12,0.6); }
[data-type="type-document"]   .sw-progress-fill { background: linear-gradient(90deg,#14b8a6,#2dd4bf); box-shadow: 0 0 10px rgba(20,184,166,0.5); }
[data-type="type-homework"]   .sw-progress-fill { background: linear-gradient(90deg,#6366f1,#818cf8); box-shadow: 0 0 10px rgba(99,102,241,0.6); }
[data-type="type-assessment"] .sw-progress-fill { background: linear-gradient(90deg,#f59e0b,#fbbf24); box-shadow: 0 0 10px rgba(245,158,11,0.6); }
[data-type="type-welcome"]    .sw-progress-fill { background: linear-gradient(90deg,#3b82f6,#60a5fa); box-shadow: 0 0 10px rgba(59,130,246,0.6); }

.sw-counter { font-size: 13px; font-weight: 700; color: #fff; flex-shrink: 0; min-width: 58px; text-align: right; }
.sw-counter-of { color: rgba(255,255,255,0.3); font-weight: 400; }

/* ═══════════════════════════════════════════════════════
   SLIDE TRANSITION
═══════════════════════════════════════════════════════ */
@keyframes swIn {
  from { opacity: 0; transform: translateY(12px) scale(0.994); }
  to   { opacity: 1; transform: translateY(0)    scale(1); }
}
.sw-slide.entering {
  animation: swIn 0.32s cubic-bezier(0.22, 1, 0.36, 1) both;
}

/* ═══════════════════════════════════════════════════════
   VIEWPORT & SLIDES
═══════════════════════════════════════════════════════ */
.sw-viewport { flex: 1; overflow: hidden; position: relative; }
.sw-slide {
  position: absolute; inset: 0;
  display: flex; flex-direction: column;
  overflow: hidden; /* clip glow orbs and watermarks that extend beyond bounds */
}
.sw-slide[hidden] { display: none; }

/* ── Ambient glow orbs (RGB set per slide type) ── */
.type-opening    { --gc: 147,51,234; }
.type-youtube    { --gc: 239,68,68; }
.type-pdf        { --gc: 249,115,22; }
.type-powerpoint { --gc: 234,88,12; }
.type-document   { --gc: 20,184,166; }
.type-homework   { --gc: 99,102,241; }
.type-assessment { --gc: 245,158,11; }
.type-welcome    { --gc: 59,130,246; }

.sw-orb {
  position: absolute; border-radius: 50%;
  pointer-events: none; z-index: 0;
  filter: blur(110px);
  background: rgba(var(--gc, 147,51,234), 1);
}
.sw-orb-1 { top: -220px; right: -180px; width: 640px; height: 640px; opacity: 0.14; }
.sw-orb-2 { bottom: -160px; left: -140px; width: 440px; height: 440px; opacity: 0.08; }

/* ═══════════════════════════════════════════════════════
   SLIDE HEADER (badge + title above content)
═══════════════════════════════════════════════════════ */
.sw-slide-header {
  position: relative; z-index: 2;
  padding: 18px 28px 0;
  display: flex; align-items: center; gap: 12px;
  flex-shrink: 0;
}
/* Full-bleed slides: header overlays the top of the card */
.type-document .sw-slide-header,
.type-homework .sw-slide-header,
.type-assessment .sw-slide-header,
.type-welcome  .sw-slide-header,
.type-pdf      .sw-slide-header,
.type-opening  .sw-slide-header {
  position: absolute; top: 0; left: 0; right: 0;
  padding: 18px 24px;
  background: linear-gradient(to bottom, rgba(8,12,21,0.65), transparent);
  z-index: 10;
}

.sw-badge {
  font-size: 10px; font-weight: 800; letter-spacing: 0.12em;
  text-transform: uppercase; padding: 4px 11px; border-radius: 999px; flex-shrink: 0;
}
.sw-slide-title {
  font-size: clamp(15px, 1.8vw, 20px); font-weight: 600;
  letter-spacing: -0.01em; color: rgba(255,255,255,0.85); margin: 0; line-height: 1.2;
}
/* Hide header title for full-bleed slides (title lives inside the card) */
.type-document  .sw-slide-title,
.type-homework  .sw-slide-title,
.type-assessment .sw-slide-title,
.type-welcome   .sw-slide-title,
.type-pdf       .sw-slide-title,
.type-opening   .sw-slide-title { display: none; }

/* badge colours */
.type-opening    .sw-badge { background: rgba(147,51,234,0.2); color: #c084fc; border: 1px solid rgba(147,51,234,0.4); }
.type-youtube    .sw-badge { background: rgba(239,68,68,0.2);  color: #f87171; border: 1px solid rgba(239,68,68,0.4); }
.type-pdf        .sw-badge { background: rgba(249,115,22,0.2); color: #fb923c; border: 1px solid rgba(249,115,22,0.4); }
.type-powerpoint .sw-badge { background: rgba(234,88,12,0.2);  color: #fdba74; border: 1px solid rgba(234,88,12,0.4); }
.type-document   .sw-badge { background: rgba(20,184,166,0.2); color: #2dd4bf; border: 1px solid rgba(20,184,166,0.4); }
.type-homework   .sw-badge { background: rgba(99,102,241,0.2); color: #a5b4fc; border: 1px solid rgba(99,102,241,0.4); }
.type-assessment .sw-badge { background: rgba(245,158,11,0.2); color: #fcd34d; border: 1px solid rgba(245,158,11,0.4); }
.type-welcome    .sw-badge { background: rgba(59,130,246,0.2); color: #93c5fd; border: 1px solid rgba(59,130,246,0.4); }

/* ═══════════════════════════════════════════════════════
   SLIDE BODY
═══════════════════════════════════════════════════════ */
.sw-slide-body {
  flex: 1; position: relative; z-index: 1;
  display: flex; align-items: center; justify-content: center;
  padding: 20px 28px 24px; min-height: 0; overflow: hidden;
}
/* Full-bleed types: body fills entire slide (header overlays it) */
.type-document   .sw-slide-body,
.type-homework   .sw-slide-body,
.type-assessment .sw-slide-body,
.type-welcome    .sw-slide-body,
.type-pdf        .sw-slide-body,
.type-opening    .sw-slide-body {
  position: absolute; inset: 0; padding: 0; align-items: stretch; overflow: hidden;
}

/* ═══════════════════════════════════════════════════════
   OPENING
═══════════════════════════════════════════════════════ */
.opening-card { width: 100%; height: 100%; position: relative; overflow: hidden; }
.opening-img {
  position: absolute; inset: 0;
  background: #0a0e1a center / cover no-repeat;
  transform: scale(1.03); transition: transform 8s ease;
}
.opening-card:hover .opening-img { transform: scale(1.07); }
.opening-grid {
  position: absolute; inset: 0;
  background-image: linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
                    linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
  background-size: 60px 60px;
}
.opening-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(8,12,21,0.82) 35%, rgba(147,51,234,0.18));
  display: flex; flex-direction: column; justify-content: flex-end; padding: 44px 52px;
}
.opening-chips { display: flex; gap: 8px; margin-bottom: 20px; flex-wrap: wrap; }
.opening-chip {
  font-size: 10px; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase;
  color: rgba(255,255,255,0.55); background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.14); padding: 4px 12px; border-radius: 999px;
}
.opening-headline {
  font-size: clamp(32px, 5vw, 62px); font-weight: 900;
  letter-spacing: -0.04em; color: #fff; line-height: 1.0; margin-bottom: 14px;
  text-shadow: 0 4px 32px rgba(0,0,0,0.5);
}
.opening-pub { font-size: 13px; color: rgba(255,255,255,0.4); font-weight: 500; }

/* ═══════════════════════════════════════════════════════
   YOUTUBE — LITE EMBED
═══════════════════════════════════════════════════════ */
.yt-outer {
  position: relative; width: 100%; max-width: 880px;
  display: flex; flex-direction: column; align-items: center;
}
.yt-glow {
  position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
  width: 110%; height: 110%; border-radius: 16px;
  background: rgba(239,68,68,0.12); filter: blur(40px);
  pointer-events: none;
}
.yt-wrap {
  position: relative; z-index: 1; width: 100%;
  border-radius: 14px; overflow: hidden;
  box-shadow: 0 0 0 1px rgba(239,68,68,0.2), 0 24px 80px rgba(0,0,0,0.7);
  aspect-ratio: 16 / 9;
}
/* Lite embed: thumbnail fills the wrap */
.yt-lite {
  position: relative; width: 100%; height: 100%;
  cursor: pointer; display: block;
  background: #000;
}
.yt-thumb {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
  transition: transform 0.4s ease, filter 0.3s ease;
}
.yt-lite:hover .yt-thumb {
  transform: scale(1.02);
  filter: brightness(0.75);
}
/* Play button */
.yt-play-btn {
  position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: center;
  background: none; border: none; cursor: pointer; padding: 0;
}
.yt-play-bg {
  filter: drop-shadow(0 4px 24px rgba(0,0,0,0.6));
  transition: transform 0.2s ease, filter 0.2s ease;
}
.yt-lite:hover .yt-play-bg {
  transform: scale(1.1);
  filter: drop-shadow(0 6px 32px rgba(0,0,0,0.8));
}
/* Once activated, fill with iframe */
.yt-wrap iframe { width: 100%; height: 100%; border: none; display: block; position: absolute; inset: 0; }

/* ═══════════════════════════════════════════════════════
   PDF HERO (full-bleed)
═══════════════════════════════════════════════════════ */
.pdf-hero {
  position: relative; width: 100%; height: 100%; overflow: hidden;
  background: linear-gradient(135deg, rgba(249,115,22,0.18) 0%, rgba(8,12,21,1) 55%);
  border-top: 2px solid rgba(249,115,22,0.3);
  display: flex; align-items: center; justify-content: center;
}
.pdf-hero-watermark {
  position: absolute; top: 50%; left: 55%;
  transform: translate(-50%,-50%);
  opacity: 0.04; color: #f97316; pointer-events: none;
}
.pdf-hero-content {
  position: relative; z-index: 1;
  display: flex; flex-direction: column; align-items: flex-start;
  gap: 16px; max-width: 560px; width: 100%; padding: 0 52px;
}
.pdf-hero-icon {
  width: 68px; height: 68px; border-radius: 16px;
  background: rgba(249,115,22,0.15); color: #fb923c;
  border: 1px solid rgba(249,115,22,0.3);
  display: flex; align-items: center; justify-content: center;
}
.pdf-hero-label {
  font-size: 11px; font-weight: 800; letter-spacing: 0.14em;
  text-transform: uppercase; color: rgba(251,146,60,0.7); margin: 0;
}
.pdf-hero-title {
  font-size: clamp(28px, 4vw, 48px); font-weight: 900;
  letter-spacing: -0.04em; color: #fff; margin: 0; line-height: 1.05;
}
.pdf-hero-desc {
  font-size: 14px; color: rgba(255,255,255,0.4); margin: 0; line-height: 1.6;
}
.pdf-hero-btn {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 14px 32px; border-radius: 10px;
  background: #f97316; color: #fff;
  font-size: 15px; font-weight: 700; text-decoration: none;
  transition: opacity 0.15s, transform 0.15s;
  box-shadow: 0 4px 28px rgba(249,115,22,0.45);
}
.pdf-hero-btn:hover { opacity: 0.88; transform: translateY(-2px); text-decoration: none; }

/* ═══════════════════════════════════════════════════════
   POWERPOINT CARD
═══════════════════════════════════════════════════════ */
.ppt-card {
  display: flex; flex-direction: column; gap: 14px;
  background: rgba(255,255,255,0.035);
  border: 1px solid rgba(234,88,12,0.18);
  border-top: 3px solid #ea580c;
  border-radius: 18px; padding: 30px 36px 28px;
  max-width: 680px; width: 100%;
  /* Constrain height so card never overflows the slide body */
  max-height: 100%;
  overflow-y: auto;
  box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 0 1px rgba(234,88,12,0.08);
  position: relative;
}
/* subtle grid inside ppt card — applied to inner wrapper so it doesn't scroll */
.ppt-card-top::before {
  content: '';
  position: absolute; inset: -30px -36px 0; pointer-events: none; z-index: 0;
  background-image: linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px),
                    linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px);
  background-size: 40px 40px;
}
.ppt-card-top { display: flex; align-items: center; gap: 16px; position: relative; }
.ppt-icon-wrap {
  width: 50px; height: 50px; border-radius: 12px;
  background: rgba(234,88,12,0.12); color: #fdba74;
  border: 1px solid rgba(234,88,12,0.25);
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.ppt-card-type {
  font-size: 10px; font-weight: 800; letter-spacing: 0.12em;
  text-transform: uppercase; color: rgba(253,186,116,0.55); margin-bottom: 4px;
}
.ppt-card-title {
  font-size: clamp(18px, 2.2vw, 24px); font-weight: 800;
  letter-spacing: -0.025em; color: #fff; margin: 0;
}
.ppt-divider { height: 1px; background: rgba(255,255,255,0.06); }
.ppt-agenda-label {
  font-size: 10px; font-weight: 800; letter-spacing: 0.12em;
  text-transform: uppercase; color: rgba(255,255,255,0.25);
}
.ppt-points { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 9px; }
.ppt-point {
  display: flex; align-items: baseline; gap: 14px;
  font-size: 14px; line-height: 1.5; color: rgba(255,255,255,0.72);
  position: relative;
}
.ppt-num {
  font-size: 10px; font-weight: 800; color: rgba(234,88,12,0.7);
  letter-spacing: 0.04em; flex-shrink: 0; width: 18px; text-align: right;
}
.ppt-open-btn {
  display: inline-flex; align-items: center; gap: 10px;
  margin-top: 2px; padding: 11px 20px; border-radius: 9px;
  font-size: 13px; font-weight: 600;
  color: rgba(255,255,255,0.25); background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08); cursor: not-allowed; width: fit-content;
  position: relative;
}
.ppt-open-soon {
  font-size: 11px; font-weight: 500; color: rgba(255,255,255,0.15);
  background: rgba(255,255,255,0.06); padding: 2px 8px; border-radius: 999px;
}

/* ═══════════════════════════════════════════════════════
   WORKSHEET CARD (full-bleed cinematic)
═══════════════════════════════════════════════════════ */
.ws-card {
  position: relative; width: 100%; height: 100%;
  overflow: hidden;
}
.ws-card-bg {
  position: absolute; inset: 0;
  background: var(--ws-img) center / cover no-repeat;
  transform: scale(1.04); transition: transform 7s ease;
}
.ws-card:hover .ws-card-bg { transform: scale(1.08); }
.ws-card-gradient {
  position: absolute; inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(8,12,21,0.08) 0%,
    rgba(8,12,21,0.3)  30%,
    rgba(8,12,21,0.75) 62%,
    rgba(8,12,21,0.97) 100%
  );
}
.ws-card-info {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 40px 52px 44px;
  display: flex; flex-direction: column; gap: 14px;
}
.ws-card-meta { display: flex; align-items: center; gap: 12px; }
.ws-card-label {
  font-size: 11px; font-weight: 800; letter-spacing: 0.16em;
  text-transform: uppercase; color: rgba(255,255,255,0.45);
}
.ws-card-title {
  font-size: clamp(30px, 5vw, 58px); font-weight: 900;
  letter-spacing: -0.04em; color: #fff; margin: 0; line-height: 1.02;
  text-shadow: 0 4px 28px rgba(0,0,0,0.5);
}
.ws-tier-badge {
  font-size: 10px; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase;
  padding: 4px 12px; border-radius: 999px; flex-shrink: 0;
}
.ws-tier-badge.bronze { background: rgba(205,127,50,0.2); color: #e8a96e; border: 1px solid rgba(205,127,50,0.35); }
.ws-tier-badge.silver { background: rgba(192,192,192,0.15); color: #d6d6d6; border: 1px solid rgba(192,192,192,0.3); }
.ws-tier-badge.gold   { background: rgba(255,211,77,0.15); color: #ffe082; border: 1px solid rgba(255,211,77,0.3); }
.ws-open-btn {
  display: inline-flex; align-items: center; gap: 12px; margin-top: 4px;
  padding: 15px 32px; background: linear-gradient(135deg, #9333ea, #7c3aed);
  color: #fff; border-radius: 12px; font-size: 15px; font-weight: 700;
  text-decoration: none; width: fit-content;
  transition: opacity 0.15s, transform 0.15s, gap 0.2s;
  box-shadow: 0 6px 28px rgba(147,51,234,0.55);
}
.ws-open-btn:hover { opacity: 0.9; transform: translateY(-2px); gap: 16px; text-decoration: none; }

/* ═══════════════════════════════════════════════════════
   BARE DOC HERO (full-bleed, no worksheet page)
═══════════════════════════════════════════════════════ */
.doc-hero {
  position: relative; width: 100%; height: 100%; overflow: hidden;
  background: linear-gradient(135deg, rgba(20,184,166,0.14) 0%, rgba(8,12,21,1) 55%);
  border-top: 2px solid rgba(20,184,166,0.25);
  display: flex; align-items: center; justify-content: center;
}
.doc-hero-watermark {
  position: absolute; top: 50%; left: 58%;
  transform: translate(-50%,-50%);
  opacity: 0.04; color: #14b8a6; pointer-events: none;
}
.doc-hero-content {
  position: relative; z-index: 1;
  display: flex; flex-direction: column; align-items: flex-start;
  gap: 16px; max-width: 560px; width: 100%; padding: 0 52px;
}
.doc-hero-icon {
  width: 68px; height: 68px; border-radius: 16px;
  background: rgba(20,184,166,0.12); color: #2dd4bf;
  border: 1px solid rgba(20,184,166,0.25);
  display: flex; align-items: center; justify-content: center;
}
.doc-hero-label {
  font-size: 11px; font-weight: 800; letter-spacing: 0.14em;
  text-transform: uppercase; color: rgba(45,212,191,0.6); margin: 0;
}
.doc-hero-title {
  font-size: clamp(28px, 4vw, 48px); font-weight: 900;
  letter-spacing: -0.04em; color: #fff; margin: 0; line-height: 1.05;
}
.doc-hero-desc { font-size: 14px; color: rgba(255,255,255,0.38); margin: 0; line-height: 1.6; }

/* ═══════════════════════════════════════════════════════
   HTML HERO (homework / assessment / welcome — full-bleed)
═══════════════════════════════════════════════════════ */
.html-hero {
  position: relative; width: 100%; height: 100%; overflow: hidden;
  display: flex; align-items: center; justify-content: center;
}
.html-homework   {
  background: linear-gradient(135deg, rgba(99,102,241,0.22) 0%, rgba(8,12,21,1) 58%);
  border-top: 2px solid rgba(99,102,241,0.3);
}
.html-assessment {
  background: linear-gradient(135deg, rgba(245,158,11,0.22) 0%, rgba(8,12,21,1) 58%);
  border-top: 2px solid rgba(245,158,11,0.3);
}
.html-welcome {
  background: linear-gradient(135deg, rgba(59,130,246,0.22) 0%, rgba(8,12,21,1) 58%);
  border-top: 2px solid rgba(59,130,246,0.3);
}
.html-hero-watermark {
  position: absolute; top: 50%; left: 58%;
  transform: translate(-50%,-50%);
  opacity: 0.04; pointer-events: none;
}
.html-homework   .html-hero-watermark { color: #6366f1; }
.html-assessment .html-hero-watermark { color: #f59e0b; }
.html-welcome    .html-hero-watermark { color: #3b82f6; }

.html-hero-content {
  position: relative; z-index: 1;
  display: flex; flex-direction: column; align-items: flex-start;
  gap: 18px; max-width: 560px; width: 100%; padding: 0 52px;
}
.html-hero-icon {
  width: 68px; height: 68px; border-radius: 16px;
  display: flex; align-items: center; justify-content: center;
}
.html-homework   .html-hero-icon { background: rgba(99,102,241,0.14); color: #a5b4fc; border: 1px solid rgba(99,102,241,0.28); }
.html-assessment .html-hero-icon { background: rgba(245,158,11,0.14); color: #fcd34d; border: 1px solid rgba(245,158,11,0.28); }
.html-welcome    .html-hero-icon { background: rgba(59,130,246,0.14); color: #93c5fd; border: 1px solid rgba(59,130,246,0.28); }

.html-hero-label {
  font-size: 11px; font-weight: 800; letter-spacing: 0.14em;
  text-transform: uppercase; margin: 0;
}
.html-homework   .html-hero-label { color: rgba(165,180,252,0.65); }
.html-assessment .html-hero-label { color: rgba(252,211,77,0.65); }
.html-welcome    .html-hero-label { color: rgba(147,197,253,0.65); }

.html-hero-title {
  font-size: clamp(28px, 4vw, 52px); font-weight: 900;
