═══════════════════════════════════════════════════════ */
.sw-viewport { flex: 1; overflow: hidden; position: relative; }
.sw-slide {
  position: absolute; inset: 0;
  display: flex; flex-direction: column;
  overflow: hidden; /* clip glow orbs and watermarks that extend beyond bounds */
}
.sw-slide[hidden] { display: none; }

/* ── Ambient glow orbs (RGB set per slide type) ── */
.type-opening    { --gc: 147,51,234; }
.type-youtube    { --gc: 239,68,68; }
.type-pdf        { --gc: 249,115,22; }
.type-powerpoint { --gc: 234,88,12; }
.type-document   { --gc: 20,184,166; }
.type-homework   { --gc: 99,102,241; }
.type-assessment { --gc: 245,158,11; }
.type-welcome    { --gc: 59,130,246; }
.type-section    { --gc: 234,179,8; }
