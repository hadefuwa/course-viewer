---
Astro.response.headers.set('Cache-Control', 'no-store');
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const adminSecret = import.meta.env.ADMIN_SECRET as string;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Admin — Course Manager</title>
</head>
<body>

<meta name="admin-secret" content={adminSecret} />

<!-- ═══════════════════════════════════════════════
     LOGIN SCREEN
═══════════════════════════════════════════════ -->
<div id="login-screen">
  <div class="login-bg"></div>
  <div class="login-wrap">
    <div class="login-card">
      <div class="login-logo">M</div>
      <h1 class="login-title">Course Admin</h1>
      <p class="login-sub">Matrix TSL · Course Admin</p>
      <div class="login-field">
        <label class="login-label" for="pin-input">Admin PIN</label>
        <input
          id="pin-input"
          type="password"
          maxlength="20"
          placeholder="••••"
          autocomplete="off"
          class="pin-input"
        />
        <span class="pin-hint">Contact your administrator for the PIN</span>
      </div>
      <button id="pin-submit" class="login-btn">Enter Admin Panel →</button>
      <div id="pin-error" class="pin-error" hidden>
        <span>✕</span> Incorrect PIN — try again
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════
     ADMIN APP
═══════════════════════════════════════════════ -->
<div id="admin-app" hidden>

  <!-- Top Header -->
  <header class="app-header">
    <div class="app-brand">
      <span class="app-logo">M</span>
      <span class="app-title">Course Admin</span>
      <span id="app-badge" class="app-badge" hidden></span>
    </div>
    <div class="app-actions">
      <span class="live-indicator">
        <span class="live-dot"></span>
        Live
      </span>
      <button id="back-to-courses-btn" class="btn-ghost" hidden>← All Courses</button>
      <a href={`${base}/admin/guide`} target="_blank" class="btn-ghost btn-guide">Content Guide ↗</a>
      <a href={`${base}/`} class="btn-ghost">← Back to Site</a>
      <button id="logout-btn" class="btn-ghost btn-logout">Logout</button>
    </div>
  </header>

  <!-- Courses List View -->
  <div id="courses-view" class="courses-view" hidden>
    <div class="courses-header">
      <div>
        <h2 class="courses-title">Courses</h2>
        <p class="courses-sub">Select a course to edit, or create a new one.</p>
      </div>
      <button id="new-course-btn" class="btn-primary">＋ New Course</button>
    </div>
    <div id="courses-grid" class="courses-grid"></div>
  </div>

  <!-- Editor View -->
  <div id="editor-view" hidden>
    <!-- Body: Sidebar + Main -->
    <div class="app-body">
      <aside class="sidebar">
        <div class="sidebar-head">COURSE CONTENT</div>
        <nav id="nav-list"></nav>
      </aside>
      <main class="main-panel">
        <div id="empty-state" class="empty-state">
          <div class="empty-glyph">✦</div>
          <p class="empty-msg">Select a section from the sidebar to begin editing</p>
          <p class="empty-sub" id="empty-sub-text">Loading…</p>
        </div>
        <div id="editor-panel" hidden></div>
      </main>
    </div>
    <!-- Sticky Save Bar -->
    <div class="save-bar">
      <div class="save-left">
        <span id="unsaved-dot" class="unsaved-dot saved"></span>
        <span id="unsaved-label" class="unsaved-label">All changes saved</span>
      </div>
      <button id="save-btn" class="btn-save">
        <span id="save-btn-text">Save Changes</span>
        <span id="save-spinner" class="spinner" hidden></span>
      </button>
    </div>
  </div>

  <!-- New Course Modal -->
  <div id="new-course-modal" class="modal-backdrop" hidden>
    <div class="modal-card">
      <div class="modal-head">
        <h3 class="modal-title">New Course</h3>
        <button class="modal-close" id="modal-close-btn">✕</button>
      </div>
      <div class="modal-body">
        <div class="modal-field">
          <label class="field-label">Course Code <span class="field-req">*</span></label>
          <input id="nc-code" class="field-input" placeholder="e.g. cp4808" />
          <span class="field-hint">Unique key — lowercase, no spaces</span>
        </div>
        <div class="modal-field">
          <label class="field-label">Course Title <span class="field-req">*</span></label>
          <input id="nc-title" class="field-input" placeholder="e.g. Introduction to Robotics" />
        </div>
        <div class="modal-field">
          <label class="field-label">Unit</label>
          <input id="nc-unit" class="field-input" placeholder="e.g. BTEC Unit 8 — Mechanical Principles" />
        </div>
        <div class="modal-row">
          <div class="modal-field">
            <label class="field-label">Hours</label>
            <input id="nc-hours" class="field-input" type="number" value="60" min="1" />
          </div>
          <div class="modal-field">
            <label class="field-label">No. of Worksheets</label>
            <input id="nc-worksheets" class="field-input" type="number" value="12" min="1" max="50" />
          </div>
        </div>
        <div class="modal-field">
          <label class="field-label">Duplicate from existing course</label>
          <select id="nc-duplicate" class="field-input">
            <option value="">— Start blank —</option>
          </select>
          <span class="field-hint">Copies all content and sections; you can then edit each worksheet</span>
        </div>
      </div>
      <div class="modal-footer">
        <button id="nc-cancel" class="btn-ghost">Cancel</button>
        <button id="nc-create" class="btn-primary">Create Course</button>
      </div>
    </div>
  </div>

</div>

<!-- Toast Notification -->
<div id="toast" class="toast" hidden></div>


<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

  /* ── Reset ── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  [hidden] { display: none !important; }

  :root {
    --bg:         #080e1a;
    --bg-1:       #0d1526;
    --bg-2:       #111d33;
    --bg-3:       #19274a;
    --surface:    rgba(255,255,255,0.04);
    --surface-hi: rgba(255,255,255,0.07);
    --border:     rgba(255,255,255,0.08);
    --border-hi:  rgba(255,255,255,0.14);
    --text:       #f0f4ff;
    --text-2:     #8b9ab8;
    --text-3:     #4a5a7a;
    --accent:     #ff6b1f;
    --accent-glow:rgba(255,107,31,0.2);
    --cyan:       #4dd0ff;
    --cyan-glow:  rgba(77,208,255,0.15);
    --purple:     #a78bfa;
    --purple-glow:rgba(167,139,250,0.15);
    --red:        #f87171;
    --red-glow:   rgba(248,113,113,0.15);
    --green:      #34d399;
    --danger:     #f87171;
    --gold:       #ffd34d;
    --silver:     #c0c0c0;
    --bronze:     #cd7f32;
    --font:       'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif;
    --mono:       ui-monospace, "SF Mono", Menlo, monospace;
    --shadow-sm:  0 1px 3px rgba(0,0,0,0.4);
    --shadow-md:  0 4px 16px rgba(0,0,0,0.5);
    --shadow-lg:  0 12px 40px rgba(0,0,0,0.6);
  }

  html, body {
    height: 100%;
    font-family: var(--font);
    background: var(--bg);
    color: var(--text);
    -webkit-font-smoothing: antialiased;
    line-height: 1.5;
    font-size: 14px;
  }

  /* ── LOGIN SCREEN ── */
  #login-screen {
    position: fixed; inset: 0; z-index: 100;
    display: flex; align-items: center; justify-content: center;
  }

  .login-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(900px 600px at 60% 20%, rgba(255,107,31,0.15), transparent 60%),
      radial-gradient(700px 500px at 10% 80%, rgba(77,208,255,0.10), transparent 60%),
      var(--bg);
  }

  .login-wrap {
    position: relative; z-index: 1;
    width: 100%; max-width: 420px;
    padding: 24px;
  }

  .login-card {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 48px 40px 40px;
    box-shadow: 0 32px 80px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,107,31,0.08);
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    animation: fadeUp 0.4s ease both;
  }

  @keyframes fadeUp {
    from { opacity:0; transform: translateY(16px); }
    to   { opacity:1; transform: translateY(0); }
  }

  .login-logo {
    width: 56px; height: 56px;
    background: linear-gradient(135deg, #ff6b1f, #ff9554);
    border-radius: 14px;
    display: grid; place-items: center;
    font-size: 26px; font-weight: 900; color: #1b0d00;
    margin-bottom: 8px;
    box-shadow: 0 8px 24px rgba(255,107,31,0.35);
  }

  .login-title {
    font-size: 22px; font-weight: 700; letter-spacing: -0.3px;
    color: var(--text);
  }

  .login-sub {
    font-size: 13px; color: var(--text-dim);
    margin-bottom: 24px;
  }

  .login-field {
    width: 100%; display: flex; flex-direction: column; gap: 6px;
    margin-bottom: 8px;
  }

  .login-label {
    font-size: 11px; font-weight: 600; letter-spacing: 0.8px;
    text-transform: uppercase; color: var(--text-dim);
  }

  .pin-input {
    width: 100%; padding: 12px 16px;
    background: var(--bg-input); border: 1px solid var(--border);
    border-radius: 10px; color: var(--text);
    font-size: 16px; letter-spacing: 2px; text-align: center;
    font-family: var(--font-mono);
    transition: border-color 0.15s, box-shadow 0.15s;
    outline: none;
  }
  .pin-input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(255,107,31,0.18);
  }

  .pin-hint {
    font-size: 11px; color: var(--text-faint);
    text-align: center;
  }

  .login-btn {
    width: 100%; padding: 13px;
    background: linear-gradient(135deg, var(--accent), #ff9554);
    border: none; border-radius: 10px;
    color: #fff; font-size: 14px; font-weight: 700;
    cursor: pointer; margin-top: 8px;
    transition: opacity 0.15s, transform 0.1s;
    letter-spacing: 0.2px;
  }
  .login-btn:hover { opacity: 0.9; transform: translateY(-1px); }
  .login-btn:active { transform: translateY(0); }

  .pin-error {
    font-size: 13px; color: var(--danger);
    display: flex; align-items: center; gap: 6px;
    margin-top: 4px;
    animation: shake 0.3s ease;
  }

  @keyframes shake {
    0%,100% { transform: translateX(0); }
    25%      { transform: translateX(-6px); }
    75%      { transform: translateX(6px); }
  }

  /* ── APP SHELL ── */
  #admin-app { display: flex; flex-direction: column; height: 100vh; overflow: hidden; }
  #courses-view, #editor-view { flex: 1; display: flex; flex-direction: column; overflow: hidden; }

  .app-header {
    flex-shrink: 0; height: 52px; padding: 0 20px;
    display: flex; align-items: center; justify-content: space-between;
    background: rgba(8,14,26,0.92); backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border); z-index: 10;
  }
  .app-brand { display: flex; align-items: center; gap: 10px; }
  .app-logo {
    width: 28px; height: 28px; border-radius: 7px;
    background: linear-gradient(135deg, var(--accent), #ff9554);
    display: grid; place-items: center;
    font-size: 13px; font-weight: 900; color: #1b0d00;
    box-shadow: 0 2px 8px var(--accent-glow);
  }
  .app-title { font-size: 14px; font-weight: 600; color: var(--text); letter-spacing: -0.2px; }
  .app-badge {
    font-size: 10px; font-weight: 600; padding: 2px 7px;
    background: rgba(255,107,31,0.12); border: 1px solid rgba(255,107,31,0.25);
    border-radius: 20px; color: var(--accent); font-family: var(--mono);
  }
  .app-actions { display: flex; align-items: center; gap: 8px; }
  .live-indicator { display: flex; align-items: center; gap: 5px; font-size: 12px; color: var(--green); font-weight: 600; }
  .live-dot {
    width: 6px; height: 6px; background: var(--green); border-radius: 50%;
    box-shadow: 0 0 6px var(--green); animation: pulse 2s infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
  .btn-ghost {
    padding: 5px 12px; background: var(--surface); border: 1px solid var(--border);
    border-radius: 7px; color: var(--text-2); font-size: 12px; font-weight: 500;
    cursor: pointer; text-decoration: none; font-family: var(--font);
    transition: all 0.15s;
  }
  .btn-ghost:hover { background: var(--surface-hi); border-color: var(--border-hi); color: var(--text); text-decoration: none; }
  .btn-logout:hover { border-color: rgba(248,113,113,0.4); color: var(--danger); background: rgba(248,113,113,0.06); }

  /* ── BODY LAYOUT ── */
  .app-body { flex: 1; display: flex; overflow: hidden; }

  /* ── SIDEBAR ── */
  .sidebar {
    width: 256px; flex-shrink: 0;
    background: var(--bg-1);
    border-right: 1px solid var(--border);
    overflow-y: auto; overflow-x: hidden;
    padding-bottom: 80px;
  }
  .sidebar::-webkit-scrollbar { width: 3px; }
  .sidebar::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
  .sidebar-head {
    padding: 14px 16px 6px;
    font-size: 10px; font-weight: 700; letter-spacing: 1.2px;
    color: var(--text-3); text-transform: uppercase; font-family: var(--mono);
  }
  .nav-group-label {
    padding: 10px 16px 3px;
    font-size: 10px; font-weight: 700; letter-spacing: 1px;
    text-transform: uppercase; font-family: var(--mono); opacity: 0.85;
  }
  .nav-item {
    display: flex; align-items: center; gap: 8px;
    width: 100%; padding: 7px 16px 7px 14px;
    background: transparent; border: none; border-left: 2px solid transparent;
    color: var(--text-2); font-size: 13px; text-align: left; cursor: pointer;
    transition: all 0.1s; font-family: var(--font); min-width: 0;
  }
  .nav-item:hover { background: var(--surface); color: var(--text); }
  .nav-item.active { background: rgba(255,107,31,0.1); border-left-color: var(--accent); color: var(--text); }
  .nav-icon { font-size: 13px; flex-shrink: 0; width: 18px; text-align: center; }
  .nav-label { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .tier-pill {
    font-size: 9px; font-weight: 700; padding: 1px 6px; border-radius: 20px;
    border: 1px solid; text-transform: uppercase; font-family: var(--mono); flex-shrink: 0; opacity: 0.65;
  }
  .nav-divider { height: 1px; background: var(--border); margin: 6px 14px; }

  /* ── MAIN PANEL ── */
  .main-panel { flex: 1; overflow-y: auto; overflow-x: hidden; background: var(--bg); }
  .main-panel::-webkit-scrollbar { width: 4px; }
  .main-panel::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  /* Empty state */
  .empty-state {
    display: flex; flex-direction: column; align-items: center;
    justify-content: center; height: 100%; min-height: 400px;
    gap: 10px; padding: 40px; text-align: center;
  }
  .empty-glyph { font-size: 36px; color: var(--text-3); margin-bottom: 4px; }
  .empty-msg { font-size: 15px; color: var(--text-2); font-weight: 500; }
  .empty-sub { font-size: 12px; color: var(--text-3); }

  /* ── EDITOR HEADER ── */
  .editor-header {
    padding: 24px 32px 20px;
    background: var(--bg-1);
    border-bottom: 1px solid var(--border);
    position: sticky; top: 0; z-index: 5;
  }
  .editor-breadcrumb {
    font-size: 11px; color: var(--text-3); font-family: var(--mono);
    margin-bottom: 8px; display: flex; align-items: center; gap: 5px;
  }
  .editor-breadcrumb span { color: var(--text-2); }
  .editor-section-title {
    font-size: 22px; font-weight: 700; color: var(--text);
    letter-spacing: -0.5px; margin-bottom: 18px;
    display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
  }
  .editor-kind-badge {
    font-size: 10px; font-weight: 700; letter-spacing: 1px; padding: 3px 8px;
    border-radius: 5px; background: rgba(77,208,255,0.1);
    border: 1px solid rgba(77,208,255,0.2); color: var(--cyan); font-family: var(--mono);
  }
  .editor-tier-badge {
    font-size: 10px; font-weight: 700; padding: 3px 8px; border-radius: 5px;
    border: 1px solid currentColor; font-family: var(--mono);
  }
  .editor-fields-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .field-group { display: flex; flex-direction: column; gap: 5px; }
  .field-label {
    font-size: 10px; font-weight: 600; letter-spacing: 0.8px;
    text-transform: uppercase; color: var(--text-3); font-family: var(--mono);
  }
  .field-input {
    padding: 9px 12px; background: var(--bg-2); border: 1px solid var(--border);
    border-radius: 8px; color: var(--text); font-size: 13px; font-family: var(--font);
    outline: none; width: 100%; transition: all 0.15s;
  }
  .field-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-glow); }

  /* ── GROUPS ── */
  .groups-container {
    padding: 20px 24px 8px; display: flex; flex-direction: column; gap: 8px;
  }

  .group-card {
    border-radius: 12px; overflow: hidden;
    border: 1px solid var(--border);
    background: var(--bg-1);
    box-shadow: var(--shadow-sm);
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .group-card:hover { border-color: var(--border-hi); box-shadow: var(--shadow-md); }

  .group-header {
    display: flex; align-items: center; gap: 8px; padding: 10px 14px;
    background: var(--bg-2); border-bottom: 1px solid var(--border);
    cursor: pointer; user-select: none;
  }
  .group-toggle {
    width: 20px; height: 20px; border-radius: 5px;
    background: var(--surface); border: 1px solid var(--border);
    color: var(--text-2); font-size: 10px; cursor: pointer;
    display: grid; place-items: center; flex-shrink: 0; transition: all 0.12s;
  }
  .group-toggle:hover { background: var(--surface-hi); color: var(--text); }
  .group-heading-input {
    flex: 1; background: transparent; border: none;
    color: var(--text); font-size: 13px; font-weight: 600;
    font-family: var(--font); outline: none; padding: 3px 6px; border-radius: 5px;
    transition: background 0.12s;
  }
  .group-heading-input:hover { background: var(--surface); }
  .group-heading-input:focus { background: var(--surface-hi); }
  .group-block-count {
    font-size: 10px; color: var(--text-3); font-family: var(--mono);
    background: var(--surface); padding: 2px 7px; border-radius: 10px;
    border: 1px solid var(--border); flex-shrink: 0;
  }
  .btn-delete-group {
    background: none; border: none; color: var(--text-3); font-size: 13px;
    cursor: pointer; padding: 3px 6px; border-radius: 5px; line-height: 1;
    transition: all 0.12s; flex-shrink: 0;
  }
  .btn-delete-group:hover { background: rgba(248,113,113,0.1); color: var(--danger); }

  .group-body { background: var(--bg); }
  .group-body.collapsed { display: none; }

  /* ── BLOCK CARDS ── */
  .blocks-list {
    display: flex; flex-direction: column; gap: 1px;
    padding: 10px; background: rgba(0,0,0,0.2);
  }

  .block-card {
    border-radius: 10px; overflow: hidden;
    border: 1px solid var(--border);
    background: var(--bg-1);
    margin-bottom: 6px;
    transition: border-color 0.15s, box-shadow 0.15s;
    box-shadow: var(--shadow-sm);
  }
  .block-card:last-child { margin-bottom: 0; }
  .block-card:hover { box-shadow: var(--shadow-md); }

  /* Left accent stripe instead of top border — more editorial */
  .block-card[data-type="p"]       { border-left: 3px solid var(--cyan); }
  .block-card[data-type="image"]   { border-left: 3px solid var(--purple); }
  .block-card[data-type="youtube"] { border-left: 3px solid var(--red); }

  .block-bar {
    display: flex; align-items: center; gap: 8px; padding: 6px 12px 6px 10px;
    background: var(--bg-2); border-bottom: 1px solid var(--border);
  }
  .block-type-chip {
    font-size: 10px; font-weight: 700; letter-spacing: 0.5px;
    text-transform: uppercase; font-family: var(--mono);
    padding: 2px 8px; border-radius: 4px; flex-shrink: 0;
  }
  .block-card[data-type="p"]       .block-type-chip { color: var(--cyan);   background: var(--cyan-glow);   }
  .block-card[data-type="image"]   .block-type-chip { color: var(--purple); background: var(--purple-glow); }
  .block-card[data-type="youtube"] .block-type-chip { color: var(--red);    background: var(--red-glow);    }

  .block-bar-spacer { flex: 1; }
  .block-tools { display: flex; align-items: center; gap: 2px; }

  .btn-tool {
    width: 26px; height: 24px; background: transparent;
    border: 1px solid transparent; border-radius: 5px;
    color: var(--text-3); font-size: 12px; cursor: pointer;
    display: grid; place-items: center; transition: all 0.12s;
  }
  .btn-tool:hover:not(:disabled) { background: var(--surface-hi); border-color: var(--border); color: var(--text); }
  .btn-tool:disabled { opacity: 0.2; cursor: not-allowed; }
  .btn-tool-del:hover:not(:disabled) { background: rgba(248,113,113,0.1); border-color: rgba(248,113,113,0.2); color: var(--danger); }

  .block-content { padding: 12px 14px; background: var(--bg-1); }

  /* Transparent textarea that feels embedded in the card */
  .block-textarea {
    width: 100%; padding: 0; background: transparent; border: none;
    color: var(--text); font-size: 13px; line-height: 1.7;
    resize: none; min-height: 52px; font-family: var(--font); outline: none;
  }
  .block-textarea::placeholder { color: var(--text-3); }

  .block-image-pair { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .block-field-wrap { display: flex; flex-direction: column; gap: 4px; }
  .block-field-label { font-size: 10px; color: var(--text-3); font-family: var(--mono); letter-spacing: 0.4px; text-transform: uppercase; }
  .block-input {
    width: 100%; padding: 7px 10px;
    background: var(--bg-2); border: 1px solid var(--border);
    border-radius: 7px; color: var(--text); font-size: 13px;
    font-family: var(--font); outline: none; transition: all 0.15s;
  }
  .block-card[data-type="p"]       .block-input:focus { border-color: var(--cyan);   box-shadow: 0 0 0 3px var(--cyan-glow);   }
  .block-card[data-type="image"]   .block-input:focus { border-color: var(--purple); box-shadow: 0 0 0 3px var(--purple-glow); }
  .block-card[data-type="youtube"] .block-input:focus { border-color: var(--red);    box-shadow: 0 0 0 3px var(--red-glow);    }

  .yt-row { display: flex; align-items: center; gap: 8px; }
  .yt-preview-link {
    font-size: 11px; color: var(--red); white-space: nowrap;
    text-decoration: none; padding: 6px 11px; border-radius: 7px;
    background: var(--red-glow); border: 1px solid rgba(248,113,113,0.2);
    font-weight: 600; transition: all 0.12s; flex-shrink: 0;
  }
  .yt-preview-link:hover { background: rgba(248,113,113,0.2); text-decoration: none; }

  /* Add block */
  .add-block-area {
    padding: 8px 10px; background: var(--bg);
    border-top: 1px solid var(--border); position: relative;
  }
  .btn-add-block {
    padding: 6px 12px; background: transparent;
    border: 1px dashed var(--border); border-radius: 7px;
    color: var(--text-3); font-size: 12px; font-weight: 500;
    cursor: pointer; font-family: var(--font);
    transition: all 0.15s; display: inline-flex; align-items: center; gap: 5px;
  }
  .btn-add-block:hover { border-color: var(--cyan); color: var(--cyan); background: var(--cyan-glow); }

  .dropdown-menu {
    position: absolute; left: 10px; bottom: calc(100% + 6px);
    background: var(--bg-2); border: 1px solid var(--border-hi);
    border-radius: 10px; padding: 5px; min-width: 160px; z-index: 20;
    box-shadow: var(--shadow-lg), 0 0 0 1px rgba(255,255,255,0.04);
    animation: dropIn 0.12s ease;
  }
  @keyframes dropIn { from{opacity:0;transform:translateY(6px)} to{opacity:1;transform:translateY(0)} }
  .dropdown-item {
    display: flex; align-items: center; gap: 10px;
    width: 100%; padding: 8px 10px; background: none; border: none;
    color: var(--text-2); font-size: 13px; cursor: pointer; border-radius: 6px;
    text-align: left; font-family: var(--font); transition: all 0.1s;
  }
  .dropdown-item:hover { background: var(--surface-hi); color: var(--text); }
  .dropdown-item .di-icon {
    width: 24px; height: 24px; border-radius: 5px;
    display: grid; place-items: center; font-size: 12px; flex-shrink: 0;
  }
  .dropdown-item:nth-child(1) .di-icon { background: var(--cyan-glow); }
  .dropdown-item:nth-child(2) .di-icon { background: var(--purple-glow); }
  .dropdown-item:nth-child(3) .di-icon { background: var(--red-glow); }

  /* Add section */
  .add-section-area { padding: 14px 24px 20px; }
  .btn-add-section {
    width: 100%; padding: 9px; background: transparent;
    border: 1px dashed var(--border); border-radius: 9px;
    color: var(--text-3); font-size: 13px; font-weight: 500;
    cursor: pointer; font-family: var(--font);
    display: flex; align-items: center; justify-content: center; gap: 6px;
    transition: all 0.15s;
  }
  .btn-add-section:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-glow); }

  /* ── SAVE BAR ── */
  .save-bar {
    position: fixed; bottom: 0; left: 256px; right: 0;
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 28px;
    background: rgba(8,14,26,0.96); backdrop-filter: blur(16px);
    border-top: 1px solid var(--border); z-index: 10;
  }
  .save-left { display: flex; align-items: center; gap: 8px; }
  .unsaved-dot {
    width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0;
    background: var(--accent); transition: background 0.3s;
  }
  .unsaved-dot.saved { background: var(--green); box-shadow: 0 0 6px var(--green); }
  .unsaved-label { font-size: 12px; color: var(--text-2); }
  .btn-save {
    padding: 8px 22px;
    background: linear-gradient(135deg, var(--accent) 0%, #ff9554 100%);
    border: none; border-radius: 8px; color: #fff;
    font-size: 13px; font-weight: 600; font-family: var(--font);
    cursor: pointer; display: flex; align-items: center; gap: 8px;
    min-width: 130px; justify-content: center;
    box-shadow: 0 2px 12px var(--accent-glow);
    transition: all 0.15s;
  }
  .btn-save:hover { transform: translateY(-1px); box-shadow: 0 4px 20px var(--accent-glow); }
  .btn-save:active { transform: none; }
  .btn-save:disabled { opacity: 0.5; cursor: not-allowed; transform: none; box-shadow: none; }
  .btn-save.success { background: linear-gradient(135deg, #059669, var(--green)); box-shadow: 0 2px 12px rgba(52,211,153,0.3); }

  .spinner {
    width: 13px; height: 13px;
    border: 2px solid rgba(255,255,255,0.3); border-top-color: #fff;
    border-radius: 50%; animation: spin 0.6s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ── TOAST ── */
  .toast {
    position: fixed; top: 64px; right: 16px; z-index: 200;
    padding: 11px 16px; border-radius: 9px; font-size: 13px; font-weight: 600;
    display: flex; align-items: center; gap: 8px;
    box-shadow: var(--shadow-lg); animation: slideIn 0.2s ease; max-width: 300px;
    font-family: var(--font);
  }
  @keyframes slideIn { from{opacity:0;transform:translateX(16px)} to{opacity:1;transform:translateX(0)} }
  .toast.success { background: #065f46; color: #6ee7b7; border: 1px solid rgba(52,211,153,0.3); }
  .toast.error   { background: #7f1d1d; color: #fca5a5; border: 1px solid rgba(248,113,113,0.3); }

  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  /* ── COURSES VIEW ── */
  .courses-view {
    flex: 1; overflow-y: auto; padding: 32px 40px 80px;
  }
  .courses-header {
    display: flex; align-items: flex-start; justify-content: space-between;
    margin-bottom: 28px; gap: 16px; flex-wrap: wrap;
  }
  .courses-title { font-size: 22px; font-weight: 700; letter-spacing: -0.4px; color: var(--text); }
  .courses-sub { font-size: 13px; color: var(--text-2); margin-top: 4px; }

  .btn-primary {
    padding: 9px 18px;
    background: linear-gradient(135deg, var(--accent), #ff9554);
    border: none; border-radius: 9px; color: #fff;
    font-size: 13px; font-weight: 600; font-family: var(--font);
    cursor: pointer; white-space: nowrap;
    box-shadow: 0 2px 12px var(--accent-glow);
    transition: all 0.15s;
  }
  .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 4px 20px var(--accent-glow); }
  .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

  .courses-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
  }

  .course-card {
    background: var(--bg-1); border: 1px solid var(--border); border-radius: 14px;
    padding: 20px 20px 16px; cursor: pointer;
    transition: all 0.15s; position: relative;
    display: flex; flex-direction: column; gap: 10px;
  }
  .course-card:hover { border-color: var(--accent); box-shadow: 0 0 0 1px var(--accent), var(--shadow-md); }

  .course-card-code {
    font-size: 10px; font-weight: 700; letter-spacing: 1px;
    font-family: var(--mono); color: var(--accent);
    background: var(--accent-glow); border: 1px solid rgba(255,107,31,0.2);
    padding: 2px 8px; border-radius: 5px; width: fit-content;
  }
  .course-card-title { font-size: 15px; font-weight: 600; color: var(--text); line-height: 1.3; }
  .course-card-meta { font-size: 12px; color: var(--text-2); }
  .course-card-actions {
    display: flex; gap: 6px; margin-top: 4px;
    opacity: 0; transition: opacity 0.15s;
  }
  .course-card:hover .course-card-actions { opacity: 1; }
  .btn-card-action {
    font-size: 11px; font-weight: 600; padding: 5px 10px;
    border-radius: 6px; cursor: pointer; font-family: var(--font);
    border: 1px solid var(--border); background: var(--surface); color: var(--text-2);
    transition: all 0.12s;
  }
  .btn-card-action:hover { background: var(--surface-hi); color: var(--text); border-color: var(--border-hi); }
  .btn-card-action.primary { background: var(--accent-glow); border-color: rgba(255,107,31,0.3); color: var(--accent); }
  .btn-card-action.primary:hover { background: rgba(255,107,31,0.2); }

  .courses-empty {
    grid-column: 1/-1; text-align: center; padding: 60px 20px;
    color: var(--text-3); font-size: 14px;
  }

  /* ── MODAL ── */
  .modal-backdrop {
    position: fixed; inset: 0; z-index: 50;
    background: rgba(0,0,0,0.7); backdrop-filter: blur(4px);
    display: flex; align-items: center; justify-content: center; padding: 24px;
  }
  .modal-card {
    background: var(--bg-1); border: 1px solid var(--border-hi);
    border-radius: 16px; width: 100%; max-width: 520px;
    box-shadow: var(--shadow-lg); animation: fadeUp 0.2s ease;
  }
  .modal-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 24px 0;
  }
  .modal-title { font-size: 17px; font-weight: 700; color: var(--text); }
  .modal-close {
    background: none; border: none; color: var(--text-3);
    font-size: 14px; cursor: pointer; padding: 4px 8px; border-radius: 6px;
    transition: all 0.12s;
  }
  .modal-close:hover { background: var(--surface-hi); color: var(--text); }
  .modal-body { padding: 20px 24px; display: flex; flex-direction: column; gap: 14px; }
  .modal-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .modal-field { display: flex; flex-direction: column; gap: 5px; }
  .field-req { color: var(--accent); }
  .field-hint { font-size: 11px; color: var(--text-3); }
  .modal-footer {
    padding: 16px 24px 20px;
    display: flex; justify-content: flex-end; gap: 8px;
    border-top: 1px solid var(--border);
  }

  .settings-tier-row {
    display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
  }
  .settings-tier-sep { font-size: 12px; color: var(--text-3); }

  /* ── EDITOR VIEW ── */
  #editor-view { display: flex; flex-direction: column; flex: 1; overflow: hidden; }
  #editor-view .app-body { flex: 1; display: flex; overflow: hidden; }
</style>

<script>
  /* ══════════════════════════════════════════════
     CONSTANTS & STATE
  ══════════════════════════════════════════════ */
  const ADMIN_PIN     = 'Matrix123';
  const ADMIN_VERSION = 'v2-multicourse';

  let course         = null;
  let activeCourseKey = null;
  let activeIdx      = -1;
  let hasUnsaved     = false;
  let expandedGroups = new Set();
  let allCourses     = [];

  /* ══════════════════════════════════════════════
     BOOT
  ══════════════════════════════════════════════ */
  function boot() {
    if (sessionStorage.getItem('admin_ok') === '1' && sessionStorage.getItem('admin_version') === ADMIN_VERSION) {
      startApp();
    } else {
      sessionStorage.removeItem('admin_ok');
      document.getElementById('login-screen').removeAttribute('hidden');
      setTimeout(() => document.getElementById('pin-input').focus(), 100);
    }

    document.getElementById('pin-submit').addEventListener('click', handlePin);
    document.getElementById('pin-input').addEventListener('keydown', e => {
      if (e.key === 'Enter') handlePin();
    });
    document.getElementById('logout-btn').addEventListener('click', logout);
    document.getElementById('save-btn').addEventListener('click', handleSave);
    document.getElementById('back-to-courses-btn').addEventListener('click', showCoursesView);
    document.getElementById('new-course-btn').addEventListener('click', openNewCourseModal);
    document.getElementById('modal-close-btn').addEventListener('click', closeNewCourseModal);
    document.getElementById('nc-cancel').addEventListener('click', closeNewCourseModal);
    document.getElementById('nc-create').addEventListener('click', handleCreateCourse);
    document.getElementById('new-course-modal').addEventListener('click', e => {
      if (e.target === e.currentTarget) closeNewCourseModal();
    });
    document.addEventListener('click', e => {
      if (!e.target.closest('.add-block-area')) closeAllDropdowns();
    });
  }

  /* ══════════════════════════════════════════════
     AUTH
  ══════════════════════════════════════════════ */
  function handlePin() {
    const val = document.getElementById('pin-input').value.trim();
    const errEl = document.getElementById('pin-error');
    if (val === ADMIN_PIN) {
      sessionStorage.setItem('admin_ok', '1');
      sessionStorage.setItem('admin_version', ADMIN_VERSION);
      document.getElementById('login-screen').style.opacity = '0';
      document.getElementById('login-screen').style.transition = 'opacity 0.3s';
      setTimeout(() => {
        document.getElementById('login-screen').setAttribute('hidden', '');
        startApp();
      }, 300);
    } else {
      errEl.removeAttribute('hidden');
      document.getElementById('pin-input').value = '';
      document.getElementById('pin-input').focus();
      setTimeout(() => errEl.setAttribute('hidden', ''), 3000);
    }
  }

  function logout() {
    sessionStorage.removeItem('admin_ok');
    window.location.reload();
  }

  /* ══════════════════════════════════════════════
     APP START
  ══════════════════════════════════════════════ */
  async function startApp() {
    document.getElementById('admin-app').removeAttribute('hidden');
    await showCoursesView();
  }

  async function showCoursesView() {
    // Reset editor state
    activeCourseKey = null;
    course = null;
    activeIdx = -1;

    document.getElementById('courses-view').removeAttribute('hidden');
    document.getElementById('editor-view').setAttribute('hidden', '');
    document.getElementById('back-to-courses-btn').setAttribute('hidden', '');
    document.getElementById('app-badge').setAttribute('hidden', '');

    await loadCoursesList();
  }

  async function loadCoursesList() {
    const grid = document.getElementById('courses-grid');
    grid.innerHTML = '<p class="courses-empty">Loading…</p>';

    try {
      const res = await fetch('/api/admin/courses');
      allCourses = res.ok ? await res.json() : [];
    } catch {
      allCourses = [];
    }

    renderCoursesGrid();
    populateDuplicateSelect();
  }

  function renderCoursesGrid() {
    const grid = document.getElementById('courses-grid');
    grid.innerHTML = '';

    if (!allCourses.length) {
      grid.innerHTML = '<p class="courses-empty">No courses yet. Create your first one.</p>';
      return;
    }

    allCourses.forEach(row => {
      const card = document.createElement('div');
      card.className = 'course-card';
      const updated = row.updated_at ? new Date(row.updated_at).toLocaleDateString() : '';
      card.innerHTML = `
        <span class="course-card-code">${escHtml(row.key)}</span>
        <div class="course-card-title">${escHtml(row.title || row.code || row.key)}</div>
        <div class="course-card-meta">${escHtml(row.unit || '')}${row.hours ? ' · ' + row.hours + 'h' : ''}${updated ? ' · Updated ' + updated : ''}</div>
        <div class="course-card-actions">
          <button class="btn-card-action primary" data-key="${escHtml(row.key)}">Edit →</button>
          <button class="btn-card-action duplicate-btn" data-key="${escHtml(row.key)}">Duplicate</button>
        </div>
      `;
      card.addEventListener('click', e => {
        if (e.target.classList.contains('duplicate-btn')) {
          openNewCourseModal(row.key);
        } else {
          openCourseEditor(row.key);
        }
      });
      grid.appendChild(card);
    });
  }

  async function openCourseEditor(key) {
    activeCourseKey = key;
    course = null;
    activeIdx = -1;
    expandedGroups = new Set();

    document.getElementById('courses-view').setAttribute('hidden', '');
    document.getElementById('editor-view').removeAttribute('hidden');
    document.getElementById('back-to-courses-btn').removeAttribute('hidden');

    const badge = document.getElementById('app-badge');
    badge.textContent = key.toUpperCase();
    badge.removeAttribute('hidden');

    // Load from API
    try {
      const res = await fetch(`/api/admin/load?key=${encodeURIComponent(key)}`);
      course = res.ok ? await res.json() : null;
    } catch { course = null; }

    if (!course) {
      showToast('Failed to load course data', 'error');
      showCoursesView();
      return;
    }

    const ws = (course.sections || []).filter(s => s.kind === 'worksheet');
    document.getElementById('empty-sub-text').textContent =
      `${ws.length} worksheet${ws.length !== 1 ? 's' : ''} · ${key.toUpperCase()}`;

    renderSidebar();
    markSaved();
  }

  function persistCourse() {
    if (activeCourseKey) {
      localStorage.setItem('admin_draft_' + activeCourseKey, JSON.stringify(course));
    }
  }

  /* ══════════════════════════════════════════════
     NEW COURSE MODAL
  ══════════════════════════════════════════════ */
  function populateDuplicateSelect() {
    const sel = document.getElementById('nc-duplicate');
    sel.innerHTML = '<option value="">— Start blank —</option>';
    allCourses.forEach(row => {
      const opt = document.createElement('option');
      opt.value = row.key;
      opt.textContent = `${row.key} — ${row.title || row.code || ''}`;
      sel.appendChild(opt);
    });
  }

  function openNewCourseModal(prefillDuplicateKey = '') {
    document.getElementById('nc-code').value = '';
    document.getElementById('nc-title').value = '';
    document.getElementById('nc-unit').value = '';
    document.getElementById('nc-hours').value = '60';
    document.getElementById('nc-worksheets').value = '12';
    if (prefillDuplicateKey) {
      document.getElementById('nc-duplicate').value = prefillDuplicateKey;
    } else {
      document.getElementById('nc-duplicate').value = '';
    }
    document.getElementById('new-course-modal').removeAttribute('hidden');
    setTimeout(() => document.getElementById('nc-code').focus(), 50);
  }

  function closeNewCourseModal() {
    document.getElementById('new-course-modal').setAttribute('hidden', '');
  }

  async function handleCreateCourse() {
    const code       = document.getElementById('nc-code').value.trim().toLowerCase();
    const title      = document.getElementById('nc-title').value.trim();
    const unit       = document.getElementById('nc-unit').value.trim();
    const hours      = parseInt(document.getElementById('nc-hours').value) || 60;
    const numWs      = Math.min(50, Math.max(1, parseInt(document.getElementById('nc-worksheets').value) || 12));
    const dupKey     = document.getElementById('nc-duplicate').value;
    const secret     = document.querySelector('meta[name="admin-secret"]')?.getAttribute('content') ?? '';

    if (!code || !title) {
      showToast('Course code and title are required', 'error');
      return;
    }
    if (!/^[a-z0-9_-]+$/.test(code)) {
      showToast('Code must be lowercase letters, numbers, hyphens or underscores', 'error');
      return;
    }

    const createBtn = document.getElementById('nc-create');
    createBtn.disabled = true;
    createBtn.textContent = 'Creating…';

    let newData;

    if (dupKey) {
      // Duplicate existing course
      try {
        const res = await fetch(`/api/admin/load?key=${encodeURIComponent(dupKey)}`);
        if (!res.ok) throw new Error('Failed to load source course');
        newData = await res.json();
        newData.code  = code.toUpperCase();
        newData.title = title;
        if (unit)  newData.unit = unit;
        if (hours) newData.hours = hours;
      } catch (e) {
        showToast('Could not load source course: ' + e.message, 'error');
        createBtn.disabled = false;
        createBtn.textContent = 'Create Course';
        return;
      }
    } else {
      // Build blank course with N worksheets
      const tiers = [
        { name: 'Bronze', range: [1, Math.ceil(numWs * 0.6)], blurb: '' },
        { name: 'Silver', range: [Math.ceil(numWs * 0.6) + 1, Math.ceil(numWs * 0.85)], blurb: '' },
        { name: 'Gold',   range: [Math.ceil(numWs * 0.85) + 1, numWs], blurb: '' },
      ];

      const getTierForNum = n => {
        for (const t of tiers) if (n >= t.range[0] && n <= t.range[1]) return t.name;
        return 'Bronze';
      };

      const sections = [
        { kind: 'cover',       title: title,         sections: [{ heading: 'Overview', blocks: [] }] },
        { kind: 'preparation', title: 'Preparation',  sections: [{ heading: 'Getting Started', blocks: [] }] },
        ...Array.from({ length: numWs }, (_, i) => ({
          kind: 'worksheet',
          number: i + 1,
          tier: getTierForNum(i + 1),
          title: `Worksheet ${i + 1}`,
          heroImage: null,
          sections: [{ heading: 'Overview', blocks: [] }],
        })),
        { kind: 'teacher', title: 'Teacher Notes', sections: [{ heading: 'Notes', blocks: [] }] },
      ];

      newData = { code: code.toUpperCase(), title, unit: unit || '', hours, tiers, sections };
    }

    try {
      const res = await fetch('/api/admin/courses', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'x-admin-secret': secret },
        body: JSON.stringify({ key: code, data: newData }),
      });
      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        throw new Error(err.error || res.statusText);
      }
    } catch (e) {
      showToast('Create failed: ' + e.message, 'error');
      createBtn.disabled = false;
      createBtn.textContent = 'Create Course';
      return;
    }

    closeNewCourseModal();
    showToast(`Course "${code}" created`, 'success');
    await loadCoursesList();
    openCourseEditor(code);
  }

  /* ══════════════════════════════════════════════
     TIER HELPERS
  ══════════════════════════════════════════════ */
  function getTier(section) {
    return section.tier || null;
  }

  function tierColor(tier) {
    if (tier === 'Bronze') return 'var(--bronze)';
    if (tier === 'Silver') return 'var(--silver)';
    if (tier === 'Gold')   return 'var(--gold)';
    return 'var(--text-dim)';
  }

  function tierIcon(tier) {
    if (tier === 'Bronze') return '🥉';
    if (tier === 'Silver') return '🥈';
    if (tier === 'Gold')   return '🥇';
    return '📝';
  }

  const KIND_ICONS = {
    cover:       '📄',
    contents:    '📋',
    preparation: '⚙️',
    worksheet:   '📝',
    teacher:     '👨‍🏫',
  };

  /* ══════════════════════════════════════════════
     SIDEBAR
  ══════════════════════════════════════════════ */
  function renderSidebar() {
    const list = document.getElementById('nav-list');
    list.innerHTML = '';

    // Course settings item at the top
    const settingsBtn = document.createElement('button');
    settingsBtn.className = 'nav-item' + (activeIdx === -2 ? ' active' : '');
    settingsBtn.innerHTML = `<span class="nav-icon">⚙️</span><span class="nav-label">Course Settings</span>`;
    settingsBtn.addEventListener('click', () => { activeIdx = -2; renderSidebar(); renderSettings(); });
    list.appendChild(settingsBtn);

    const divTop = document.createElement('div');
    divTop.className = 'nav-divider';
    list.appendChild(divTop);

    const nonWorksheets = course.sections.filter(s => s.kind !== 'worksheet');
    const worksheets    = course.sections.filter(s => s.kind === 'worksheet');

    // Non-worksheet sections at top
    nonWorksheets.slice(0, 3).forEach(section => {
      const idx = course.sections.indexOf(section);
      list.appendChild(makeNavItem(section, idx));
    });

    // Divider
    const div = document.createElement('div');
    div.className = 'nav-divider';
    list.appendChild(div);

    // Worksheets grouped by tier
    let lastTier = null;
    worksheets.forEach(section => {
      const tier = getTier(section);
      if (tier !== lastTier) {
        lastTier = tier;
        const groupLabel = document.createElement('div');
        groupLabel.className = 'nav-group-label';
        groupLabel.style.color = tierColor(tier);
        groupLabel.textContent = tier ? tier.toUpperCase() : 'WORKSHEETS';
        list.appendChild(groupLabel);
      }
      const idx = course.sections.indexOf(section);
      list.appendChild(makeNavItem(section, idx));
    });

    // Divider + Teacher Notes
    const div2 = document.createElement('div');
    div2.className = 'nav-divider';
    list.appendChild(div2);

    nonWorksheets.slice(3).forEach(section => {
      const idx = course.sections.indexOf(section);
      list.appendChild(makeNavItem(section, idx));
    });
  }

  function makeNavItem(section, idx) {
    const tier = getTier(section);
    const icon = tier ? tierIcon(tier) : (KIND_ICONS[section.kind] || '📄');
    const label = section.kind === 'worksheet'
      ? `Worksheet ${section.number}${section.title ? ': ' + section.title : ''}`
      : (section.title || section.label || section.kind);

    const btn = document.createElement('button');
    btn.className = 'nav-item' + (idx === activeIdx ? ' active' : '');
    btn.dataset.idx = String(idx);

    let tierPill = '';
    if (tier) {
      tierPill = `<span class="tier-pill" style="color:${tierColor(tier)};border-color:${tierColor(tier)}">${tier}</span>`;
    }

    btn.innerHTML = `
      <span class="nav-icon">${icon}</span>
      <span class="nav-label">${escHtml(label)}</span>
      ${tierPill}
    `;

    btn.addEventListener('click', () => selectSection(idx));
    return btn;
  }

  /* ══════════════════════════════════════════════
     SECTION SELECTION
  ══════════════════════════════════════════════ */
  function selectSection(idx) {
    activeIdx = idx;
    expandedGroups = new Set([0]); // expand first group by default
    renderSidebar();
    renderEditor();
  }

  /* ══════════════════════════════════════════════
     SETTINGS PANEL
  ══════════════════════════════════════════════ */
  function renderSettings() {
    const panelEl = document.getElementById('editor-panel');
    const emptyEl = document.getElementById('empty-state');
    panelEl.removeAttribute('hidden');
    emptyEl.setAttribute('hidden', '');

    const tiers = course.tiers ?? [];
    const tierRows = tiers.map((t, i) => `
      <div class="settings-tier-row" data-ti="${i}">
        <input type="text" class="field-input tier-name-input" data-ti="${i}" value="${escHtml(t.name)}" placeholder="Tier name" style="width:120px" />
        <span class="settings-tier-sep">WS</span>
        <input type="number" class="field-input tier-from-input" data-ti="${i}" value="${t.range[0]}" min="1" style="width:72px" />
        <span class="settings-tier-sep">–</span>
        <input type="number" class="field-input tier-to-input" data-ti="${i}" value="${t.range[1]}" min="1" style="width:72px" />
        <button class="btn-delete-group tier-del-btn" data-ti="${i}" title="Remove tier">✕</button>
      </div>
    `).join('');

    panelEl.innerHTML = `
      <div class="editor-header">
        <div class="editor-breadcrumb">
          <span>${escHtml((activeCourseKey || '').toUpperCase())}</span> › <span>Course Settings</span>
        </div>
        <div class="editor-section-title">Course Settings <span class="editor-kind-badge">METADATA</span></div>
      </div>
      <div class="groups-container" style="display:flex;flex-direction:column;gap:16px;padding:24px 24px 80px">

        <div class="group-card" style="padding:20px;display:flex;flex-direction:column;gap:14px">
          <div class="field-group">
            <label class="field-label">Course Title</label>
            <input id="s-title" class="field-input" value="${escHtml(course.title || '')}" placeholder="e.g. Introduction to Microcontrollers" />
          </div>
          <div class="editor-fields-row">
            <div class="field-group">
              <label class="field-label">Course Code</label>
              <input id="s-code" class="field-input" value="${escHtml(course.code || '')}" placeholder="e.g. CP4807" />
            </div>
            <div class="field-group">
              <label class="field-label">Hours</label>
              <input id="s-hours" class="field-input" type="number" value="${course.hours ?? 60}" min="1" />
            </div>
          </div>
          <div class="field-group">
            <label class="field-label">Unit / Description</label>
            <input id="s-unit" class="field-input" value="${escHtml(course.unit || '')}" placeholder="e.g. BTEC Unit 6 — Microcontrollers" />
          </div>
          <div class="field-group">
            <label class="field-label">Publisher</label>
            <input id="s-publisher" class="field-input" value="${escHtml(course.publisher || '')}" placeholder="e.g. Matrix Technology Solutions" />
          </div>
        </div>

        <div class="group-card" style="padding:20px">
          <div class="sidebar-head" style="padding:0 0 12px;font-size:11px">TIER CONFIGURATION</div>
          <div id="tiers-list" style="display:flex;flex-direction:column;gap:8px">
            ${tierRows}
          </div>
          <button id="add-tier-btn" class="btn-add-section" style="margin-top:12px">＋ Add Tier</button>
        </div>

      </div>
    `;

    // Bind title/code/hours/unit/publisher
    ['title','code','hours','unit','publisher'].forEach(field => {
      document.getElementById(`s-${field}`).addEventListener('input', e => {
        const val = e.target.value;
        course[field] = field === 'hours' ? (parseInt(val) || val) : val;
        markUnsaved();
      });
    });

    // Bind tier inputs
    function bindTierInputs() {
      document.querySelectorAll('.tier-name-input').forEach(el => {
        el.addEventListener('input', e => {
          course.tiers[+e.target.dataset.ti].name = e.target.value;
          markUnsaved();
        });
      });
      document.querySelectorAll('.tier-from-input').forEach(el => {
        el.addEventListener('input', e => {
          course.tiers[+e.target.dataset.ti].range[0] = parseInt(e.target.value) || 1;
          markUnsaved();
        });
      });
      document.querySelectorAll('.tier-to-input').forEach(el => {
        el.addEventListener('input', e => {
          course.tiers[+e.target.dataset.ti].range[1] = parseInt(e.target.value) || 1;
          markUnsaved();
        });
      });
      document.querySelectorAll('.tier-del-btn').forEach(el => {
        el.addEventListener('click', e => {
          const i = +e.target.dataset.ti;
          course.tiers.splice(i, 1);
          markUnsaved();
          renderSettings();
        });
      });
    }
    bindTierInputs();

    document.getElementById('add-tier-btn').addEventListener('click', () => {
      if (!course.tiers) course.tiers = [];
      const lastTo = course.tiers.length ? course.tiers[course.tiers.length - 1].range[1] : 0;
      course.tiers.push({ name: 'New Tier', range: [lastTo + 1, lastTo + 3], blurb: '' });
      markUnsaved();
      renderSettings();
    });
  }

  /* ══════════════════════════════════════════════
     EDITOR
  ══════════════════════════════════════════════ */
  function renderEditor() {
    const section  = course.sections[activeIdx];
    const panelEl  = document.getElementById('editor-panel');
    const emptyEl  = document.getElementById('empty-state');

    panelEl.removeAttribute('hidden');
    emptyEl.setAttribute('hidden', '');

    const tier = getTier(section);

    const sectionLabel = section.kind === 'worksheet'
      ? `Worksheet ${section.number}`
      : (section.title || section.label || section.kind);

    panelEl.innerHTML = `
      <div class="editor-header">
        <div class="editor-breadcrumb">
          <span>${escHtml((activeCourseKey || '').toUpperCase())}</span> › <span>${escHtml(sectionLabel)}</span>
        </div>
        <div class="editor-section-title">
          ${escHtml(section.title || sectionLabel)}
          <span class="editor-kind-badge">${escHtml(section.kind.toUpperCase())}</span>
          ${tier ? `<span class="editor-tier-badge" style="color:${tierColor(tier)};border-color:${tierColor(tier)}">${tier}</span>` : ''}
        </div>
        <div class="editor-fields-row">
          <div class="field-group">
            <label class="field-label">Title</label>
            <input type="text" class="field-input" id="edit-title"
              value="${escHtml(section.title || '')}"
              placeholder="Section title" />
          </div>
          <div class="field-group">
            <label class="field-label">Hero Image</label>
            <input type="text" class="field-input" id="edit-hero"
              value="${escHtml(section.heroImage || '')}"
              placeholder="filename.jpg" />
          </div>
        </div>
      </div>

      <div class="groups-container" id="groups-container"></div>

      <div class="add-section-area">
        <button class="btn-add-section" id="add-section-btn">＋ Add Section Group</button>
      </div>
    `;

    // Render groups
    renderGroups();

    // Bind header fields
    document.getElementById('edit-title').addEventListener('input', e => {
      course.sections[activeIdx].title = e.target.value;
      markUnsaved();
      // Update sidebar label
      renderSidebar();
    });
    document.getElementById('edit-hero').addEventListener('input', e => {
      course.sections[activeIdx].heroImage = e.target.value || null;
      markUnsaved();
    });
    document.getElementById('add-section-btn').addEventListener('click', addSectionGroup);
  }

  function renderGroups() {
    const container = document.getElementById('groups-container');
    if (!container) return;
    container.innerHTML = '';

    const section = course.sections[activeIdx];
    (section.sections || []).forEach((group, gIdx) => {
      container.appendChild(makeGroupCard(group, gIdx));
    });
  }

  function makeGroupCard(group, gIdx) {
    const isOpen = expandedGroups.has(gIdx);
    const card = document.createElement('div');
    card.className = 'group-card';
    card.dataset.gidx = String(gIdx);

    const blockCount = (group.blocks || []).length;
    card.innerHTML = `
      <div class="group-header">
        <button class="group-toggle" data-gidx="${gIdx}">${isOpen ? '▾' : '▸'}</button>
        <input type="text" class="group-heading-input"
          value="${escHtml(group.heading)}"
          data-gidx="${gIdx}"
          placeholder="Section heading" />
        <span class="group-block-count">${blockCount} block${blockCount !== 1 ? 's' : ''}</span>
        <button class="btn-delete-group" data-gidx="${gIdx}" title="Delete section group">✕</button>
      </div>
      <div class="group-body${isOpen ? '' : ' collapsed'}" data-gbody="${gIdx}">
        <div class="blocks-list" data-gidx="${gIdx}"></div>
        <div class="add-block-area">
          <button class="btn-add-block" data-gidx="${gIdx}">＋ Add Block</button>
          <div class="dropdown-menu" id="dropdown-${gIdx}" hidden></div>
        </div>
      </div>
    `;

    // Render blocks
    const blocksList = card.querySelector(`.blocks-list[data-gidx="${gIdx}"]`);
    (group.blocks || []).forEach((block, bIdx) => {
      blocksList.appendChild(makeBlockRow(block, gIdx, bIdx, (group.blocks || []).length));
    });

    // Dropdown items
    const dropdown = card.querySelector(`#dropdown-${gIdx}`);
    [['p','¶','Paragraph'],['image','🖼','Image'],['youtube','▶','YouTube']].forEach(([type,icon,label]) => {
      const item = document.createElement('button');
      item.className = 'dropdown-item';
      item.innerHTML = `<span class="di-icon">${icon}</span>${label}`;
      item.addEventListener('click', () => { addBlock(gIdx, type); closeAllDropdowns(); });
      dropdown.appendChild(item);
    });

    // Toggle expand
    card.querySelector('.group-toggle').addEventListener('click', () => {
      if (expandedGroups.has(gIdx)) expandedGroups.delete(gIdx);
      else expandedGroups.add(gIdx);
      renderGroups();
    });

    // Header click also toggles (except on inputs/buttons)
    card.querySelector('.group-header').addEventListener('click', e => {
      if (e.target.tagName === 'INPUT' || e.target.tagName === 'BUTTON') return;
      if (expandedGroups.has(gIdx)) expandedGroups.delete(gIdx);
      else expandedGroups.add(gIdx);
      renderGroups();
    });

    // Heading input
    card.querySelector(`.group-heading-input[data-gidx="${gIdx}"]`).addEventListener('input', e => {
      course.sections[activeIdx].sections[gIdx].heading = e.target.value;
      markUnsaved();
    });

    // Delete group
    card.querySelector(`.btn-delete-group[data-gidx="${gIdx}"]`).addEventListener('click', () => {
      if (!confirm(`Delete the "${group.heading}" section group and all its blocks?`)) return;
      course.sections[activeIdx].sections.splice(gIdx, 1);
      markUnsaved();
      renderGroups();
    });

    // Add block button
    card.querySelector(`.btn-add-block[data-gidx="${gIdx}"]`).addEventListener('click', e => {
      e.stopPropagation();
      const dd = document.getElementById(`dropdown-${gIdx}`);
      const wasHidden = dd.hasAttribute('hidden');
      closeAllDropdowns();
      if (wasHidden) dd.removeAttribute('hidden');
    });

    return card;
  }

  function makeBlockRow(block, gIdx, bIdx, total) {
    const canUp   = bIdx > 0;
    const canDown = bIdx < total - 1;

    const row = document.createElement('div');
    row.className = 'block-card';
    row.dataset.type = block.type;
    row.dataset.gidx = String(gIdx);
    row.dataset.bidx = String(bIdx);

    const typeLabels = { p: 'Paragraph', image: 'Image', youtube: 'YouTube' };
    const typeIcons  = { p: '¶', image: '🖼', youtube: '▶' };

    let contentHtml = '';
    if (block.type === 'p') {
      contentHtml = `<textarea class="block-textarea" data-gidx="${gIdx}" data-bidx="${bIdx}" rows="3"
        placeholder="Paragraph text…">${escHtml(block.text || '')}</textarea>`;
    } else if (block.type === 'image') {
      contentHtml = `
        <div class="block-image-pair">
          <div class="block-field-wrap">
            <span class="block-field-label">Filename</span>
            <input type="text" class="block-input block-img-src" data-gidx="${gIdx}" data-bidx="${bIdx}"
              value="${escHtml(block.src || '')}" placeholder="image.jpg" />
          </div>
          <div class="block-field-wrap">
            <span class="block-field-label">Alt text</span>
            <input type="text" class="block-input block-img-alt" data-gidx="${gIdx}" data-bidx="${bIdx}"
              value="${escHtml(block.alt || '')}" placeholder="Describe the image" />
          </div>
        </div>`;
    } else if (block.type === 'youtube') {
      const ytUrl = block.id ? `https://youtu.be/${block.id}` : '';
      contentHtml = `
        <div class="block-field-wrap" style="margin-bottom:0">
          <span class="block-field-label">Video ID</span>
          <div class="yt-row">
            <input type="text" class="block-input block-yt-id" data-gidx="${gIdx}" data-bidx="${bIdx}"
              value="${escHtml(block.id || '')}" placeholder="e.g. dQw4w9WgXcQ" style="flex:1" />
            ${block.id ? `<a href="${ytUrl}" target="_blank" class="yt-preview-link">▶ Preview</a>` : ''}
          </div>
        </div>`;
    }

    row.innerHTML = `
      <div class="block-bar">
        <span class="block-type-chip">${typeIcons[block.type] || '?'} ${typeLabels[block.type] || block.type}</span>
        <span class="block-bar-spacer"></span>
        <div class="block-tools">
          <button class="btn-tool" data-action="up" data-gidx="${gIdx}" data-bidx="${bIdx}"
            ${canUp ? '' : 'disabled'} title="Move up">↑</button>
          <button class="btn-tool" data-action="down" data-gidx="${gIdx}" data-bidx="${bIdx}"
            ${canDown ? '' : 'disabled'} title="Move down">↓</button>
          <button class="btn-tool btn-tool-del" data-action="del" data-gidx="${gIdx}" data-bidx="${bIdx}"
            title="Delete block">✕</button>
        </div>
      </div>
      <div class="block-content">${contentHtml}</div>
    `;

    // Bind block field events
    if (block.type === 'p') {
      const ta = row.querySelector('.block-textarea');
      ta.addEventListener('input', () => {
        autoResize(ta);
        course.sections[activeIdx].sections[gIdx].blocks[bIdx].text = ta.value;
        markUnsaved();
      });
      setTimeout(() => autoResize(ta), 0);
    } else if (block.type === 'image') {
      row.querySelector('.block-img-src').addEventListener('input', e => {
        course.sections[activeIdx].sections[gIdx].blocks[bIdx].src = e.target.value;
        markUnsaved();
      });
      row.querySelector('.block-img-alt').addEventListener('input', e => {
        course.sections[activeIdx].sections[gIdx].blocks[bIdx].alt = e.target.value;
        markUnsaved();
      });
    } else if (block.type === 'youtube') {
      row.querySelector('.block-yt-id').addEventListener('input', e => {
        course.sections[activeIdx].sections[gIdx].blocks[bIdx].id  = e.target.value;
        course.sections[activeIdx].sections[gIdx].blocks[bIdx].url = e.target.value ? `https://youtu.be/${e.target.value}` : '';
        markUnsaved();
      });
    }

    // Block action buttons
    row.querySelectorAll('.btn-tool').forEach(btn => {
      btn.addEventListener('click', () => {
        const action = btn.dataset.action;
        const g = parseInt(btn.dataset.gidx);
        const b = parseInt(btn.dataset.bidx);
        const blocks = course.sections[activeIdx].sections[g].blocks;
        if (action === 'up' && b > 0) {
          [blocks[b - 1], blocks[b]] = [blocks[b], blocks[b - 1]];
        } else if (action === 'down' && b < blocks.length - 1) {
          [blocks[b], blocks[b + 1]] = [blocks[b + 1], blocks[b]];
        } else if (action === 'del') {
          if (!confirm('Delete this block?')) return;
          blocks.splice(b, 1);
        }
        markUnsaved();
        renderGroups();
      });
    });

    return row;
  }

  /* ══════════════════════════════════════════════
     MUTATIONS
  ══════════════════════════════════════════════ */
  function addBlock(gIdx, type) {
    const newBlock = type === 'p'
      ? { type: 'p', text: '' }
      : type === 'image'
        ? { type: 'image', src: '', alt: '' }
        : { type: 'youtube', url: '', id: '' };

    course.sections[activeIdx].sections[gIdx].blocks.push(newBlock);
    expandedGroups.add(gIdx);
    markUnsaved();
    renderGroups();
  }

  function addSectionGroup() {
    const newGroup = { heading: 'New Section', blocks: [] };
    const idx = course.sections[activeIdx].sections.length;
    course.sections[activeIdx].sections.push(newGroup);
    expandedGroups.add(idx);
    markUnsaved();
    renderGroups();
    // Scroll to new group
    setTimeout(() => {
      const cards = document.querySelectorAll('.group-card');
      if (cards.length) cards[cards.length - 1].scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 50);
  }

  function closeAllDropdowns() {
    document.querySelectorAll('.dropdown-menu').forEach(d => d.setAttribute('hidden', ''));
  }

  /* ══════════════════════════════════════════════
     SAVE
  ══════════════════════════════════════════════ */
  async function handleSave() {
    const btn     = document.getElementById('save-btn');
    const btnText = document.getElementById('save-btn-text');
    const spinner = document.getElementById('save-spinner');
    const secret  = document.querySelector('meta[name="admin-secret"]')?.getAttribute('content') ?? '';

    btn.disabled = true;
    btnText.textContent = 'Saving…';
    spinner.removeAttribute('hidden');
    btn.classList.remove('success');

    try {
      const res = await fetch('/api/admin/save', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'x-admin-secret': secret,
        },
        body: JSON.stringify({ ...course, _key: activeCourseKey }),
      });

      if (!res.ok) {
        const err = await res.json().catch(() => ({ error: res.statusText }));
        throw new Error(err.error ?? 'Save failed');
      }

      persistCourse();
      spinner.setAttribute('hidden', '');
      btnText.textContent = 'Saved ✓';
      btn.classList.add('success');
      markSaved();
      showToast('Changes saved to database', 'success');
    } catch (e) {
      spinner.setAttribute('hidden', '');
      btnText.textContent = 'Save Changes';
      btn.disabled = false;
      showToast('Save failed: ' + e.message, 'error');
      return;
    }

    setTimeout(() => {
      btnText.textContent = 'Save Changes';
      btn.classList.remove('success');
      btn.disabled = false;
    }, 2500);
  }

  /* ══════════════════════════════════════════════
     CHANGE TRACKING
  ══════════════════════════════════════════════ */
  function markUnsaved() {
    hasUnsaved = true;
    const dot   = document.getElementById('unsaved-dot');
    const label = document.getElementById('unsaved-label');
    if (dot)   { dot.classList.remove('saved'); }
    if (label) label.textContent = 'Unsaved changes';
    document.getElementById('save-btn').disabled = false;
  }

  function markSaved() {
    hasUnsaved = false;
    const dot   = document.getElementById('unsaved-dot');
    const label = document.getElementById('unsaved-label');
    if (dot)   dot.classList.add('saved');
    if (label) label.textContent = 'All changes saved';
  }

  /* ══════════════════════════════════════════════
     TOAST
  ══════════════════════════════════════════════ */
  function showToast(msg, type = 'success') {
    const toast = document.getElementById('toast');
    toast.textContent = (type === 'success' ? '✓  ' : '✕  ') + msg;
    toast.className = `toast ${type}`;
    toast.removeAttribute('hidden');
    clearTimeout(toast._timer);
    toast._timer = setTimeout(() => toast.setAttribute('hidden', ''), 3000);
  }

  /* ══════════════════════════════════════════════
     UTILS
  ══════════════════════════════════════════════ */
  function escHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function autoResize(ta) {
    ta.style.height = 'auto';
    ta.style.height = ta.scrollHeight + 'px';
  }

  /* ══════════════════════════════════════════════
     INIT
  ══════════════════════════════════════════════ */
  boot();
</script>

</body>
</html>
