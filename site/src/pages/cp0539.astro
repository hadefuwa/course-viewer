---
import Base from "../layouts/Base.astro";
import { getCourseByKey } from "../lib/supabase";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const course = await getCourseByKey("cp0539");
const worksheets = ((course?.sections ?? []) as any[]).filter((s: any) => s.kind === "worksheet");
const wsMap: Record<number, any> = {};
for (const w of worksheets) wsMap[w.number] = w;

function ytId(url: string): string {
  return url.match(/youtu\.be\/([^?&]+)/)?.[1] ?? url.match(/[?&]v=([^&]+)/)?.[1] ?? "";
}

type SchedType = "lecture" | "worksheet" | "homework" | "assessment" | "project" | "module";
const SCHEDULE: { label: string; hrs: number; type: SchedType }[] = [
  // Session 1
  { label: "Course introduction & system walkthrough",       hrs: 1, type: "lecture" },
  { label: "Health & safety in industrial environments",     hrs: 1, type: "lecture" },
  { label: "Closed-loop control theory (presentation)",      hrs: 1, type: "lecture" },
  { label: "PLC architecture & programming overview",        hrs: 1, type: "lecture" },
  // Sessions 2–3
  { label: "Worksheet 1: Closed-Loop Control Systems",       hrs: 2, type: "worksheet" },
  { label: "Worksheet 2: Emergency Stops",                   hrs: 2, type: "worksheet" },
  // Session 4
  { label: "Worksheet 3: Status LED",                        hrs: 2, type: "worksheet" },
  { label: "Worksheet 4: PLC",                               hrs: 2, type: "worksheet" },
  // Session 5
  { label: "Worksheet 5: HMI",                               hrs: 2, type: "worksheet" },
  // Sessions 6–7
  { label: "Fluid power — pumps & valves (presentation)",    hrs: 1, type: "lecture" },
  { label: "Worksheet 6: Pump",                              hrs: 2, type: "worksheet" },
  { label: "Worksheet 7: Valve",                             hrs: 2, type: "worksheet" },
  // Session 8: Assessment 1
  { label: "Assessment 1",                                   hrs: 2, type: "assessment" },
  // Sessions 9–10
  { label: "Worksheet 8: Float Switch",                      hrs: 2, type: "worksheet" },
  { label: "Worksheet 9: Proximity Switch",                  hrs: 2, type: "worksheet" },
  // Sessions 11–12
  { label: "Process sensing & measurement (presentation)",   hrs: 1, type: "lecture" },
  { label: "Worksheet 10: Flow Sensor",                      hrs: 2, type: "worksheet" },
  { label: "Worksheet 11: Temperature Sensor",               hrs: 2, type: "worksheet" },
  // Sessions 13–14
  { label: "Worksheet 12: Digital Sensors",                  hrs: 2, type: "worksheet" },
  { label: "Worksheet 13: Analogue Sensors",                 hrs: 2, type: "worksheet" },
  // Session 15: Assessment 2
  { label: "Assessment 2",                                   hrs: 2, type: "assessment" },
  // Sessions 16–17
  { label: "Fault diagnosis & safe isolation (presentation)", hrs: 1, type: "lecture" },
  { label: "Worksheet 14: Faults",                           hrs: 2, type: "worksheet" },
  { label: "Worksheet 15: Lock Out Tag Out",                 hrs: 2, type: "worksheet" },
  // Session 18: Assessment 3
  { label: "Assessment 3",                                   hrs: 2, type: "assessment" },
  // Sessions 19–23
  { label: "Student project — sessions 19–23",               hrs: 10, type: "project" },
];

const EXTENSION: { label: string; hrs: number; type: SchedType }[] = [
  { label: "SCADA & HMI Integration module",         hrs: 12, type: "module" },
  { label: "Advanced PID Tuning module",             hrs: 12, type: "module" },
  { label: "Industrial Safety Systems (SIL) module", hrs: 12, type: "module" },
  { label: "Network Communications module",          hrs: 12, type: "module" },
  { label: "Further Project",                        hrs: 12, type: "module" },
];
const schedTotal = SCHEDULE.reduce((s, x) => s + x.hrs, 0);
const extTotal   = EXTENSION.reduce((s, x) => s + x.hrs, 0);

interface DocSlide    { type: "document";    title: string; ws?: number; }
interface YtSlide     { type: "youtube";     title: string; url: string; }
interface PdfSlide    { type: "pdf";         title: string; url: string; }
interface PptSlide    { type: "powerpoint";  title: string; points: string[]; }
interface HtmlSlide   { type: "html";        title: string; subtype: "welcome" | "homework" | "assessment"; }
interface OpenSlide   { type: "opening";     title: string; }
interface SectionSlide { type: "section";   title: string; subtitle: string; hours: number; }
interface ModuleSlide  { type: "module";    title: string; desc: string; icon: string; }
type SlideDef = DocSlide | YtSlide | PdfSlide | PptSlide | HtmlSlide | OpenSlide | SectionSlide | ModuleSlide;

const SLIDES: SlideDef[] = [

  // ── Course intro ──────────────────────────────────────────────────────────
  { type: "opening", title: "Industrial Maintenance of Closed Loop Systems" },
  { type: "html",    title: "Welcome", subtype: "welcome" },

  // ── Session 1: Theory intro ───────────────────────────────────────────────
  { type: "powerpoint", title: "Closed-Loop Control Theory", points: [
    "What is a closed-loop system and why is feedback essential to industrial processes?",
    "The control loop: sensor, controller, actuator, and process variable explained",
    "Open-loop vs closed-loop: why setpoint accuracy matters in manufacturing",
    "PID control: Proportional, Integral, and Derivative terms and their effects",
    "Steady-state error, overshoot, and settling time — key performance metrics",
    "Real-world examples: flow control, temperature regulation, level control",
  ]},
  { type: "powerpoint", title: "PLC Architecture & Programming", points: [
    "What is a PLC? Origins, structure and why it replaced relay logic in industry",
    "The scan cycle: input sampling, programme execution, and output update",
    "Digital inputs and outputs — NPN, PNP, sourcing and sinking explained",
    "Ladder logic fundamentals: contacts, coils, timers and counters",
    "IEC 61131-3 languages: Ladder, Structured Text, and Function Block Diagram",
    "Introduction to the Siemens S7-1200 PLC used in this training system",
  ]},

  // ── Sessions 2–3: Foundations ────────────────────────────────────────────
  { type: "document", title: "Closed-Loop Control Systems", ws: 1 },
  { type: "document", title: "Emergency Stops",              ws: 2 },
  { type: "document", title: "Status LED",                   ws: 3 },
  { type: "document", title: "PLC",                          ws: 4 },

  { type: "html", title: "Homework 1", subtype: "homework" },

  // ── Session 5: HMI ───────────────────────────────────────────────────────
  { type: "document", title: "HMI",  ws: 5 },

  { type: "html", title: "Homework 2", subtype: "homework" },

  // ── Sessions 6–7: Fluid power ────────────────────────────────────────────
  { type: "powerpoint", title: "Fluid Power — Pumps & Valves", points: [
    "Centrifugal vs positive displacement pumps — selection criteria for industrial use",
    "Pump curves, affinity laws, and how VFD speed control reduces energy consumption",
    "Proportional control valves: how electrical signals produce variable flow restriction",
    "Cavitation, water hammer, and other common pump and valve failure modes",
    "Flow measurement principles: differential pressure, electromagnetic and Coriolis",
    "Maintenance checks: mechanical seals, impeller wear, valve stroke and seat condition",
  ]},
  { type: "document", title: "Pump",  ws: 6 },
  { type: "document", title: "Valve", ws: 7 },

  { type: "html", title: "Homework 3", subtype: "homework" },

  // ── Session 8: Assessment 1 ──────────────────────────────────────────────
  { type: "html", title: "Assessment 1", subtype: "assessment" },

  // ── Sessions 9–10: Discrete sensors ─────────────────────────────────────
  { type: "document", title: "Float Switch",      ws: 8 },
  { type: "document", title: "Proximity Switch",  ws: 9 },

  { type: "html", title: "Homework 4", subtype: "homework" },

  // ── Sessions 11–14: Process measurement ─────────────────────────────────
  { type: "powerpoint", title: "Process Sensing & Measurement", points: [
    "Sensor selection criteria: range, accuracy, resolution, and response time",
    "4–20 mA signal loops: why current loops are preferred in noisy industrial environments",
    "Thermocouple and RTD fundamentals — Type K, J, E thermocouples and PT100 explained",
    "Float switches, proximity sensors, and flow meters — operating principles compared",
    "Signal conditioning: filtering, amplification, and analogue-to-digital conversion",
    "Common faults: sensor drift, electrical noise, cable shielding, and connection integrity",
  ]},
  { type: "document", title: "Flow Sensor",         ws: 10 },
  { type: "document", title: "Temperature Sensor",  ws: 11 },
  { type: "document", title: "Digital Sensors",     ws: 12 },
  { type: "document", title: "Analogue Sensors",    ws: 13 },

  { type: "html", title: "Homework 5", subtype: "homework" },

  // ── Session 15: Assessment 2 ─────────────────────────────────────────────
  { type: "html", title: "Assessment 2", subtype: "assessment" },

  // ── Sessions 16–17: Fault finding & safety ───────────────────────────────
  { type: "powerpoint", title: "Fault Diagnosis & Safe Isolation", points: [
    "Systematic fault-finding: symptom → hypothesis → test → confirm approach",
    "Reading PLC diagnostic logs and interpreting I/O status LEDs in real time",
    "Common actuator faults: valve sticking, pump cavitation, and motor tripping",
    "Common sensor faults: short circuits, open circuits, signal drift, and EMI interference",
    "Lockout/Tagout (LOTO) legislation and why it saves lives — UK PSSR 2000 & PUWER 1998",
    "Documentation: isolation certificates, permit-to-work, and competency records",
  ]},
  { type: "document", title: "Faults",             ws: 14 },
  { type: "document", title: "Lock Out Tag Out",   ws: 15 },

  { type: "html", title: "Homework 6", subtype: "homework" },

  // ── Session 18: Assessment 3 ─────────────────────────────────────────────
  { type: "html", title: "Assessment 3", subtype: "assessment" },

  // ── Extension Programme ───────────────────────────────────────────────────
  { type: "section", title: "Extended Scheme of Work", subtitle: "Builds on the 60-hour core programme with advanced industrial topics", hours: 120 },
  { type: "module", title: "SCADA & HMI Integration",       icon: "monitor", desc: "Students learn to configure Supervisory Control and Data Acquisition systems, building custom HMI screens that display live process data, trend graphs, and alarm management in a simulated industrial plant." },
  { type: "module", title: "Advanced PID Tuning",            icon: "sensors", desc: "Students use Ziegler-Nichols and relay tuning methods on the live training rig to optimise proportional, integral, and derivative gains — minimising overshoot and settling time under realistic disturbances." },
  { type: "module", title: "Industrial Safety Systems",      icon: "safety",  desc: "An in-depth look at Safety Integrity Levels (SIL), safety instrumented functions, and the design of emergency shutdown systems to IEC 61511 — directly relevant to process industry careers." },
  { type: "module", title: "Network Communications",         icon: "network", desc: "Students configure Profibus, Profinet, and Modbus TCP/IP communications between the PLC, HMI, and remote I/O modules — mirroring the architecture found in modern industrial plant." },
  { type: "module", title: "Further Project",                icon: "project", desc: "Students undertake an extended open-ended project drawing on all skills from the full 120-hour programme — specifying, designing, implementing, and commissioning a complete closed-loop control solution." },
];

const slides = SLIDES.map((s, i) => {
  const wsNum = (s as DocSlide).ws;
  return { ...s, index: i, wsData: wsNum ? wsMap[wsNum] : null };
});
const total = slides.length;

function typeLabel(s: SlideDef): string {
  if (s.type === "html") {
    return { welcome: "Welcome", homework: "Homework", assessment: "Assessment" }[(s as HtmlSlide).subtype];
  }
  return ({ opening: "Introduction", youtube: "Video", pdf: "PDF Resource", powerpoint: "Presentation", document: "Worksheet", section: "Extended Programme", module: "Module" } as Record<string,string>)[s.type] ?? s.type;
}
function typeClass(s: SlideDef): string {
  if (s.type === "html") return `type-${(s as HtmlSlide).subtype}`;
  return `type-${s.type}`;
}
---

<Base title={`${course?.unit ?? "Unit 36 PLCs"}: Scheme of Work`}>
  <div class="sw-wrap" id="sw-wrap">

    <!-- Top bar -->
    <div class="sw-topbar">
      <div class="sw-topbar-left">
        <span class="sw-course-code">{course?.code ?? "CP0539"}</span>
        <span class="sw-course-name">{course?.title ?? "Industrial Maintenance of Closed Loop Systems"}</span>
      </div>
      <div class="sw-progress-track">
        <div class="sw-progress-fill" id="sw-progress-fill"></div>
      </div>
      <div class="sw-counter" id="sw-counter">1 <span class="sw-counter-of">/ {total}</span></div>
    </div>

    <!-- Slides container -->
    <div class="sw-viewport" id="sw-viewport">
      {slides.map((s, i) => {
        const label  = typeLabel(s as SlideDef);
        const cls    = typeClass(s as SlideDef);
        const isDoc  = s.type === "document";
        const wsNum  = (s as any).ws as number | undefined;
        const wsData = (s as any).wsData;
        return (
          <div class={`sw-slide ${cls}`} data-index={i} data-type={cls} aria-hidden={i > 0 ? "true" : "false"} hidden={i > 0}>

            <div class="sw-orb sw-orb-1" aria-hidden="true"></div>
            <div class="sw-orb sw-orb-2" aria-hidden="true"></div>

            <div class="sw-slide-header">
              <span class={`sw-badge ${cls}`}>{label}</span>
              <h1 class="sw-slide-title">{s.title}</h1>
            </div>

            <div class="sw-slide-body">

              {/* ── Opening ── */}
              {s.type === "opening" && (
                <div class="opening-card">
                  <div class="opening-img" style={`background-image: url('${base}/images/cp0539-image1.png')`}>
                    <div class="opening-grid" aria-hidden="true"></div>
                    <div class="opening-overlay">
                      <div class="opening-chips">
                        <span class="opening-chip">{course?.unit ?? "BTEC Unit 36 — PLCs"}</span>
                        <span class="opening-chip">{course?.code ?? "CP0539"}</span>
                        <span class="opening-chip">{course?.hours ?? 60}-hour course</span>
                      </div>
                      <div class="opening-headline">{s.title}</div>
                      <div class="opening-pub">{course?.publisher ?? "Matrix Technology Solutions"}</div>
                    </div>
                  </div>
                </div>
              )}

              {/* ── YouTube ── */}
              {s.type === "youtube" && (
                <div class="yt-shell" data-src={`https://www.youtube.com/embed/${ytId((s as YtSlide).url)}?autoplay=1&rel=0`}>
                  <img
                    class="yt-thumb"
                    src={`https://img.youtube.com/vi/${ytId((s as YtSlide).url)}/maxresdefault.jpg`}
                    onerror={`this.src='https://img.youtube.com/vi/${ytId((s as YtSlide).url)}/hqdefault.jpg'`}
                    alt={s.title}
                    draggable="false"
                  />
                  <div class="yt-overlay" aria-hidden="true"></div>
                  <button class="yt-play-btn" aria-label={`Play: ${s.title}`}>
                    <svg viewBox="0 0 68 48" width="80" height="56" aria-hidden="true">
                      <path d="M66.5 7.7a8.5 8.5 0 0 0-6-6C56.1 0 34 0 34 0S11.9 0 7.5 1.7a8.5 8.5 0 0 0-6 6C0 12.1 0 24 0 24s0 11.9 1.5 16.3a8.5 8.5 0 0 0 6 6C11.9 48 34 48 34 48s22.1 0 26.5-1.7a8.5 8.5 0 0 0 6-6C68 35.9 68 24 68 24s0-11.9-1.5-16.3z" fill="#ff0000"/>
                      <path d="M45 24L27 14v20" fill="#fff"/>
                    </svg>
                  </button>
                  <iframe class="yt-iframe" src="" title={s.title} frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
                </div>
              )}

              {/* ── PDF ── */}
              {s.type === "pdf" && (
                <div class="pdf-hero">
                  <div class="pdf-hero-watermark" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.4" width="340" height="340"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                  </div>
                  <div class="pdf-hero-content">
                    <div class="pdf-hero-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="36" height="36"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                    </div>
                    <p class="pdf-hero-label">PDF Resource</p>
                    <h2 class="pdf-hero-title">{s.title}</h2>
                    <p class="pdf-hero-desc">Technical specification document — open to read or download.</p>
                    <a href={(s as PdfSlide).url} target="_blank" rel="noopener" class="pdf-hero-btn">
                      Open PDF
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                    </a>
                  </div>
                </div>
              )}

              {/* ── PowerPoint ── */}
              {s.type === "powerpoint" && (
                <div class="ppt-card">
                  <div class="ppt-card-top">
                    <div class="ppt-icon-wrap">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/><path d="M9 8h3a2 2 0 0 1 0 4H9V8z"/></svg>
                    </div>
                    <div>
                      <div class="ppt-card-type">PowerPoint Presentation</div>
                      <h2 class="ppt-card-title">{s.title}</h2>
                    </div>
                  </div>
                  <div class="ppt-divider"></div>
                  <div class="ppt-agenda-label">In this session we will cover:</div>
                  <ul class="ppt-points">
                    {(s as PptSlide).points.map((p, pi) => (
                      <li class="ppt-point">
                        <span class="ppt-num" aria-hidden="true">0{pi + 1}</span>
                        {p}
                      </li>
                    ))}
                  </ul>
                  <button class="ppt-open-btn" disabled aria-disabled="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
                    Open Presentation
                    <span class="ppt-open-soon">coming soon</span>
                  </button>
                </div>
              )}

              {/* ── Worksheet with data ── */}
              {isDoc && wsData && (
                <div
                  class="ws-card"
                  style={wsData.heroImage ? `--ws-img: url('${base}/images/${wsData.heroImage}')` : ""}
                >
                  {wsData.heroImage && <div class="ws-card-bg"></div>}
                  <div class="ws-card-gradient"></div>
                  <div class="ws-card-info">
                    <div class="ws-card-meta">
                      <span class="ws-card-label">Worksheet {wsNum}</span>
                      {wsData.tier && (
                        <span class={`ws-tier-badge ${wsData.tier.toLowerCase()}`}>{wsData.tier}</span>
                      )}
                    </div>
                    <h2 class="ws-card-title">{s.title}</h2>
                    <a href={`${base}/courses/cp0539/worksheets/${wsNum}`} class="ws-open-btn">
                      Open interactive worksheet
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="18" height="18" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </a>
                  </div>
                </div>
              )}

              {/* ── Worksheet without data ── */}
              {isDoc && !wsData && (
                <div class="doc-hero">
                  <div class="doc-hero-watermark" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.35" width="300" height="300"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                  </div>
                  <div class="doc-hero-content">
                    <div class="doc-hero-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="32" height="32"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                    </div>
                    <p class="doc-hero-label">Worksheet Document</p>
                    <h2 class="doc-hero-title">{s.title}</h2>
                    <p class="doc-hero-desc">Practical worksheet — work through the activities on the closed loop training rig.</p>
                    <div class="slide-callouts">
                      <button class="slide-callout-btn" disabled aria-disabled="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                        Open Worksheet PDF
                        <span class="slide-callout-soon">Coming Soon</span>
                      </button>
                    </div>
                  </div>
                </div>
              )}

              {/* ── Welcome ── */}
              {s.type === "html" && (s as HtmlSlide).subtype === "welcome" && (
                <div class="welcome-hero">
                  <div class="welcome-header">
                    <div class="welcome-header-top">
                      <div class="welcome-chips">
                        <span class="welcome-chip">{course?.unit ?? "BTEC Unit 36 — PLCs"}</span>
                        <span class="welcome-chip">{course?.code ?? "CP0539"}</span>
                        <span class="welcome-chip">15 worksheets</span>
                      </div>
                      <div class="welcome-tiers">
                        <span class="ws-tier-badge bronze">Bronze</span>
                        <span class="ws-tier-badge silver">Silver</span>
                        <span class="ws-tier-badge gold">Gold</span>
                      </div>
                    </div>
                    <h2 class="welcome-title">{course?.title ?? "Industrial Maintenance of Closed Loop Systems"}</h2>
                  </div>
                  <div class="sched-scroll">
                    <div class="sched-grid">
                      {SCHEDULE.map((item) => (
                        <div class={`sched-item sched-${item.type}`}>
                          <span class="sched-dot"></span>
                          <span class="sched-lbl">{item.label}</span>
                          <span class="sched-hrs">{item.hrs}h</span>
                        </div>
                      ))}
                      <div class="sched-milestone">
                        <span class="sched-milestone-line"></span>
                        <span class="sched-milestone-label">{schedTotal} hrs — Core programme complete</span>
                        <span class="sched-milestone-line"></span>
                      </div>
                      {EXTENSION.map((item) => (
                        <div class={`sched-item sched-${item.type}`}>
                          <span class="sched-dot"></span>
                          <span class="sched-lbl">{item.label}</span>
                          <span class="sched-hrs">{item.hrs}h</span>
                        </div>
                      ))}
                      <div class="sched-milestone sched-total">
                        <span class="sched-milestone-line"></span>
                        <span class="sched-milestone-label">{schedTotal + extTotal} hrs — Full programme</span>
                        <span class="sched-milestone-line"></span>
                      </div>
                    </div>
                  </div>
                </div>
              )}

              {/* ── Homework / Assessment ── */}
              {s.type === "html" && (s as HtmlSlide).subtype !== "welcome" && (
                <div class={`html-hero html-${(s as HtmlSlide).subtype}`}>
                  <div class="html-hero-watermark" aria-hidden="true">
                    {(s as HtmlSlide).subtype === "assessment" && (
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.3" width="340" height="340"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                    )}
                    {(s as HtmlSlide).subtype === "homework" && (
