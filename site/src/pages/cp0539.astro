<script define:vars={{ total }}>
(function () {
  let current = 0;
  const slideEls = Array.from(document.querySelectorAll('.sw-slide'));
  const wrap     = document.getElementById('sw-wrap');
  const prevBtn  = document.getElementById('sw-prev');
  const nextBtn  = document.getElementById('sw-next');
  const counter  = document.getElementById('sw-counter');
  const fill     = document.getElementById('sw-progress-fill');
  const pipsWrap = document.getElementById('sw-pips');

  const PIP_MAX = 9;
  const pipEls  = [];
  for (let i = 0; i < Math.min(total, PIP_MAX); i++) {
    const btn = document.createElement('button');
    btn.className = 'sw-pip';
    pipsWrap.appendChild(btn);
    pipEls.push(btn);
  }

  document.querySelectorAll('.yt-shell').forEach(shell => {
    shell.querySelector('.yt-play-btn').addEventListener('click', () => {
      const iframe = shell.querySelector('.yt-iframe');
      iframe.src = shell.dataset.src;
      iframe.classList.add('active');
      shell.querySelector('.yt-thumb').style.display = 'none';
      shell.querySelector('.yt-overlay').style.display = 'none';
      shell.querySelector('.yt-play-btn').style.display = 'none';
    }, { once: true });
  });

  function stopVideosInSlide(slideEl) {
    slideEl.querySelectorAll('.yt-iframe.active').forEach(f => {
      f.src = '';
      f.classList.remove('active');
    });
  }

  function goTo(n) {
    const prev = slideEls[current];
    stopVideosInSlide(prev);
    prev.hidden = true;
    prev.setAttribute('aria-hidden', 'true');
    prev.classList.remove('entering');

    current = Math.max(0, Math.min(total - 1, n));
    const next = slideEls[current];
    next.hidden = false;
    next.setAttribute('aria-hidden', 'false');
    next.classList.remove('entering');
    requestAnimationFrame(() => next.classList.add('entering'));

    wrap.dataset.type = next.dataset.type || '';
    update();
  }

  function update() {
    prevBtn.disabled = current === 0;
    nextBtn.disabled = current === total - 1;
    counter.innerHTML = (current + 1) + ' <span class="sw-counter-of">/ ' + total + '</span>';
    if (fill) fill.style.width = ((current + 1) / total * 100) + '%';

    if (total <= PIP_MAX) {
      pipEls.forEach((p, i) => {
        p.classList.toggle('active', i === current);
        p.onclick = () => goTo(i);
        p.setAttribute('aria-label', 'Slide ' + (i + 1));
      });
    } else {
      const half  = Math.floor(PIP_MAX / 2);
      let   start = Math.max(0, current - half);
      if (start + PIP_MAX > total) start = total - PIP_MAX;
      pipEls.forEach((p, i) => {
        const idx = start + i;
        p.classList.toggle('active', idx === current);
        p.setAttribute('aria-label', 'Slide ' + (idx + 1));
        p.onclick = () => goTo(idx);
      });
    }
  }

  prevBtn.addEventListener('click', () => goTo(current - 1));
  nextBtn.addEventListener('click', () => goTo(current + 1));
  document.addEventListener('keydown', e => {
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown') { e.preventDefault(); goTo(current + 1); }
    if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')   { e.preventDefault(); goTo(current - 1); }
  });

  const viewport = document.getElementById('sw-viewport');
  let touchStartX = 0;
  let touchStartY = 0;
  viewport?.addEventListener('touchstart', e => {
    touchStartX = e.touches[0].clientX;
    touchStartY = e.touches[0].clientY;
  }, { passive: true });
  viewport?.addEventListener('touchend', e => {
    const dx = e.changedTouches[0].clientX - touchStartX;
    const dy = e.changedTouches[0].clientY - touchStartY;
    if (Math.abs(dx) < 80 || Math.abs(dx) < Math.abs(dy) * 1.5) return;
    if (dx < 0) goTo(current + 1);
    else        goTo(current - 1);
  }, { passive: true });

  wrap.dataset.type = slideEls[0]?.dataset.type || '';
  slideEls[0]?.classList.add('entering');
  update();
})();
</script>

