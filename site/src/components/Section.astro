---
const { section, skipImages = [] } = Astro.props as { section: any; skipImages?: string[] };
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const h = (section.heading || "").toLowerCase().trim();
const isOverToYou = h.includes("over to you");
const isChallenge = h.includes("challenge");
const isHint = h.includes("hint");
const isOverview = h.includes("overview") || h === "";
const paragraphs = section.blocks.filter((b: any) => b.type === "p");

const calloutButtons = [
  { icon: "📋", label: "Open Assessment PDF" },
  { icon: "📝", label: "Open Homework PDF" },
  { icon: "📊", label: "Open Presentation" },
];

// Skip image blocks that are directly before a youtube block (they're redundant thumbnails)
const ytThumbnailIndices = new Set<number>(
  section.blocks
    .map((_: any, i: number) =>
      i > 0 &&
      section.blocks[i].type === "youtube" &&
      section.blocks[i - 1].type === "image"
        ? i - 1
        : -1
    )
    .filter((i: number) => i >= 0)
);

function showImage(src: string, blockIndex: number) {
  if (!src) return false;
  if (src.toLowerCase().includes("youtube_logo")) return false;
  if (skipImages.includes(src)) return false;
  if (ytThumbnailIndices.has(blockIndex)) return false;
  return true;
}
---

{isOverToYou && (
  <div class="ws-section ws-tasks">
    <div class="section-header">
      <span class="section-icon" aria-hidden="true">✏️</span>
      <h2>{section.heading}</h2>
      <span class="section-xp-tag cyan">Tasks · +10 XP each</span>
    </div>
    <div class="task-list">
      {section.blocks.map((b: any, i: number) => {
        if (b.type === "p") return (
          <label class="task-item">
            <span class="task-check-wrap">
              <input type="checkbox" class="task-check" />
              <span class="task-checkmark"></span>
            </span>
            <span class="task-text">{b.text}</span>
            <span class="task-xp">+10 XP</span>
          </label>
        );
        if (b.type === "image") return showImage(b.src, i) ? <img src={`${base}/images/${b.src}`} alt={b.alt || ""} loading="lazy" /> : null;
        return null;
      })}
    </div>
  </div>
)}

{isChallenge && !isHint && (
  <div class="ws-section ws-challenges">
    <div class="section-header">
      <span class="section-icon" aria-hidden="true">🏆</span>
      <h2>{section.heading}</h2>
      <span class="section-xp-tag gold">+25 XP each</span>
    </div>
    <div class="challenge-list">
      {section.blocks.map((b: any, i: number) => {
        if (b.type === "p") return (
          <div class="challenge-card">
            <div class="challenge-num">#{paragraphs.indexOf(b) + 1}</div>
            <p class="challenge-text">{b.text}</p>
            <button class="challenge-btn" type="button">
              <span class="btn-idle">Mark Complete</span>
              <span class="btn-done">✓ Done</span>
            </button>
          </div>
        );
        if (b.type === "image") return showImage(b.src, i) ? <img src={`${base}/images/${b.src}`} alt={b.alt || ""} loading="lazy" /> : null;
        return null;
      })}
    </div>
  </div>
)}

{isHint && (
  <div class="ws-section ws-hints">
    <button class="hints-toggle" type="button" aria-expanded="false">
      <span class="hints-icon" aria-hidden="true">💡</span>
      <span class="hints-label">Hints</span>
      <span class="hints-count">{paragraphs.length} available — click to reveal</span>
      <span class="hints-arrow" aria-hidden="true">▼</span>
    </button>
    <div class="hints-body" hidden>
      {section.blocks.map((b: any, i: number) => {
        if (b.type === "p") return <p class="hint-item"><span class="hint-bullet" aria-hidden="true">→</span>{b.text}</p>;
        if (b.type === "image") return showImage(b.src, i) ? <img src={`${base}/images/${b.src}`} alt={b.alt || ""} loading="lazy" /> : null;
        return null;
      })}
    </div>
  </div>
)}

{!isOverToYou && !isChallenge && !isHint && (
  <div class="ws-section ws-content-section">
    <div class="section-header">
      <span class="section-icon" aria-hidden="true">{isOverview ? "🎓" : "📖"}</span>
      <h2>{section.heading || "Overview"}</h2>
      {isOverview && <span class="section-tag teacher-tag">Teacher Guide</span>}
    </div>

    {isOverview && paragraphs.length > 0 && (
      <ul class="teacher-bullets">
        {paragraphs.map((b: any) => (
          <li class="teacher-bullet-item">
            <span class="bullet-dot" aria-hidden="true">▸</span>
            <span>{b.text}</span>
          </li>
        ))}
      </ul>
    )}

    {!isOverview && section.blocks.map((b: any, i: number) => {
      if (b.type === "p") return <p>{b.text}</p>;
      if (b.type === "image") return showImage(b.src, i) ? (
        <img src={`${base}/images/${b.src}`} alt={b.alt || ""} loading="lazy" />
      ) : null;
      if (b.type === "youtube") return (
        <div class="yt-card">
          <div class="yt" data-ytembed={`https://www.youtube.com/embed/${b.id}?autoplay=1`}>
            <img class="yt-thumb" src={`https://img.youtube.com/vi/${b.id}/maxresdefault.jpg`} alt="YouTube video thumbnail" loading="lazy" />
            <div class="yt-play">
              <svg viewBox="0 0 68 48" xmlns="http://www.w3.org/2000/svg">
                <path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="#ff0000"/>
                <path d="M45 24 27 14v20" fill="#fff"/>
              </svg>
            </div>
          </div>
          <a class="yt-external" href={b.url} target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19 19H5V5h7V3H5a2 2 0 002 2v14a2 2 0 002 2h14a2 2 0 002-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/></svg>
            Open on YouTube
          </a>
        </div>
      );
      return null;
    })}

    {isOverview && section.blocks.filter((b: any) => b.type !== "p").map((b: any, i: number) => {
      if (b.type === "image") return showImage(b.src, section.blocks.indexOf(b)) ? (
        <img src={`${base}/images/${b.src}`} alt={b.alt || ""} loading="lazy" />
      ) : null;
      if (b.type === "youtube") return (
        <div class="yt-card">
          <div class="yt" data-ytembed={`https://www.youtube.com/embed/${b.id}?autoplay=1`}>
            <img class="yt-thumb" src={`https://img.youtube.com/vi/${b.id}/maxresdefault.jpg`} alt="YouTube video thumbnail" loading="lazy" />
            <div class="yt-play">
              <svg viewBox="0 0 68 48" xmlns="http://www.w3.org/2000/svg">
                <path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="#ff0000"/>
                <path d="M45 24 27 14v20" fill="#fff"/>
              </svg>
            </div>
          </div>
          <a class="yt-external" href={b.url} target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19 19H5V5h7V3H5a2 2 0 002 2v14a2 2 0 002 2h14a2 2 0 002-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/></svg>
            Open on YouTube
          </a>
        </div>
      );
      return null;
    })}

    <div class="callout-buttons">
      {calloutButtons.map(btn => (
        <button class="callout-btn" disabled type="button" aria-disabled="true">
          <span class="callout-icon" aria-hidden="true">{btn.icon}</span>
          <span class="callout-label">{btn.label}</span>
          <span class="callout-soon">Coming Soon</span>
        </button>
      ))}
    </div>
  </div>
)}

<script>
  document.querySelectorAll<HTMLElement>('.yt[data-ytembed]').forEach(el => {
    el.addEventListener('click', () => {
      const src = el.dataset.ytembed!;
      const iframe = document.createElement('iframe');
      iframe.src = src;
      iframe.title = 'YouTube video player';
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
      iframe.allowFullscreen = true;
      el.innerHTML = '';
      el.appendChild(iframe);
    }, { once: true });
  });
</script>
