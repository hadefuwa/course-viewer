---
import "../styles/global.css";
import course from "../data/course.json";

interface Props {
  title?: string;
  description?: string;
  active?: "home" | "worksheet";
}
const { title, description, active = "home" } = Astro.props;
const pageTitle = title
  ? `${title} — ${course.title}`
  : `${course.title} — ${course.unit}`;
const desc =
  description ??
  `${course.unit}, a ${course.hours}-hour course from ${course.publisher} delivered with E-blocks 3 and Flowcode Embedded.`;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={desc} />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a class="brand" href={`${base}/unit6`}>
          <span class="logo">M</span>
          <span>
            Unit 6 Microcontrollers <span class="small">· Course Viewer</span>
          </span>
        </a>
        <button class="nav-toggle" id="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
        <nav class="nav" id="main-nav">
          <a href={`${base}/`} style="font-size:13px;">← All Courses</a>
          <a href={`${base}/unit6`} class={active === "home" ? "active" : ""}>Overview</a>
          <a href="https://www.matrixtsl.com/" target="_blank" rel="noopener">Matrix TSL ↗</a>
          <a href={`${base}/admin`} class="admin-nav-link">Admin</a>
        </nav>
      </div>
    </header>
    <script>
      const toggle = document.getElementById('nav-toggle');
      const nav = document.getElementById('main-nav');
      toggle?.addEventListener('click', () => {
        const open = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!open));
        nav?.classList.toggle('open', !open);
      });
      nav?.querySelectorAll('a').forEach(a => {
        a.addEventListener('click', () => {
          toggle?.setAttribute('aria-expanded', 'false');
          nav.classList.remove('open');
        });
      });
    </script>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <span>Generated from <code>{course.source}</code></span>
        <span>Course content © {course.publisher}</span>
        <a href={`${base}/admin`} style="font-size:11px;opacity:0.35;color:inherit;">Admin</a>
      </div>
    </footer>
  </body>
</html>
